      --as-of) AS_OF="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      *) echo "ERROR: unknown list argument: $1" >&2; exit 2 ;;
    esac
  done
  case "$FORMAT" in
    tsv|text) ;;
    *) echo "ERROR: invalid format: $FORMAT (expected 'tsv' or 'text')" >&2; exit 2 ;;
  esac
  cd "$ROOT_DIR" && bqn src_edit/plan_list_cmd.bqn "$BASE_DIR" "$SHOW_ALL" "$FORMAT" "$TEMPORAL" "$AS_OF"
  exit $?
fi

if [[ "$1" == "plan" && "$2" == "related" ]]; then
  shift 2
  INDEX="0"
  PLAN_ID=""
  ACTUAL_DATE=""
  FORMAT="tsv"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --index) INDEX="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      --id) PLAN_ID="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      --actual-date) ACTUAL_DATE="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      --format) FORMAT="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      *) echo "ERROR: unknown related argument: $1" >&2; exit 2 ;;
    esac
  done
  if [[ "$INDEX" == "0" && -z "$PLAN_ID" ]]; then
    echo "ERROR: must specify plan using --index or --id" >&2
    exit 2
  fi
  if [[ -z "$ACTUAL_DATE" ]]; then
    echo "ERROR: missing required option: --actual-date" >&2
    exit 2
  fi
  case "$FORMAT" in
    tsv) ;;
    *) echo "ERROR: invalid format: $FORMAT (expected 'tsv')" >&2; exit 2 ;;
  esac
  cd "$ROOT_DIR" && bqn src_edit/plan_related_cmd.bqn "$BASE_DIR" "$INDEX" "$PLAN_ID" "$ACTUAL_DATE" "$FORMAT"
  exit $?
fi

if [[ "$1" == "issue" && "$2" == "list" ]]; then
  shift 2
  EXPECTED_TARGET_FILE="$ISSUES_FILE"
  handle_edit_bqn_issue_list "$@"
  exit $?
fi

if [[ "$1" == "issue" && "$2" == "close" ]]; then
  shift 2
  EXPECTED_TARGET_FILE="$ISSUES_FILE"
  handle_edit_bqn_issue_close "$@"
  exit $?
fi

if [[ "$2" != "add" ]]; then
  echo "ERROR: tools/edit-bqn currently supports only: account list, journal add/multi-add, journal list, journal reverse, budget add, issue add/list/close, plan add, plan list, plan related, plan finish, and plan edit" >&2
  usage
  exit 2
fi
COMMAND="$1"
case "$COMMAND" in
  journal)
    EXPECTED_TARGET_FILE="$JOURNAL_FILE"
    PREVIEW_TITLE="Journal"
    ROW_TITLE="Journal row"
    ;;
  budget)
    EXPECTED_TARGET_FILE="$BUDGET_ALLOC_FILE"
    PREVIEW_TITLE="Budget allocation"
    ROW_TITLE="Budget allocation row"
    ;;
  plan)
    EXPECTED_TARGET_FILE="$PLAN_FILE"
    PREVIEW_TITLE="Plan"
    ROW_TITLE="Plan row"
    ;;
  issue)
    EXPECTED_TARGET_FILE="$ISSUES_FILE"
    PREVIEW_TITLE="Issue"
    ROW_TITLE="Issue row"
    ;;
  *)
    echo "ERROR: tools/edit-bqn currently supports only: account list, journal add/multi-add, journal list, journal reverse, budget add, issue add/list/close, plan add, plan list, plan related, plan finish, and plan edit" >&2
    usage
    exit 2
    ;;
esac
shift 2

if [[ "$COMMAND" == "issue" ]]; then
  handle_edit_bqn_issue_add "$@"
  exit $?
fi
DATE=""
MEMO=""
FROM=""
TO=""
AMOUNT=""
CURRENCY=""
META=()
PLAN_ID=""
DRY_RUN=0
YES=0
POST_CHECK="lint"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --date) DATE="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
    --memo) MEMO="$(get_opt_val_allow_empty "$1" "${2-}")"; shift 2 ;;
    --from) FROM="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
    --to) TO="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
    --amount) AMOUNT="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
    --currency) CURRENCY="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
    --meta) META+=("$(get_opt_val "$1" "${2-}")"); shift 2 ;;
    --id) PLAN_ID="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
    --dry-run) DRY_RUN=1; shift ;;
    --yes) YES=1; shift ;;
    --post-check) POST_CHECK="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
    *) echo "ERROR: unknown option $1" >&2; exit 2 ;;
  esac
done

if [[ "$COMMAND" != "journal" && "$COMMAND" != "budget" && "$COMMAND" != "plan" && -n "$CURRENCY" ]]; then
  echo "ERROR: --currency is currently supported only for journal, budget, and plan add" >&2
  exit 2
fi
edit_bqn_validate_post_check "$POST_CHECK"

# The stable `journal add` surface follows the explicit BQN-owned source route.
# Journal mode delegates to the native block writer only; it never also writes TSV.
if [[ "$COMMAND" == "journal" ]]; then
  ACTUAL_ROUTE="$(cd "$ROOT_DIR" && bqn src_edit/actual_source_route_cmd.bqn "$BASE_DIR")"
  IFS=$'\t' read -r ACTUAL_MODE ACTUAL_FILE ACTUAL_EXTRA <<< "$ACTUAL_ROUTE"
  [[ -z "${ACTUAL_EXTRA:-}" ]] || { echo "ERROR: invalid actual-source route" >&2; exit 1; }
  if [[ "$ACTUAL_MODE" == "journal" ]]; then
    [[ -z "$CURRENCY" || "$CURRENCY" == "JPY" ]] || { echo "ERROR: native Journal daily add currently supports JPY only" >&2; exit 1; }
    for item in "${META[@]}"; do
      [[ "$item" != "income_budget=unassigned" ]] || { echo "ERROR: native Journal income budget companion is not yet supported; no files changed" >&2; exit 1; }
    done
    native_args=(--base "$BASE_DIR" journal-block add --identity ordinary --journal-file "$ACTUAL_FILE" --date "$DATE" --description "$MEMO" --posting "$TO=$AMOUNT" --posting "$FROM=-$AMOUNT" --post-check "$POST_CHECK")
    for item in "${META[@]}"; do native_args+=(--meta "$item"); done
    [[ "$DRY_RUN" -eq 1 ]] && native_args+=(--dry-run)
    [[ "$YES" -eq 1 ]] && native_args+=(--yes)
    exec "$0" "${native_args[@]}"
  fi
fi

TARGET_PATH="$BASE_DIR/$EXPECTED_TARGET_FILE"
SNAPSHOT_TOKEN="$(safe_snapshot_token "$TARGET_PATH")"
IFS=$'\t' read -r SNAP_SIZE SNAP_MTIME SNAP_SHA256 <<< "$SNAPSHOT_TOKEN"

BQN_STDERR="$(mktemp)"
trap 'rm -f "$BQN_STDERR"' EXIT
BQN_OUT=""
if [[ "$COMMAND" == "plan" ]]; then
  if ! BQN_OUT="$(cd "$ROOT_DIR" && bqn src_edit/plan_add_cmd.bqn "$BASE_DIR" "$DATE" "$MEMO" "$FROM" "$TO" "$AMOUNT" "$PLAN_ID" "$CURRENCY" "${META[@]}" 2>"$BQN_STDERR")"; then
    if [[ -n "$BQN_OUT" ]]; then
      printf '%s\n' "$BQN_OUT" >&2
    fi
    if [[ -s "$BQN_STDERR" ]]; then
      cat "$BQN_STDERR" >&2
    fi
    exit 1
  fi
else
  if ! BQN_OUT="$(cd "$ROOT_DIR" && bqn src_edit/journal_add_cmd.bqn "$BASE_DIR" "$COMMAND" "$DATE" "$MEMO" "$FROM" "$TO" "$AMOUNT" "$CURRENCY" "${META[@]}" 2>"$BQN_STDERR")"; then
    if [[ -n "$BQN_OUT" ]]; then
      printf '%s\n' "$BQN_OUT" >&2
    fi
    if [[ -s "$BQN_STDERR" ]]; then
      cat "$BQN_STDERR" >&2
    fi
    exit 1
  fi
fi

if ! edit_bqn_split_protocol_output "$BQN_OUT"; then
  exit 1
fi
FIRST_LINE="$EDIT_BQN_PROTOCOL_FIRST_LINE"
PAYLOAD="$EDIT_BQN_PROTOCOL_PAYLOAD"

INCOME_SYNC_TXN_ID=""
if [[ "$COMMAND" == "journal" ]]; then
  if ! edit_bqn_require_append_protocol_prefix "$FIRST_LINE" "$EXPECTED_TARGET_FILE"; then exit 1; fi
  IFS=$'\t' read -r _status _op _target INCOME_SYNC_TXN_ID _extra <<< "$FIRST_LINE"
  [[ -z "${_extra:-}" ]] || { echo "ERROR: invalid journal protocol header: $FIRST_LINE" >&2; exit 1; }
else
  if ! edit_bqn_require_append_protocol "$FIRST_LINE" "$EXPECTED_TARGET_FILE"; then exit 1; fi
fi

MODE="$(edit_bqn_mode "$DRY_RUN" "$YES")"

if [[ "$DRY_RUN" -eq 1 ]]; then
  edit_bqn_print_append_preview "$PREVIEW_TITLE" "$TARGET_PATH" "$MODE" "$POST_CHECK" "$ROW_TITLE" "$PAYLOAD"
  printf 'Dry-run only. No files were modified.\n'
  exit 0
fi

if [[ "$YES" -eq 0 ]]; then
  edit_bqn_print_append_preview "$PREVIEW_TITLE" "$TARGET_PATH" "$MODE" "$POST_CHECK" "$ROW_TITLE" "$PAYLOAD"
  if ! confirm_append; then
    echo "Cancelled. No files were modified."
    exit 0
  fi
fi

# Test-only stale-write injection point used by check-edit-bqn-journal-add.sh.
# This must not become production extension behavior; it exists only to simulate
# a concurrent source TSV edit between validation/preview and append.
POST_CHECK_OWNER="default"
[[ "$COMMAND" == "journal" ]] && POST_CHECK_OWNER="journal"
edit_bqn_apply_append_checked "$BASE_DIR" "$POST_CHECK" "$TARGET_PATH" "$PAYLOAD" "$SNAP_SIZE" "$SNAP_MTIME" "$SNAP_SHA256" EDIT_BQN_TEST_BEFORE_APPEND_HOOK "$POST_CHECK_OWNER"
if [[ -n "$INCOME_SYNC_TXN_ID" ]]; then
  sync_args=(--id "$INCOME_SYNC_TXN_ID" --post-check "$POST_CHECK")
  [[ "$YES" -eq 1 ]] && sync_args+=(--yes)
  if ! "$ROOT_DIR/tools/edit" --base "$BASE_DIR" journal income-budget-sync "${sync_args[@]}"; then
    echo "BUDGET_SYNC_PENDING: journal actual is committed; retry with: tools/edit --base '$BASE_DIR' journal income-budget-sync --id '$INCOME_SYNC_TXN_ID'" >&2
    exit 1
  fi
fi
