#!/usr/bin/env bash
# tools/edit-bqn — BQN-backed editor entry point.
#
# Current scope: daily write commands (`journal add`, `budget add`, `issue add`,
# `plan add`, `plan list`, `plan finish`, `plan edit`, `journal reverse`).
# `tools/edit` is the public wrapper that delegates here.
#
# Shared parsing/protocol/write handling is kept in one path for the
# journal-like append commands instead of copy-pasting command branches.

set -euo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$DIR/.." && pwd)"
# shellcheck source=tools/lib/system-defaults.sh
source "$DIR/lib/system-defaults.sh"
# shellcheck source=tools/lib/safe-write.sh
source "$DIR/lib/safe-write.sh"
# shellcheck source=tools/lib/edit-bqn-common.sh
source "$DIR/lib/edit-bqn-common.sh"
# shellcheck source=tools/lib/edit-bqn-issue.sh
source "$DIR/lib/edit-bqn-issue.sh"

BASE_DIR="${LEDGER_DATA_DIR:-$(get_default_base_dir)}"
JOURNAL_FILE="$(get_system_default_file DEFAULT_JOURNAL_FILE journal.tsv)"
BUDGET_ALLOC_FILE="$(get_system_default_file DEFAULT_BUDGET_ALLOC_FILE budget_alloc.tsv)"
PLAN_FILE="$(get_system_default_file DEFAULT_PLAN_FILE plan.tsv)"
ISSUES_FILE="issues.tsv"

usage() {
  cat <<'USAGE' >&2
Usage:
  tools/edit-bqn [--base DIR] journal add --date YYYY-MM-DD --memo MEMO --from ACCOUNT --to ACCOUNT --amount INT [--meta key=value ...] [--dry-run] [--yes] [--post-check none|lint|full]
  tools/edit-bqn [--base DIR] budget add  --date YYYY-MM-DD --memo MEMO --from ACCOUNT --to ACCOUNT --amount INT [--meta key=value ...] [--dry-run] [--yes] [--post-check none|lint|full]
  tools/edit-bqn [--base DIR] plan add --date YYYY-MM-DD --memo MEMO --from ACCOUNT --to ACCOUNT --amount INT [--meta key=value ...] [--id plan-YYYY-MM-DD-series] [--dry-run] [--yes] [--post-check none|lint|full]
  tools/edit-bqn [--base DIR] issue add [--date YYYY-MM-DD] [--status open|resolved|dropped] --title TITLE [--amount INT] [--memo MEMO] [--dry-run] [--yes]
  tools/edit-bqn [--base DIR] account list [--role ROLE]
  tools/edit-bqn [--base DIR] plan list [--all] [--format tsv|text]
  tools/edit-bqn [--base DIR] plan related [--index NUMBER] [--id PLAN_ID] --actual-date YYYY-MM-DD [--format tsv]
  tools/edit-bqn [--base DIR] plan finish [--index NUMBER] [--id PLAN_ID] --actual-date YYYY-MM-DD [--dry-run] [--yes] [--post-check none|lint|full]
  tools/edit-bqn [--base DIR] plan edit [--index NUMBER] [--id PLAN_ID] [--date YYYY-MM-DD] [--amount INT] [--all] [--dry-run] [--yes] [--post-check none|lint|full]
  tools/edit-bqn [--base DIR] journal reverse [--index NUMBER] [--id TXN_ID] [--date YYYY-MM-DD] [--dry-run] [--yes] [--post-check none|lint|full]

Current scope: BQN editor daily commands (journal/budget/plan/issue add, account list, plan list, plan related, plan finish, plan edit, journal reverse).
USAGE
}

REM_ARGS=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --base)
      BASE_DIR="$(get_opt_val "$1" "${2-}")"
      shift 2
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      REM_ARGS+=("$1")
      shift
      ;;
  esac
done
set -- "${REM_ARGS[@]}"

if [[ $# -lt 2 ]]; then
  echo "ERROR: missing command/subcommand" >&2
  usage
  exit 2
fi

if [[ "$1" == "account" && "$2" == "list" ]]; then
  shift 2
  ROLE=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --role) ROLE="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      *) echo "ERROR: unknown account list argument: $1" >&2; exit 2 ;;
    esac
  done
  cd "$ROOT_DIR" && bqn src_edit/account_list_cmd.bqn "$BASE_DIR" "$ROLE"
  exit $?
fi

if [[ "$1" == "journal" && "$2" == "reverse" ]]; then
  shift 2
  INDEX="0"
  ID=""
  DATE=""
  DRY_RUN=0
  YES=0
  POST_CHECK="lint"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --index) INDEX="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      --id) ID="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      --date) DATE="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      --dry-run) DRY_RUN=1; shift ;;
      --yes) YES=1; shift ;;
      --post-check) POST_CHECK="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      *) echo "ERROR: unknown option: $1" >&2; exit 2 ;;
    esac
  done

  if [[ "$INDEX" == "0" && -z "$ID" ]]; then
    echo "ERROR: must specify journal row to reverse using --index or --id" >&2
    exit 2
  fi
  edit_bqn_validate_post_check "$POST_CHECK"

  TARGET_PATH="$BASE_DIR/$JOURNAL_FILE"
  SNAPSHOT_TOKEN="$(safe_snapshot_token "$TARGET_PATH")"
  IFS=$'\t' read -r SNAP_SIZE SNAP_MTIME SNAP_SHA256 <<< "$SNAPSHOT_TOKEN"

  BQN_STDERR="$(mktemp)"
  trap 'rm -f "$BQN_STDERR"' EXIT
  BQN_OUT=""
  if ! BQN_OUT="$(cd "$ROOT_DIR" && bqn src_edit/editor_cmd.bqn "$BASE_DIR" journal reverse "$ID" "$INDEX" "$DATE" "$YES" 2>"$BQN_STDERR")"; then
    if [[ -n "$BQN_OUT" ]]; then
      printf '%s\n' "$BQN_OUT" >&2
    fi
    if [[ -s "$BQN_STDERR" ]]; then
      cat "$BQN_STDERR" >&2
    fi
    exit 1
  fi

  FIRST_LINE="${BQN_OUT%%$'\n'*}"
  if [[ "$FIRST_LINE" == "$BQN_OUT" ]]; then
    echo "ERROR: invalid BQN protocol: missing payload line" >&2
    exit 1
  fi
  PAYLOAD="${BQN_OUT#*$'\n'}"

  IFS=$'\t' read -r STATUS OP PROTOCOL_TARGET_FILE TARGET_IDX ORIG_DATE ORIG_MEMO ORIG_FROM ORIG_TO ORIG_AMOUNT <<< "$FIRST_LINE"
  if [[ "$STATUS" == "ERROR" ]]; then
    echo "ERROR: $OP" >&2
    exit 1
  fi
  if [[ "$STATUS" != "OK" || "$OP" != "APPEND" || "$PROTOCOL_TARGET_FILE" != "$JOURNAL_FILE" ]]; then
    echo "ERROR: invalid BQN protocol header: $FIRST_LINE" >&2
    exit 1
  fi

  MODE="$(edit_bqn_mode "$DRY_RUN" "$YES")"

  printf 'Reversing journal row %s (date=%s, memo=%s)\n' "$TARGET_IDX" "$ORIG_DATE" "$ORIG_MEMO"
  printf '  Original: %s -> %s  %s\n' "$ORIG_FROM" "$ORIG_TO" "$ORIG_AMOUNT"
  printf '  Reversed: %s -> %s  %s\n' "$ORIG_TO" "$ORIG_FROM" "$ORIG_AMOUNT"

  printf 'Journal reverse preview\n'
  printf 'Target: %s\n' "$TARGET_PATH"
  printf 'Mode: %s\n' "$MODE"
  printf 'Post-check: %s\n' "$POST_CHECK"
  printf 'Reversed row:\n'
  printf '%s\n' "$PAYLOAD"

  if [[ "$DRY_RUN" -eq 1 ]]; then
    printf 'Dry-run only. No files were modified.\n'
    exit 0
  fi

  if [[ "$YES" -eq 0 ]]; then
    printf 'Append this row? [y/N]: '
    read -r REPLY
    case "$REPLY" in
      y|Y|yes|YES) ;;
      *) echo "Cancelled. No files were modified."; exit 0 ;;
    esac
  fi

  edit_bqn_run_test_hook EDIT_BQN_TEST_BEFORE_APPEND_HOOK

  WRITE_OUT="$(safe_append_checked "$TARGET_PATH" "$PAYLOAD" "$SNAP_SIZE" "$SNAP_MTIME" "$SNAP_SHA256")"
  printf '%s\n' "$WRITE_OUT"

  BACKUP_PATH="$(awk -F': ' '$1 == "Backup" {print $2}' <<< "$WRITE_OUT")"
  run_post_check "$BASE_DIR" "$POST_CHECK" "$TARGET_PATH" "$BACKUP_PATH"
  exit 0
fi

if [[ "$1" == "plan" && "$2" == "edit" ]]; then
  shift 2
  INDEX="0"
  PLAN_ID=""
  DATE=""
  AMOUNT=""
  SHOW_ALL=0
  DRY_RUN=0
  YES=0
  POST_CHECK="lint"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --index) INDEX="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      --id) PLAN_ID="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      --date) DATE="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      --amount) AMOUNT="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      --all) SHOW_ALL=1; shift ;;
      --dry-run) DRY_RUN=1; shift ;;
      --yes) YES=1; shift ;;
      --post-check) POST_CHECK="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      *) echo "ERROR: unknown option: $1" >&2; exit 2 ;;
    esac
  done

  if [[ "$INDEX" == "0" && -z "$PLAN_ID" ]]; then
    echo "ERROR: must specify plan to edit using --index or --id" >&2
    exit 2
  fi
  if [[ -z "$DATE" && -z "$AMOUNT" ]]; then
    echo "ERROR: must specify at least one of --date or --amount" >&2
    exit 2
  fi
  edit_bqn_validate_post_check "$POST_CHECK"

  TARGET_PATH="$BASE_DIR/$PLAN_FILE"
  SNAPSHOT_TOKEN="$(safe_snapshot_token "$TARGET_PATH")"
  IFS=$'\t' read -r SNAP_SIZE SNAP_MTIME SNAP_SHA256 <<< "$SNAPSHOT_TOKEN"

  BQN_STDERR="$(mktemp)"
  trap 'rm -f "$BQN_STDERR"' EXIT
  BQN_OUT=""
  if ! BQN_OUT="$(cd "$ROOT_DIR" && bqn src_edit/editor_cmd.bqn "$BASE_DIR" plan edit "$INDEX" "$PLAN_ID" "$DATE" "$AMOUNT" "$SHOW_ALL" "$DRY_RUN" "$YES" "$POST_CHECK" 2>"$BQN_STDERR")"; then
    if [[ -n "$BQN_OUT" ]]; then
      printf '%s\n' "$BQN_OUT" >&2
    fi
    if [[ -s "$BQN_STDERR" ]]; then
      cat "$BQN_STDERR" >&2
    fi
    exit 1
  fi

  # Parse REPLACE protocol:
  # BQN outputs:
  # Line 1: OK\tREPLACE\t<lineNum>\t<planID>  (or ERROR\t<msg>)
  # Line 2: <oldLine>
  # Line 3: <newLine>
  bqn_lines=()
  mapfile -t bqn_lines <<< "$BQN_OUT"

  IFS=$'\t' read -r STATUS OP LINE_NUM EDIT_PLAN_ID <<< "${bqn_lines[0]}"
  if [[ "$STATUS" == "ERROR" ]]; then
    echo "ERROR: $OP" >&2
    exit 1
  fi
  if [[ "$STATUS" != "OK" || "$OP" != "REPLACE" ]]; then
    echo "ERROR: unexpected BQN protocol: expected OK REPLACE, got: $STATUS $OP" >&2
    exit 1
  fi

  OLD_LINE="${bqn_lines[1]}"
  NEW_LINE="${bqn_lines[2]}"

  if [[ -z "$LINE_NUM" || -z "$OLD_LINE" || -z "$NEW_LINE" ]]; then
    echo "ERROR: incomplete REPLACE protocol output" >&2
    exit 1
  fi

  MODE="$(edit_bqn_mode "$DRY_RUN" "$YES")"

  # Preview output matching BQN editor format
  printf 'Plan edit preview\n'
  printf 'Target: %s\n' "$TARGET_PATH"
  printf 'Line: %s\n' "$LINE_NUM"
  printf 'Plan ID: %s\n' "$EDIT_PLAN_ID"
  printf 'Mode: %s\n' "$MODE"
  printf 'Post-check: %s\n' "$POST_CHECK"
  printf 'Diff:\n'
  printf -- '- %s\n' "$OLD_LINE"
  printf -- '+ %s\n' "$NEW_LINE"

  if [[ "$DRY_RUN" -eq 1 ]]; then
    printf 'Dry-run only. No files were modified.\n'
    exit 0
  fi

  if [[ "$YES" -eq 0 ]]; then
    printf 'Rewrite this plan row? [y/N]: '
    read -r REPLY
    case "$REPLY" in
      y|Y|yes|YES) ;;
      *) echo "Cancelled. No files were modified."; exit 0 ;;
    esac
  fi

  # Test-only stale-write injection point.
  edit_bqn_run_test_hook EDIT_BQN_TEST_BEFORE_REPLACE_HOOK

  WRITE_OUT="$(safe_replace_line_checked "$TARGET_PATH" "$LINE_NUM" "$OLD_LINE" "$NEW_LINE" "$SNAP_SIZE" "$SNAP_MTIME" "$SNAP_SHA256")"
  printf '%s\n' "$WRITE_OUT"

  BACKUP_PATH="$(awk -F': ' '$1 == "Backup" {print $2}' <<< "$WRITE_OUT")"
  run_post_check "$BASE_DIR" "$POST_CHECK" "$TARGET_PATH" "$BACKUP_PATH"
  exit 0
fi

if [[ "$1" == "plan" && "$2" == "finish" ]]; then
  shift 2
  INDEX="0"
  PLAN_ID=""
  ACTUAL_DATE=""
  APPLY=0
  DRY_RUN_EXPLICIT=0
  YES=0
  POST_CHECK="lint"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --index) INDEX="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      --id) PLAN_ID="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      --actual-date) ACTUAL_DATE="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      --apply) APPLY=1; shift ;;
      --dry-run) DRY_RUN_EXPLICIT=1; shift ;;
      --yes) YES=1; shift ;;
      --post-check) POST_CHECK="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      *) echo "ERROR: unknown option: $1" >&2; exit 2 ;;
    esac
  done

  if [[ "$APPLY" -eq 1 && "$DRY_RUN_EXPLICIT" -eq 0 ]]; then
    DRY_RUN=0
  else
    DRY_RUN=1
  fi

  if [[ "$INDEX" == "0" && -z "$PLAN_ID" ]]; then
    echo "ERROR: must specify plan to finish using --index or --id" >&2
    exit 2
  fi
  if [[ -z "$ACTUAL_DATE" ]]; then
    echo "ERROR: missing required option: --actual-date" >&2
    exit 2
  fi

  TARGET_PATH="$BASE_DIR/$JOURNAL_FILE"
  SNAPSHOT_TOKEN="$(safe_snapshot_token "$TARGET_PATH")"
  IFS=$'\t' read -r SNAP_SIZE SNAP_MTIME SNAP_SHA256 <<< "$SNAPSHOT_TOKEN"

  BQN_STDERR="$(mktemp)"
  trap 'rm -f "$BQN_STDERR"' EXIT
  BQN_OUT=""
  if ! BQN_OUT="$(cd "$ROOT_DIR" && bqn src_edit/plan_finish_cmd.bqn "$BASE_DIR" "$INDEX" "$PLAN_ID" "$ACTUAL_DATE" 2>"$BQN_STDERR")"; then
    if [[ -n "$BQN_OUT" ]]; then
      printf '%s\n' "$BQN_OUT" >&2
    fi
    if [[ -s "$BQN_STDERR" ]]; then
      cat "$BQN_STDERR" >&2
    fi
    exit 1
  fi

  FIRST_LINE="${BQN_OUT%%$'\n'*}"
  if [[ "$FIRST_LINE" == "$BQN_OUT" ]]; then
    echo "ERROR: invalid BQN protocol: missing payload line" >&2
    exit 1
  fi
  PAYLOAD="${BQN_OUT#*$'\n'}"

  IFS=$'\t' read -r STATUS OP PROTOCOL_TARGET_FILE EXTRA <<< "$FIRST_LINE"
  if [[ -n "${EXTRA:-}" || "$STATUS" != "OK" || "$OP" != "APPEND" || "$PROTOCOL_TARGET_FILE" != "$JOURNAL_FILE" ]]; then
    echo "ERROR: invalid BQN protocol header: $FIRST_LINE" >&2
    exit 1
  fi

  MODE="$(edit_bqn_mode "$DRY_RUN" "$YES")"

  if [[ "$DRY_RUN" -eq 1 ]]; then
    printf 'Journal (from plan) append preview\n'
    printf 'Target: %s\n' "$TARGET_PATH"
    printf 'Mode: %s\n' "$MODE"
    printf 'Post-check: %s\n' "$POST_CHECK"
    printf 'Journal row:\n'
    printf '%s\n' "$PAYLOAD"
    printf 'Dry-run only. No files were modified.\n'
    exit 0
  fi

  if [[ "$YES" -eq 0 ]]; then
    printf 'Journal (from plan) append preview\n'
    printf 'Target: %s\n' "$TARGET_PATH"
    printf 'Mode: %s\n' "$MODE"
    printf 'Post-check: %s\n' "$POST_CHECK"
    printf 'Journal row:\n'
    printf '%s\n' "$PAYLOAD"
    if ! confirm_append; then
      echo "Cancelled. No files were modified."
      exit 0
    fi
  fi

  edit_bqn_run_test_hook EDIT_BQN_TEST_BEFORE_APPEND_HOOK

  WRITE_OUT="$(safe_append_checked "$TARGET_PATH" "$PAYLOAD" "$SNAP_SIZE" "$SNAP_MTIME" "$SNAP_SHA256")"
  printf '%s\n' "$WRITE_OUT"

  BACKUP_PATH="$(awk -F': ' '$1 == "Backup" {print $2}' <<< "$WRITE_OUT")"
  run_post_check "$BASE_DIR" "$POST_CHECK" "$TARGET_PATH" "$BACKUP_PATH"
  exit 0
fi

if [[ "$1" == "plan" && "$2" == "list" ]]; then
  shift 2
  SHOW_ALL=0
  FORMAT="text"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --all) SHOW_ALL=1; shift ;;
      --format) FORMAT="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      *) echo "ERROR: unknown list argument: $1" >&2; exit 2 ;;
    esac
  done
  case "$FORMAT" in
    tsv|text) ;;
    *) echo "ERROR: invalid format: $FORMAT (expected 'tsv' or 'text')" >&2; exit 2 ;;
  esac
  cd "$ROOT_DIR" && bqn src_edit/plan_list_cmd.bqn "$BASE_DIR" "$SHOW_ALL" "$FORMAT"
  exit $?
fi

if [[ "$1" == "plan" && "$2" == "related" ]]; then
  shift 2
  INDEX="0"
  PLAN_ID=""
  ACTUAL_DATE=""
  FORMAT="tsv"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --index) INDEX="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      --id) PLAN_ID="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      --actual-date) ACTUAL_DATE="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      --format) FORMAT="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      *) echo "ERROR: unknown related argument: $1" >&2; exit 2 ;;
    esac
  done
  if [[ "$INDEX" == "0" && -z "$PLAN_ID" ]]; then
    echo "ERROR: must specify plan using --index or --id" >&2
    exit 2
  fi
  if [[ -z "$ACTUAL_DATE" ]]; then
    echo "ERROR: missing required option: --actual-date" >&2
    exit 2
  fi
  case "$FORMAT" in
    tsv) ;;
    *) echo "ERROR: invalid format: $FORMAT (expected 'tsv')" >&2; exit 2 ;;
  esac
  cd "$ROOT_DIR" && bqn src_edit/plan_related_cmd.bqn "$BASE_DIR" "$INDEX" "$PLAN_ID" "$ACTUAL_DATE" "$FORMAT"
  exit $?
fi

if [[ "$2" != "add" ]]; then
  echo "ERROR: tools/edit-bqn currently supports only: account list, journal add, journal reverse, budget add, plan add, issue add, plan list, plan related, plan finish, and plan edit" >&2
  usage
  exit 2
fi
COMMAND="$1"
case "$COMMAND" in
  journal)
    EXPECTED_TARGET_FILE="$JOURNAL_FILE"
    PREVIEW_TITLE="Journal"
    ROW_TITLE="Journal row"
    ;;
  budget)
    EXPECTED_TARGET_FILE="$BUDGET_ALLOC_FILE"
    PREVIEW_TITLE="Budget allocation"
    ROW_TITLE="Budget allocation row"
    ;;
  plan)
    EXPECTED_TARGET_FILE="$PLAN_FILE"
    PREVIEW_TITLE="Plan"
    ROW_TITLE="Plan row"
    ;;
  issue)
    EXPECTED_TARGET_FILE="$ISSUES_FILE"
    PREVIEW_TITLE="Issue"
    ROW_TITLE="Issue row"
    ;;
  *)
    echo "ERROR: tools/edit-bqn currently supports only: account list, journal add, journal reverse, budget add, plan add, issue add, plan list, plan related, plan finish, and plan edit" >&2
    usage
    exit 2
    ;;
esac
shift 2

if [[ "$COMMAND" == "issue" ]]; then
  handle_edit_bqn_issue_add "$@"
  exit $?
fi
DATE=""
MEMO=""
FROM=""
TO=""
AMOUNT=""
META=()
PLAN_ID=""
DRY_RUN=0
YES=0
POST_CHECK="lint"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --date) DATE="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
    --memo) MEMO="$(get_opt_val_allow_empty "$1" "${2-}")"; shift 2 ;;
    --from) FROM="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
    --to) TO="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
    --amount) AMOUNT="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
    --meta) META+=("$(get_opt_val "$1" "${2-}")"); shift 2 ;;
    --id) PLAN_ID="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
    --dry-run) DRY_RUN=1; shift ;;
    --yes) YES=1; shift ;;
    --post-check) POST_CHECK="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
    *) echo "ERROR: unknown option $1" >&2; exit 2 ;;
  esac
done

edit_bqn_validate_post_check "$POST_CHECK"

TARGET_PATH="$BASE_DIR/$EXPECTED_TARGET_FILE"
SNAPSHOT_TOKEN="$(safe_snapshot_token "$TARGET_PATH")"
IFS=$'\t' read -r SNAP_SIZE SNAP_MTIME SNAP_SHA256 <<< "$SNAPSHOT_TOKEN"

BQN_STDERR="$(mktemp)"
trap 'rm -f "$BQN_STDERR"' EXIT
BQN_OUT=""
if [[ "$COMMAND" == "plan" ]]; then
  if ! BQN_OUT="$(cd "$ROOT_DIR" && bqn src_edit/plan_add_cmd.bqn "$BASE_DIR" "$DATE" "$MEMO" "$FROM" "$TO" "$AMOUNT" "$PLAN_ID" "${META[@]}" 2>"$BQN_STDERR")"; then
    if [[ -n "$BQN_OUT" ]]; then
      printf '%s\n' "$BQN_OUT" >&2
    fi
    if [[ -s "$BQN_STDERR" ]]; then
      cat "$BQN_STDERR" >&2
    fi
    exit 1
  fi
else
  if ! BQN_OUT="$(cd "$ROOT_DIR" && bqn src_edit/journal_add_cmd.bqn "$BASE_DIR" "$COMMAND" "$DATE" "$MEMO" "$FROM" "$TO" "$AMOUNT" "${META[@]}" 2>"$BQN_STDERR")"; then
    if [[ -n "$BQN_OUT" ]]; then
      printf '%s\n' "$BQN_OUT" >&2
    fi
    if [[ -s "$BQN_STDERR" ]]; then
      cat "$BQN_STDERR" >&2
    fi
    exit 1
  fi
fi

FIRST_LINE="${BQN_OUT%%$'\n'*}"
if [[ "$FIRST_LINE" == "$BQN_OUT" ]]; then
  echo "ERROR: invalid BQN protocol: missing payload line" >&2
  exit 1
fi
PAYLOAD="${BQN_OUT#*$'\n'}"

IFS=$'\t' read -r STATUS OP PROTOCOL_TARGET_FILE EXTRA <<< "$FIRST_LINE"
if [[ -n "${EXTRA:-}" || "$STATUS" != "OK" || "$OP" != "APPEND" || "$PROTOCOL_TARGET_FILE" != "$EXPECTED_TARGET_FILE" ]]; then
  echo "ERROR: invalid BQN protocol header: $FIRST_LINE" >&2
  exit 1
fi

MODE="$(edit_bqn_mode "$DRY_RUN" "$YES")"

if [[ "$DRY_RUN" -eq 1 ]]; then
  printf '%s append preview\n' "$PREVIEW_TITLE"
  printf 'Target: %s\n' "$TARGET_PATH"
  printf 'Mode: %s\n' "$MODE"
  printf 'Post-check: %s\n' "$POST_CHECK"
  printf '%s:\n' "$ROW_TITLE"
  printf '%s\n' "$PAYLOAD"
  printf 'Dry-run only. No files were modified.\n'
  exit 0
fi

if [[ "$YES" -eq 0 ]]; then
  printf '%s append preview\n' "$PREVIEW_TITLE"
  printf 'Target: %s\n' "$TARGET_PATH"
  printf 'Mode: %s\n' "$MODE"
  printf 'Post-check: %s\n' "$POST_CHECK"
  printf '%s:\n' "$ROW_TITLE"
  printf '%s\n' "$PAYLOAD"
  if ! confirm_append; then
    echo "Cancelled. No files were modified."
    exit 0
  fi
fi

# Test-only stale-write injection point used by check-edit-bqn-journal-add.sh.
# This must not become production extension behavior; it exists only to simulate
# a concurrent source TSV edit between validation/preview and append.
edit_bqn_run_test_hook EDIT_BQN_TEST_BEFORE_APPEND_HOOK

WRITE_OUT="$(safe_append_checked "$TARGET_PATH" "$PAYLOAD" "$SNAP_SIZE" "$SNAP_MTIME" "$SNAP_SHA256")"
printf '%s\n' "$WRITE_OUT"

BACKUP_PATH="$(awk -F': ' '$1 == "Backup" {print $2}' <<< "$WRITE_OUT")"
run_post_check "$BASE_DIR" "$POST_CHECK" "$TARGET_PATH" "$BACKUP_PATH"
