  [[ "$OP" == "CLEANUP_REWRITE" || "$OP" == "CLEANUP_NOOP" ]] || { echo "ERROR: invalid cleanup prepare operation" >&2; exit 1; }
  if [[ "$OP" == "CLEANUP_NOOP" ]]; then
    [[ "$REMOVAL_COUNT" -eq 0 && "${#CLEANUP_LINES[@]}" -eq 1 ]] || { echo "ERROR: invalid cleanup no-op protocol" >&2; exit 1; }
    echo "No removable legacy event IDs. No files were modified."
    exit 0
  fi
  [[ "$REMOVAL_COUNT" -gt 0 && "${#CLEANUP_LINES[@]}" -eq $((REMOVAL_COUNT + 1)) && -f "$CANDIDATE_FILE" ]] || { echo "ERROR: incomplete cleanup rewrite protocol" >&2; exit 1; }
  for ((i=1; i<${#CLEANUP_LINES[@]}; i++)); do
    IFS=$'\t' read -r ROW_OP ROW_NUMBER EVENT_LINE ROW_DATE ROW_EVENT_ID ROW_DESCRIPTION ROW_EXTRA <<< "${CLEANUP_LINES[$i]}"
    [[ "$ROW_OP" == "REMOVE" && "$ROW_NUMBER" =~ ^[0-9]+$ && "$EVENT_LINE" =~ ^[0-9]+$ && -n "$ROW_DATE" && -n "$ROW_EVENT_ID" && -n "$ROW_DESCRIPTION" && -z "${ROW_EXTRA:-}" ]] || { echo "ERROR: invalid cleanup removal manifest row" >&2; exit 1; }
  done
  _safe_write_check_expected_snapshot "$TARGET_PATH" "$SNAP_SIZE" "$SNAP_MTIME" "$SNAP_SHA256" || exit 1

  MODE="$(edit_bqn_mode "$DRY_RUN" "$YES")"
  printf 'Journal legacy entry-id cleanup preview\nTarget: %s\nMode: %s\nPost-check: %s\nRemoval count: %s\n' "$TARGET_PATH" "$MODE" "$POST_CHECK" "$REMOVAL_COUNT"
  for ((i=1; i<${#CLEANUP_LINES[@]}; i++)); do
