#!/usr/bin/env bash
# tools/edit-bqn — BQN-backed editor entry point.
#
# Current scope: daily commands (`account add/list`, `journal add/list/reverse`,
# `budget add`, `issue add/list/close`, and `plan add/list/related/finish/edit`).
# plus dedicated `travel friend add` and `travel exchange add` source-event commands.
# `tools/edit` is the public wrapper that delegates here.
#
# Shared parsing/protocol/write handling is kept in one path for the
# journal-like append commands instead of copy-pasting command branches.

set -euo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$DIR/.." && pwd)"
# shellcheck source=tools/lib/system-defaults.sh
source "$DIR/lib/system-defaults.sh"
# shellcheck source=tools/lib/safe-write.sh
source "$DIR/lib/safe-write.sh"
# shellcheck source=tools/lib/edit-bqn-common.sh
source "$DIR/lib/edit-bqn-common.sh"
# shellcheck source=tools/lib/edit-bqn-issue.sh
source "$DIR/lib/edit-bqn-issue.sh"
# shellcheck source=tools/lib/edit-bqn-travel.sh
source "$DIR/lib/edit-bqn-travel.sh"

BASE_DIR="${LEDGER_DATA_DIR:-$(get_default_base_dir)}"
JOURNAL_FILE="$(get_system_default_file DEFAULT_JOURNAL_FILE journal.tsv)"
BUDGET_ALLOC_FILE="$(get_system_default_file DEFAULT_BUDGET_ALLOC_FILE budget_alloc.tsv)"
PLAN_FILE="$(get_system_default_file DEFAULT_PLAN_FILE plan.tsv)"
ISSUES_FILE="issues.tsv"
ACCOUNTS_FILE="$(get_system_default_file DEFAULT_ACCOUNTS_FILE accounts.tsv)"

usage() {
  cat <<'USAGE' >&2
Usage:
  tools/edit-bqn [--base DIR] journal add --date YYYY-MM-DD --memo MEMO --from ACCOUNT --to ACCOUNT --amount DECIMAL [--currency JPY|ILS] [--meta key=value ...] [--dry-run] [--yes] [--post-check none|lint|full]
  tools/edit-bqn [--base DIR] journal income-budget-sync --id TXN_ID [--dry-run] [--yes] [--post-check none|lint|full]
  tools/edit-bqn [--base DIR] budget add  --date YYYY-MM-DD --memo MEMO --from ACCOUNT --to ACCOUNT --amount INT [--meta key=value ...] [--dry-run] [--yes] [--post-check none|lint|full]
  tools/edit-bqn [--base DIR] plan add --date YYYY-MM-DD --memo MEMO --from ACCOUNT --to ACCOUNT --amount INT [--meta key=value ...] [--id plan-YYYY-MM-DD-series] [--dry-run] [--yes] [--post-check none|lint|full]
  tools/edit-bqn [--base DIR] issue add [--date YYYY-MM-DD] [--status open|resolved|dropped] --title TITLE [--amount INT] [--memo MEMO] [--dry-run] [--yes] [--post-check none|lint|full]
  tools/edit-bqn [--base DIR] issue list [--format tsv|text]
  tools/edit-bqn [--base DIR] issue close --index NUMBER [--status resolved|dropped] --decision MEMO [--dry-run] [--yes] [--post-check none|lint|full]
  tools/edit-bqn [--base DIR] account add --name ACCOUNT --role asset|liability|income|expense [--type liquid|savings|invest] [--currency JPY|ILS] [--dry-run] [--yes] [--post-check none|lint|full]
  tools/edit-bqn [--base DIR] account list [--role ROLE] [--currency JPY|ILS]
  tools/edit-bqn [--base DIR] journal list [--format tsv|text]
  tools/edit-bqn [--base DIR] plan list [--all] [--format tsv|text]
  tools/edit-bqn [--base DIR] plan related [--index NUMBER] [--id PLAN_ID] --actual-date YYYY-MM-DD [--format tsv]
  tools/edit-bqn [--base DIR] plan finish [--index NUMBER] [--id PLAN_ID] --actual-date YYYY-MM-DD [--actual-amount INT] [--dry-run] [--yes] [--post-check none|lint|full]
  tools/edit-bqn [--base DIR] plan budget-sync --id PLAN_ID [--dry-run] [--yes] [--post-check none|lint|full]
  tools/edit-bqn [--base DIR] plan edit [--index NUMBER] [--id PLAN_ID] [--date YYYY-MM-DD] [--amount INT] [--all] [--dry-run] [--yes] [--post-check none|lint|full]
  tools/edit-bqn [--base DIR] journal reverse [--index NUMBER] [--id TXN_ID] [--date YYYY-MM-DD] [--dry-run] [--yes] [--post-check none|lint|full]
  tools/edit-bqn [--base DIR] travel friend add --date YYYY-MM-DD --party PARTY --item ITEM --amount DECIMAL --currency ILS --payer friend --trip-id israel-2026 --source-event-id ID [--dry-run] [--yes]
  tools/edit-bqn [--base DIR] travel exchange add --date YYYY-MM-DD --memo MEMO --source-account ACCOUNT --source-amount INT --source-currency JPY --target-account ACCOUNT --target-amount DECIMAL --target-currency ILS --exchange-id ID --trip-id israel-2026 [--dry-run] [--yes]

Current scope: BQN editor daily commands (account add/list, journal/budget/plan/issue add, travel friend/exchange add, issue list/close, journal list/reverse, and plan list/related/finish/edit).
USAGE
}

REM_ARGS=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --base)
      BASE_DIR="$(get_opt_val "$1" "${2-}")"
      shift 2
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      REM_ARGS+=("$1")
      shift
      ;;
  esac
done
set -- "${REM_ARGS[@]}"

if [[ $# -lt 2 ]]; then
  echo "ERROR: missing command/subcommand" >&2
  usage
  exit 2
fi

if [[ "$1" == "travel" && "$2" == "friend" && "${3-}" == "add" ]]; then
  shift 3
  handle_edit_bqn_travel_friend_add "$@"
  exit $?
fi
if [[ "$1" == "travel" && "$2" == "exchange" && "${3-}" == "add" ]]; then
  shift 3
  handle_edit_bqn_travel_exchange_add "$@"
  exit $?
fi

if [[ "$1" == "account" && "$2" == "add" ]]; then
  shift 2
  NAME=""
  ROLE=""
  TYPE=""
  CURRENCY=""
  DRY_RUN=0
  YES=0
  POST_CHECK="lint"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name) NAME="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      --role) ROLE="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      --type) TYPE="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      --currency) CURRENCY="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      --dry-run) DRY_RUN=1; shift ;;
      --yes) YES=1; shift ;;
      --post-check) POST_CHECK="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      *) echo "ERROR: unknown account add argument: $1" >&2; exit 2 ;;
    esac
  done
  [[ -n "$NAME" ]] || { echo "ERROR: missing required option: --name" >&2; exit 2; }
  [[ -n "$ROLE" ]] || { echo "ERROR: missing required option: --role" >&2; exit 2; }
  edit_bqn_validate_post_check "$POST_CHECK"

  TARGET_PATH="$BASE_DIR/$ACCOUNTS_FILE"
  SNAPSHOT_TOKEN="$(safe_snapshot_token "$TARGET_PATH")"
  IFS=$'\t' read -r SNAP_SIZE SNAP_MTIME SNAP_SHA256 <<< "$SNAPSHOT_TOKEN"
  BQN_STDERR="$(mktemp)"
  trap 'rm -f "$BQN_STDERR"' EXIT
  BQN_OUT=""
  if ! BQN_OUT="$(cd "$ROOT_DIR" && bqn src_edit/account_add_cmd.bqn "$BASE_DIR" "$NAME" "$ROLE" "$TYPE" "$CURRENCY" 2>"$BQN_STDERR")"; then
    [[ -n "$BQN_OUT" ]] && printf '%s\n' "$BQN_OUT" >&2
    [[ -s "$BQN_STDERR" ]] && cat "$BQN_STDERR" >&2
    exit 1
  fi
  if ! edit_bqn_split_protocol_output "$BQN_OUT"; then exit 1; fi
  FIRST_LINE="$EDIT_BQN_PROTOCOL_FIRST_LINE"
  PAYLOAD="$EDIT_BQN_PROTOCOL_PAYLOAD"
  if ! edit_bqn_require_append_protocol "$FIRST_LINE" "$ACCOUNTS_FILE"; then exit 1; fi
  MODE="$(edit_bqn_mode "$DRY_RUN" "$YES")"
  edit_bqn_print_append_preview "Account" "$TARGET_PATH" "$MODE" "$POST_CHECK" "Account row" "$PAYLOAD"
  if [[ "$DRY_RUN" -eq 1 ]]; then
    printf 'Dry-run only. No files were modified.\n'
    exit 0
  fi
  if [[ "$YES" -eq 0 ]] && ! confirm_append; then
    echo "Cancelled. No files were modified."
    exit 0
  fi
  edit_bqn_apply_append_checked "$BASE_DIR" "$POST_CHECK" "$TARGET_PATH" "$PAYLOAD" "$SNAP_SIZE" "$SNAP_MTIME" "$SNAP_SHA256" EDIT_BQN_TEST_BEFORE_APPEND_HOOK
  exit 0
fi

if [[ "$1" == "account" && "$2" == "list" ]]; then
  shift 2
  ROLE=""
  CURRENCY=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --role) ROLE="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      --currency) CURRENCY="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      *) echo "ERROR: unknown account list argument: $1" >&2; exit 2 ;;
    esac
  done
  cd "$ROOT_DIR" && bqn src_edit/account_list_cmd.bqn "$BASE_DIR" "$ROLE" "$CURRENCY"
  exit $?
fi

if [[ "$1" == "journal" && "$2" == "list" ]]; then
  shift 2
  FORMAT="text"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --format) FORMAT="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      *) echo "ERROR: unknown journal list argument: $1" >&2; exit 2 ;;
    esac
  done
  case "$FORMAT" in
    tsv|text) ;;
    *) echo "ERROR: invalid format: $FORMAT (expected 'tsv' or 'text')" >&2; exit 2 ;;
  esac
  cd "$ROOT_DIR" && bqn src_edit/journal_list_cmd.bqn "$BASE_DIR" "$FORMAT"
  exit $?
fi

if [[ "$1" == "journal" && "$2" == "income-budget-sync" ]]; then
  shift 2
  TXN_ID=""; DRY_RUN=0; YES=0; POST_CHECK="lint"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --id) TXN_ID="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      --dry-run) DRY_RUN=1; shift ;;
      --yes) YES=1; shift ;;
      --post-check) POST_CHECK="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      *) echo "ERROR: unknown journal income-budget-sync argument: $1" >&2; exit 2 ;;
    esac
  done
  [[ -n "$TXN_ID" ]] || { echo "ERROR: missing required option: --id" >&2; exit 2; }
  edit_bqn_validate_post_check "$POST_CHECK"
  TARGET_PATH="$BASE_DIR/$BUDGET_ALLOC_FILE"
  SNAPSHOT_TOKEN="$(safe_snapshot_token "$TARGET_PATH")"
  IFS=$'\t' read -r SNAP_SIZE SNAP_MTIME SNAP_SHA256 <<< "$SNAPSHOT_TOKEN"
  BQN_STDERR="$(mktemp)"; trap 'rm -f "$BQN_STDERR"' EXIT
  if ! BQN_OUT="$(edit_bqn_bqn_capture "$BQN_STDERR" bqn src_edit/income_budget_sync_cmd.bqn "$BASE_DIR" "$TXN_ID")"; then exit 1; fi
  FIRST_LINE="${BQN_OUT%%$'\n'*}"
  case "$FIRST_LINE" in
    $'OK\tAPPLIED\t'*) printf 'Income budget sync already applied: %s\n' "$TXN_ID"; exit 0 ;;
    $'OK\tNOT_LINKED\t'*) printf 'Income budget sync not linked: %s\n' "$TXN_ID"; exit 0 ;;
  esac
  if ! edit_bqn_split_protocol_output "$BQN_OUT"; then exit 1; fi
  if ! edit_bqn_require_append_protocol "$EDIT_BQN_PROTOCOL_FIRST_LINE" "$BUDGET_ALLOC_FILE"; then exit 1; fi
  PAYLOAD="$EDIT_BQN_PROTOCOL_PAYLOAD"; MODE="$(edit_bqn_mode "$DRY_RUN" "$YES")"
  edit_bqn_print_append_preview "Income budget sync" "$TARGET_PATH" "$MODE" "$POST_CHECK" "Budget companion row" "$PAYLOAD"
  if [[ "$DRY_RUN" -eq 1 ]]; then printf 'Dry-run only. No files were modified.\n'; exit 0; fi
  if [[ "$YES" -eq 0 ]] && ! confirm_append; then echo 'BUDGET_SYNC_PENDING: no files were modified.'; exit 130; fi
  edit_bqn_apply_append_checked "$BASE_DIR" "$POST_CHECK" "$TARGET_PATH" "$PAYLOAD" "$SNAP_SIZE" "$SNAP_MTIME" "$SNAP_SHA256" EDIT_BQN_TEST_BEFORE_APPEND_HOOK
  exit 0
fi

if [[ "$1" == "journal" && "$2" == "reverse" ]]; then
  shift 2
  INDEX="0"
  ID=""
  DATE=""
  DRY_RUN=0
  YES=0
  POST_CHECK="lint"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --index) INDEX="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      --id) ID="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      --date) DATE="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      --dry-run) DRY_RUN=1; shift ;;
      --yes) YES=1; shift ;;
      --post-check) POST_CHECK="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      *) echo "ERROR: unknown option: $1" >&2; exit 2 ;;
    esac
  done

  if [[ "$INDEX" == "0" && -z "$ID" ]]; then
    echo "ERROR: must specify journal row to reverse using --index or --id" >&2
    exit 2
  fi
  edit_bqn_validate_post_check "$POST_CHECK"

  TARGET_PATH="$BASE_DIR/$JOURNAL_FILE"
  SNAPSHOT_TOKEN="$(safe_snapshot_token "$TARGET_PATH")"
  IFS=$'\t' read -r SNAP_SIZE SNAP_MTIME SNAP_SHA256 <<< "$SNAPSHOT_TOKEN"

  BQN_STDERR="$(mktemp)"
  trap 'rm -f "$BQN_STDERR"' EXIT
  BQN_OUT=""
  if ! BQN_OUT="$(cd "$ROOT_DIR" && bqn src_edit/journal_reverse_cmd.bqn "$BASE_DIR" "$ID" "$INDEX" "$DATE" 2>"$BQN_STDERR")"; then
    if [[ -n "$BQN_OUT" ]]; then
      printf '%s\n' "$BQN_OUT" >&2
    fi
    if [[ -s "$BQN_STDERR" ]]; then
      cat "$BQN_STDERR" >&2
    fi
    exit 1
  fi

  if ! edit_bqn_split_protocol_output "$BQN_OUT"; then
    exit 1
  fi
  FIRST_LINE="$EDIT_BQN_PROTOCOL_FIRST_LINE"
  PAYLOAD="$EDIT_BQN_PROTOCOL_PAYLOAD"

  IFS=$'\t' read -r STATUS OP PROTOCOL_TARGET_FILE TARGET_IDX ORIG_DATE ORIG_MEMO ORIG_FROM ORIG_TO ORIG_AMOUNT <<< "$FIRST_LINE"
  if [[ "$STATUS" == "ERROR" ]]; then
    echo "ERROR: $OP" >&2
    exit 1
  fi
  if ! edit_bqn_require_append_protocol_prefix "$FIRST_LINE" "$JOURNAL_FILE"; then
    exit 1
  fi

  MODE="$(edit_bqn_mode "$DRY_RUN" "$YES")"

  printf 'Reversing journal row %s (date=%s, memo=%s)\n' "$TARGET_IDX" "$ORIG_DATE" "$ORIG_MEMO"
  printf '  Original: %s -> %s  %s\n' "$ORIG_FROM" "$ORIG_TO" "$ORIG_AMOUNT"
  printf '  Reversed: %s -> %s  %s\n' "$ORIG_TO" "$ORIG_FROM" "$ORIG_AMOUNT"

  printf 'Journal reverse preview\n'
  printf 'Target: %s\n' "$TARGET_PATH"
  printf 'Mode: %s\n' "$MODE"
  printf 'Post-check: %s\n' "$POST_CHECK"
  printf 'Reversed row:\n'
  printf '%s\n' "$PAYLOAD"

  if [[ "$DRY_RUN" -eq 1 ]]; then
    printf 'Dry-run only. No files were modified.\n'
    exit 0
  fi

  if [[ "$YES" -eq 0 ]]; then
    printf 'Append this row? [y/N]: '
    read -r REPLY
    case "$REPLY" in
      y|Y|yes|YES) ;;
      *) echo "Cancelled. No files were modified."; exit 0 ;;
    esac
  fi

  edit_bqn_apply_append_checked "$BASE_DIR" "$POST_CHECK" "$TARGET_PATH" "$PAYLOAD" "$SNAP_SIZE" "$SNAP_MTIME" "$SNAP_SHA256" EDIT_BQN_TEST_BEFORE_APPEND_HOOK journal
  exit 0
fi

if [[ "$1" == "plan" && "$2" == "budget-sync" ]]; then
  shift 2
  PLAN_ID=""
  DRY_RUN=0
  YES=0
  POST_CHECK="lint"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --id) PLAN_ID="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      --dry-run) DRY_RUN=1; shift ;;
      --yes) YES=1; shift ;;
      --post-check) POST_CHECK="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      *) echo "ERROR: unknown plan budget-sync argument: $1" >&2; exit 2 ;;
    esac
  done
  [[ -n "$PLAN_ID" ]] || { echo "ERROR: missing required option: --id" >&2; exit 2; }
  edit_bqn_validate_post_check "$POST_CHECK"

  TARGET_PATH="$BASE_DIR/$BUDGET_ALLOC_FILE"
  SNAPSHOT_TOKEN="$(safe_snapshot_token "$TARGET_PATH")"
  IFS=$'\t' read -r SNAP_SIZE SNAP_MTIME SNAP_SHA256 <<< "$SNAPSHOT_TOKEN"
  BQN_STDERR="$(mktemp)"; trap 'rm -f "$BQN_STDERR"' EXIT
  if ! BQN_OUT="$(edit_bqn_bqn_capture "$BQN_STDERR" bqn src_edit/plan_budget_sync_cmd.bqn "$BASE_DIR" "$PLAN_ID")"; then exit 1; fi
  FIRST_LINE="${BQN_OUT%%$'\n'*}"
  case "$FIRST_LINE" in
    $'OK\tAPPLIED\t'*) printf 'Budget sync already applied: %s\n' "$PLAN_ID"; exit 0 ;;
    $'OK\tNOT_LINKED\t'*) printf 'Budget sync not linked: %s\n' "$PLAN_ID"; exit 0 ;;
  esac
  if ! edit_bqn_split_protocol_output "$BQN_OUT"; then exit 1; fi
  if ! edit_bqn_require_append_protocol "$EDIT_BQN_PROTOCOL_FIRST_LINE" "$BUDGET_ALLOC_FILE"; then exit 1; fi
  PAYLOAD="$EDIT_BQN_PROTOCOL_PAYLOAD"
  MODE="$(edit_bqn_mode "$DRY_RUN" "$YES")"
  edit_bqn_print_append_preview "Plan budget sync" "$TARGET_PATH" "$MODE" "$POST_CHECK" "Budget companion row" "$PAYLOAD"
  if [[ "$DRY_RUN" -eq 1 ]]; then printf 'Dry-run only. No files were modified.\n'; exit 0; fi
  if [[ "$YES" -eq 0 ]] && ! confirm_append; then echo 'BUDGET_SYNC_PENDING: no files were modified.'; exit 130; fi
  edit_bqn_apply_append_checked "$BASE_DIR" "$POST_CHECK" "$TARGET_PATH" "$PAYLOAD" "$SNAP_SIZE" "$SNAP_MTIME" "$SNAP_SHA256" EDIT_BQN_TEST_BEFORE_APPEND_HOOK
  exit 0
fi

if [[ "$1" == "plan" && "$2" == "edit" ]]; then
  shift 2
  INDEX="0"
  PLAN_ID=""
  DATE=""
  AMOUNT=""
  SHOW_ALL=0
  DRY_RUN=0
  YES=0
  POST_CHECK="lint"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --index) INDEX="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      --id) PLAN_ID="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      --date) DATE="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      --amount) AMOUNT="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      --all) SHOW_ALL=1; shift ;;
      --dry-run) DRY_RUN=1; shift ;;
      --yes) YES=1; shift ;;
      --post-check) POST_CHECK="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      *) echo "ERROR: unknown option: $1" >&2; exit 2 ;;
    esac
  done

  if [[ "$INDEX" == "0" && -z "$PLAN_ID" ]]; then
    echo "ERROR: must specify plan to edit using --index or --id" >&2
    exit 2
  fi
  if [[ -z "$DATE" && -z "$AMOUNT" ]]; then
    echo "ERROR: must specify at least one of --date or --amount" >&2
    exit 2
  fi
  edit_bqn_validate_post_check "$POST_CHECK"

  TARGET_PATH="$BASE_DIR/$PLAN_FILE"
  SNAPSHOT_TOKEN="$(safe_snapshot_token "$TARGET_PATH")"
  IFS=$'\t' read -r SNAP_SIZE SNAP_MTIME SNAP_SHA256 <<< "$SNAPSHOT_TOKEN"

  BQN_STDERR="$(mktemp)"
  trap 'rm -f "$BQN_STDERR"' EXIT
  BQN_OUT=""
  if ! BQN_OUT="$(cd "$ROOT_DIR" && bqn src_edit/plan_edit_cmd.bqn "$BASE_DIR" "$INDEX" "$PLAN_ID" "$DATE" "$AMOUNT" "$SHOW_ALL" 2>"$BQN_STDERR")"; then
    if [[ -n "$BQN_OUT" ]]; then
      printf '%s\n' "$BQN_OUT" >&2
    fi
    if [[ -s "$BQN_STDERR" ]]; then
      cat "$BQN_STDERR" >&2
    fi
    exit 1
  fi

  if ! edit_bqn_parse_replace_protocol "$BQN_OUT"; then
    exit 1
  fi
  LINE_NUM="$EDIT_BQN_REPLACE_LINE_NUM"
  EDIT_PLAN_ID="$EDIT_BQN_REPLACE_ID"
  OLD_LINE="$EDIT_BQN_REPLACE_OLD_LINE"
  NEW_LINE="$EDIT_BQN_REPLACE_NEW_LINE"

  MODE="$(edit_bqn_mode "$DRY_RUN" "$YES")"

  edit_bqn_print_replace_preview "Plan edit" "$TARGET_PATH" "$LINE_NUM" "$EDIT_PLAN_ID" "$MODE" "$POST_CHECK" "$OLD_LINE" "$NEW_LINE"

  if [[ "$DRY_RUN" -eq 1 ]]; then
    printf 'Dry-run only. No files were modified.\n'
    exit 0
  fi

  if [[ "$YES" -eq 0 ]]; then
    printf 'Rewrite this plan row? [y/N]: '
    read -r REPLY
    case "$REPLY" in
      y|Y|yes|YES) ;;
      *) echo "Cancelled. No files were modified."; exit 0 ;;
    esac
  fi

  edit_bqn_apply_replace_checked "$BASE_DIR" "$POST_CHECK" "$TARGET_PATH" "$LINE_NUM" "$OLD_LINE" "$NEW_LINE" "$SNAP_SIZE" "$SNAP_MTIME" "$SNAP_SHA256" EDIT_BQN_TEST_BEFORE_REPLACE_HOOK
  exit 0
fi

if [[ "$1" == "plan" && "$2" == "finish" ]]; then
  shift 2
  INDEX="0"
  PLAN_ID=""
  ACTUAL_DATE=""
  ACTUAL_AMOUNT=""
  APPLY=0
  DRY_RUN_EXPLICIT=0
  YES=0
  POST_CHECK="lint"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --index) INDEX="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      --id) PLAN_ID="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      --actual-date) ACTUAL_DATE="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      --actual-amount) ACTUAL_AMOUNT="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      --apply) APPLY=1; shift ;;
      --dry-run) DRY_RUN_EXPLICIT=1; shift ;;
      --yes) YES=1; shift ;;
      --post-check) POST_CHECK="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      *) echo "ERROR: unknown option: $1" >&2; exit 2 ;;
    esac
  done

  if [[ "$APPLY" -eq 1 && "$DRY_RUN_EXPLICIT" -eq 0 ]]; then
    DRY_RUN=0
  else
    DRY_RUN=1
  fi

  if [[ "$INDEX" == "0" && -z "$PLAN_ID" ]]; then
    echo "ERROR: must specify plan to finish using --index or --id" >&2
    exit 2
  fi
  if [[ -z "$ACTUAL_DATE" ]]; then
    echo "ERROR: missing required option: --actual-date" >&2
    exit 2
  fi

  TARGET_PATH="$BASE_DIR/$JOURNAL_FILE"
  SNAPSHOT_TOKEN="$(safe_snapshot_token "$TARGET_PATH")"
  IFS=$'\t' read -r SNAP_SIZE SNAP_MTIME SNAP_SHA256 <<< "$SNAPSHOT_TOKEN"

  BQN_STDERR="$(mktemp)"
  trap 'rm -f "$BQN_STDERR"' EXIT
  BQN_OUT=""
  if ! BQN_OUT="$(cd "$ROOT_DIR" && bqn src_edit/plan_finish_cmd.bqn "$BASE_DIR" "$INDEX" "$PLAN_ID" "$ACTUAL_DATE" "$ACTUAL_AMOUNT" 2>"$BQN_STDERR")"; then
    if [[ -n "$BQN_OUT" ]]; then
      printf '%s\n' "$BQN_OUT" >&2
    fi
    if [[ -s "$BQN_STDERR" ]]; then
      cat "$BQN_STDERR" >&2
    fi
    exit 1
  fi

  if ! edit_bqn_split_protocol_output "$BQN_OUT"; then
    exit 1
  fi
  FIRST_LINE="$EDIT_BQN_PROTOCOL_FIRST_LINE"
  PAYLOAD="$EDIT_BQN_PROTOCOL_PAYLOAD"

  if ! edit_bqn_require_append_protocol "$FIRST_LINE" "$JOURNAL_FILE"; then
    exit 1
  fi

  MODE="$(edit_bqn_mode "$DRY_RUN" "$YES")"

  if [[ "$DRY_RUN" -eq 1 ]]; then
    edit_bqn_print_append_preview "Journal (from plan)" "$TARGET_PATH" "$MODE" "$POST_CHECK" "Journal row" "$PAYLOAD"
    printf 'Dry-run only. No files were modified.\n'
    exit 0
  fi

  if [[ "$YES" -eq 0 ]]; then
    edit_bqn_print_append_preview "Journal (from plan)" "$TARGET_PATH" "$MODE" "$POST_CHECK" "Journal row" "$PAYLOAD"
    if ! confirm_append; then
      echo "Cancelled. No files were modified."
      exit 0
    fi
  fi

  edit_bqn_apply_append_checked "$BASE_DIR" "$POST_CHECK" "$TARGET_PATH" "$PAYLOAD" "$SNAP_SIZE" "$SNAP_MTIME" "$SNAP_SHA256" EDIT_BQN_TEST_BEFORE_APPEND_HOOK journal
  exit 0
fi

if [[ "$1" == "plan" && "$2" == "list" ]]; then
  shift 2
  SHOW_ALL=0
  FORMAT="text"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --all) SHOW_ALL=1; shift ;;
      --format) FORMAT="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      *) echo "ERROR: unknown list argument: $1" >&2; exit 2 ;;
    esac
  done
  case "$FORMAT" in
    tsv|text) ;;
    *) echo "ERROR: invalid format: $FORMAT (expected 'tsv' or 'text')" >&2; exit 2 ;;
  esac
  cd "$ROOT_DIR" && bqn src_edit/plan_list_cmd.bqn "$BASE_DIR" "$SHOW_ALL" "$FORMAT"
  exit $?
fi

if [[ "$1" == "plan" && "$2" == "related" ]]; then
  shift 2
  INDEX="0"
  PLAN_ID=""
  ACTUAL_DATE=""
  FORMAT="tsv"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --index) INDEX="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      --id) PLAN_ID="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      --actual-date) ACTUAL_DATE="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      --format) FORMAT="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      *) echo "ERROR: unknown related argument: $1" >&2; exit 2 ;;
    esac
  done
  if [[ "$INDEX" == "0" && -z "$PLAN_ID" ]]; then
    echo "ERROR: must specify plan using --index or --id" >&2
    exit 2
  fi
  if [[ -z "$ACTUAL_DATE" ]]; then
    echo "ERROR: missing required option: --actual-date" >&2
    exit 2
  fi
  case "$FORMAT" in
    tsv) ;;
    *) echo "ERROR: invalid format: $FORMAT (expected 'tsv')" >&2; exit 2 ;;
  esac
  cd "$ROOT_DIR" && bqn src_edit/plan_related_cmd.bqn "$BASE_DIR" "$INDEX" "$PLAN_ID" "$ACTUAL_DATE" "$FORMAT"
  exit $?
fi

if [[ "$1" == "issue" && "$2" == "list" ]]; then
  shift 2
  EXPECTED_TARGET_FILE="$ISSUES_FILE"
  handle_edit_bqn_issue_list "$@"
  exit $?
fi

if [[ "$1" == "issue" && "$2" == "close" ]]; then
  shift 2
  EXPECTED_TARGET_FILE="$ISSUES_FILE"
  handle_edit_bqn_issue_close "$@"
  exit $?
fi

if [[ "$2" != "add" ]]; then
  echo "ERROR: tools/edit-bqn currently supports only: account list, journal add, journal list, journal reverse, budget add, issue add/list/close, plan add, plan list, plan related, plan finish, and plan edit" >&2
  usage
  exit 2
fi
COMMAND="$1"
case "$COMMAND" in
  journal)
    EXPECTED_TARGET_FILE="$JOURNAL_FILE"
    PREVIEW_TITLE="Journal"
    ROW_TITLE="Journal row"
    ;;
  budget)
    EXPECTED_TARGET_FILE="$BUDGET_ALLOC_FILE"
    PREVIEW_TITLE="Budget allocation"
    ROW_TITLE="Budget allocation row"
    ;;
  plan)
    EXPECTED_TARGET_FILE="$PLAN_FILE"
    PREVIEW_TITLE="Plan"
    ROW_TITLE="Plan row"
    ;;
  issue)
    EXPECTED_TARGET_FILE="$ISSUES_FILE"
    PREVIEW_TITLE="Issue"
    ROW_TITLE="Issue row"
    ;;
  *)
    echo "ERROR: tools/edit-bqn currently supports only: account list, journal add, journal list, journal reverse, budget add, issue add/list/close, plan add, plan list, plan related, plan finish, and plan edit" >&2
    usage
    exit 2
    ;;
esac
shift 2

if [[ "$COMMAND" == "issue" ]]; then
  handle_edit_bqn_issue_add "$@"
  exit $?
fi
DATE=""
MEMO=""
FROM=""
TO=""
AMOUNT=""
CURRENCY=""
META=()
PLAN_ID=""
DRY_RUN=0
YES=0
POST_CHECK="lint"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --date) DATE="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
    --memo) MEMO="$(get_opt_val_allow_empty "$1" "${2-}")"; shift 2 ;;
    --from) FROM="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
    --to) TO="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
    --amount) AMOUNT="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
    --currency) CURRENCY="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
    --meta) META+=("$(get_opt_val "$1" "${2-}")"); shift 2 ;;
    --id) PLAN_ID="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
    --dry-run) DRY_RUN=1; shift ;;
    --yes) YES=1; shift ;;
    --post-check) POST_CHECK="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
    *) echo "ERROR: unknown option $1" >&2; exit 2 ;;
  esac
done

if [[ "$COMMAND" != "journal" && -n "$CURRENCY" ]]; then
  echo "ERROR: --currency is currently supported only for journal add" >&2
  exit 2
fi
edit_bqn_validate_post_check "$POST_CHECK"

TARGET_PATH="$BASE_DIR/$EXPECTED_TARGET_FILE"
SNAPSHOT_TOKEN="$(safe_snapshot_token "$TARGET_PATH")"
IFS=$'\t' read -r SNAP_SIZE SNAP_MTIME SNAP_SHA256 <<< "$SNAPSHOT_TOKEN"

BQN_STDERR="$(mktemp)"
trap 'rm -f "$BQN_STDERR"' EXIT
BQN_OUT=""
if [[ "$COMMAND" == "plan" ]]; then
  if ! BQN_OUT="$(cd "$ROOT_DIR" && bqn src_edit/plan_add_cmd.bqn "$BASE_DIR" "$DATE" "$MEMO" "$FROM" "$TO" "$AMOUNT" "$PLAN_ID" "${META[@]}" 2>"$BQN_STDERR")"; then
    if [[ -n "$BQN_OUT" ]]; then
      printf '%s\n' "$BQN_OUT" >&2
    fi
    if [[ -s "$BQN_STDERR" ]]; then
      cat "$BQN_STDERR" >&2
    fi
    exit 1
  fi
else
  if ! BQN_OUT="$(cd "$ROOT_DIR" && bqn src_edit/journal_add_cmd.bqn "$BASE_DIR" "$COMMAND" "$DATE" "$MEMO" "$FROM" "$TO" "$AMOUNT" "$CURRENCY" "${META[@]}" 2>"$BQN_STDERR")"; then
    if [[ -n "$BQN_OUT" ]]; then
      printf '%s\n' "$BQN_OUT" >&2
    fi
    if [[ -s "$BQN_STDERR" ]]; then
      cat "$BQN_STDERR" >&2
    fi
    exit 1
  fi
fi

if ! edit_bqn_split_protocol_output "$BQN_OUT"; then
  exit 1
fi
FIRST_LINE="$EDIT_BQN_PROTOCOL_FIRST_LINE"
PAYLOAD="$EDIT_BQN_PROTOCOL_PAYLOAD"

INCOME_SYNC_TXN_ID=""
if [[ "$COMMAND" == "journal" ]]; then
  if ! edit_bqn_require_append_protocol_prefix "$FIRST_LINE" "$EXPECTED_TARGET_FILE"; then exit 1; fi
  IFS=$'\t' read -r _status _op _target INCOME_SYNC_TXN_ID _extra <<< "$FIRST_LINE"
  [[ -z "${_extra:-}" ]] || { echo "ERROR: invalid journal protocol header: $FIRST_LINE" >&2; exit 1; }
else
  if ! edit_bqn_require_append_protocol "$FIRST_LINE" "$EXPECTED_TARGET_FILE"; then exit 1; fi
fi

MODE="$(edit_bqn_mode "$DRY_RUN" "$YES")"

if [[ "$DRY_RUN" -eq 1 ]]; then
  edit_bqn_print_append_preview "$PREVIEW_TITLE" "$TARGET_PATH" "$MODE" "$POST_CHECK" "$ROW_TITLE" "$PAYLOAD"
  printf 'Dry-run only. No files were modified.\n'
  exit 0
fi

if [[ "$YES" -eq 0 ]]; then
  edit_bqn_print_append_preview "$PREVIEW_TITLE" "$TARGET_PATH" "$MODE" "$POST_CHECK" "$ROW_TITLE" "$PAYLOAD"
  if ! confirm_append; then
    echo "Cancelled. No files were modified."
    exit 0
  fi
fi

# Test-only stale-write injection point used by check-edit-bqn-journal-add.sh.
# This must not become production extension behavior; it exists only to simulate
# a concurrent source TSV edit between validation/preview and append.
POST_CHECK_OWNER="default"
[[ "$COMMAND" == "journal" ]] && POST_CHECK_OWNER="journal"
edit_bqn_apply_append_checked "$BASE_DIR" "$POST_CHECK" "$TARGET_PATH" "$PAYLOAD" "$SNAP_SIZE" "$SNAP_MTIME" "$SNAP_SHA256" EDIT_BQN_TEST_BEFORE_APPEND_HOOK "$POST_CHECK_OWNER"
if [[ -n "$INCOME_SYNC_TXN_ID" ]]; then
  sync_args=(--id "$INCOME_SYNC_TXN_ID" --post-check "$POST_CHECK")
  [[ "$YES" -eq 1 ]] && sync_args+=(--yes)
  if ! "$ROOT_DIR/tools/edit" --base "$BASE_DIR" journal income-budget-sync "${sync_args[@]}"; then
    echo "BUDGET_SYNC_PENDING: journal actual is committed; retry with: tools/edit --base '$BASE_DIR' journal income-budget-sync --id '$INCOME_SYNC_TXN_ID'" >&2
    exit 1
  fi
fi
