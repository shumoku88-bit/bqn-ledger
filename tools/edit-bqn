    printf '#%s date=%s id=%s event-line=%s %s\n' "$ROW_NUMBER" "$ROW_DATE" "$ROW_EVENT_ID" "$EVENT_LINE" "$ROW_DESCRIPTION"
  done
  if [[ "$DRY_RUN" -eq 1 ]]; then echo "Dry-run only. No files were modified."; exit 0; fi
  if [[ "$YES" -eq 0 ]]; then
    printf 'Remove these legacy event-id lines? [y/N]: '
    REPLY=""; read -r REPLY || true
    case "$REPLY" in y|Y|yes|YES) ;; *) echo "Cancelled. No files were modified."; exit 0 ;; esac
  fi
  edit_bqn_apply_rewrite_checked "$CANONICAL_BASE" "$POST_CHECK" "$TARGET_PATH" "$CANDIDATE_FILE" "$SNAP_SIZE" "$SNAP_MTIME" "$SNAP_SHA256"
  exit $?
