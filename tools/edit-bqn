#!/usr/bin/env bash
# tools/edit-bqn — BQN-backed editor entry point.
#
# Current scope: daily commands (`account add/list`, `journal add/list/cleanup-plan/cleanup-apply/reverse`,
# `budget add`, `issue add/list/close`, and `plan add/list/related/finish/edit`),
# the separate explicit-path `journal-block add`, and dedicated travel source-event commands.
# `tools/edit` is the public wrapper that delegates here.
#
# Shared parsing/protocol/write handling is kept in one path for the
# journal-like append commands instead of copy-pasting command branches.

set -euo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$DIR/.." && pwd)"
# shellcheck source=tools/lib/system-defaults.sh
source "$DIR/lib/system-defaults.sh"
# shellcheck source=tools/lib/safe-write.sh
source "$DIR/lib/safe-write.sh"
# shellcheck source=tools/lib/edit-bqn-common.sh
source "$DIR/lib/edit-bqn-common.sh"
# shellcheck source=tools/lib/edit-bqn-issue.sh
source "$DIR/lib/edit-bqn-issue.sh"
# shellcheck source=tools/lib/edit-bqn-travel.sh
source "$DIR/lib/edit-bqn-travel.sh"

BASE_DIR="${LEDGER_DATA_DIR:-$(get_default_base_dir)}"
JOURNAL_FILE="$(get_system_default_file DEFAULT_JOURNAL_FILE journal.tsv)"
BUDGET_ALLOC_FILE="$(get_system_default_file DEFAULT_BUDGET_ALLOC_FILE budget_alloc.tsv)"
PLAN_FILE="$(get_system_default_file DEFAULT_PLAN_FILE plan.tsv)"
ISSUES_FILE="issues.tsv"
ACCOUNTS_FILE="$(get_system_default_file DEFAULT_ACCOUNTS_FILE accounts.tsv)"

usage() {
  cat <<'USAGE' >&2
Usage:
  tools/edit-bqn [--base DIR] journal-block add [--identity ordinary|durable] --journal-file FILE --date YYYY-MM-DD --description DESCRIPTION [--event-id EVENT_ID] --posting ACCOUNT=SIGNED_INTEGER --posting ACCOUNT=SIGNED_INTEGER [--posting ACCOUNT=SIGNED_INTEGER ...] [--meta key=value ...] [--dry-run] [--yes] [--post-check none|lint|full]
  tools/edit-bqn [--base DIR] journal add --date YYYY-MM-DD --memo MEMO --from ACCOUNT --to ACCOUNT --amount DECIMAL [--currency CODE] [--meta key=value ...] [--dry-run] [--yes] [--post-check none|lint|full]
  tools/edit-bqn [--base DIR] journal multi-add --date YYYY-MM-DD --description DESCRIPTION --posting ACCOUNT=SIGNED_INTEGER --posting ACCOUNT=SIGNED_INTEGER [--posting ACCOUNT=SIGNED_INTEGER ...] [--meta key=value ...] [--dry-run] [--yes] [--post-check none|lint|full]
  tools/edit-bqn [--base DIR] journal income-budget-sync --id TXN_ID [--dry-run] [--yes] [--post-check none|lint|full]
  tools/edit-bqn [--base DIR] budget add  --date YYYY-MM-DD --memo MEMO --from ACCOUNT --to ACCOUNT --amount DECIMAL [--currency CODE] [--meta key=value ...] [--dry-run] [--yes] [--post-check none|lint|full]
  tools/edit-bqn [--base DIR] plan add --date YYYY-MM-DD --memo MEMO --from ACCOUNT --to ACCOUNT --amount DECIMAL [--currency CODE] [--meta key=value ...] [--id plan-YYYY-MM-DD-series] [--dry-run] [--yes] [--post-check none|lint|full]
  tools/edit-bqn [--base DIR] issue add [--date YYYY-MM-DD] [--status open|resolved|dropped] --title TITLE [--amount INT] [--memo MEMO] [--dry-run] [--yes] [--post-check none|lint|full]
  tools/edit-bqn [--base DIR] issue list [--format tsv|text]
  tools/edit-bqn [--base DIR] issue close --index NUMBER [--status resolved|dropped] --decision MEMO [--dry-run] [--yes] [--post-check none|lint|full]
  tools/edit-bqn [--base DIR] account add --name ACCOUNT --role asset|liability|income|expense [--type liquid|savings|invest] [--currency CODE] [--dry-run] [--yes] [--post-check none|lint|full]
  tools/edit-bqn [--base DIR] account list [--role ROLE] [--currency CODE]
  tools/edit-bqn [--base DIR] journal list [--format tsv|text]
  tools/edit-bqn [--base DIR] journal cleanup-plan [--format tsv|text]
  tools/edit-bqn [--base DIR] journal cleanup-apply [--dry-run] [--yes] [--post-check none|lint|full]
  tools/edit-bqn [--base DIR] plan list [--all] [--format tsv|text] [--temporal all|overdue|upcoming] [--as-of YYYY-MM-DD]
  tools/edit-bqn [--base DIR] plan related [--index NUMBER] [--id PLAN_ID] --actual-date YYYY-MM-DD [--format tsv]
  tools/edit-bqn [--base DIR] plan finish [--index NUMBER] [--id PLAN_ID] --actual-date YYYY-MM-DD [--actual-amount DECIMAL] [--dry-run] [--yes] [--post-check none|lint|full]
  tools/edit-bqn [--base DIR] plan budget-sync --id PLAN_ID [--dry-run] [--yes] [--post-check none|lint|full]
  tools/edit-bqn [--base DIR] plan edit [--index NUMBER] [--id PLAN_ID] [--date YYYY-MM-DD] [--amount DECIMAL] [--all] [--dry-run] [--yes] [--post-check none|lint|full]
  tools/edit-bqn [--base DIR] journal reverse [--index NUMBER] [--id TXN_ID] [--date YYYY-MM-DD] [--dry-run] [--yes] [--post-check none|lint|full]
  tools/edit-bqn [--base DIR] travel friend add --date YYYY-MM-DD --party PARTY --item ITEM --amount DECIMAL --currency ILS --payer friend --trip-id israel-2026 --source-event-id ID [--dry-run] [--yes]
  tools/edit-bqn [--base DIR] travel exchange add --date YYYY-MM-DD --memo MEMO --source-account ACCOUNT --source-amount INT --source-currency JPY --target-account ACCOUNT --target-amount DECIMAL --target-currency ILS --exchange-id ID --trip-id israel-2026 [--dry-run] [--yes]

Current scope: BQN editor daily commands (account add/list, journal add/multi-add, budget/plan/issue add, explicit-path journal-block add, travel friend/exchange add, issue list/close, journal list/cleanup-plan/cleanup-apply/reverse, and plan list/related/finish/edit).
USAGE
}

REM_ARGS=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --base)
      BASE_DIR="$(get_opt_val "$1" "${2-}")"
      shift 2
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      REM_ARGS+=("$1")
      shift
      ;;
  esac
done
set -- "${REM_ARGS[@]}"

if [[ $# -lt 2 ]]; then
  echo "ERROR: missing command/subcommand" >&2
  usage
  exit 2
fi

if [[ "$1" == "travel" && "$2" == "friend" && "${3-}" == "add" ]]; then
  shift 3
  handle_edit_bqn_travel_friend_add "$@"
  exit $?
fi
if [[ "$1" == "travel" && "$2" == "exchange" && "${3-}" == "add" ]]; then
  shift 3
  handle_edit_bqn_travel_exchange_add "$@"
  exit $?
fi

if [[ "$1" == "journal" && "$2" == "multi-add" ]]; then
  shift 2
  DATE=""; DESCRIPTION=""; POSTINGS=(); BLOCK_META=(); DRY_RUN=0; YES=0; POST_CHECK="lint"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --date) DATE="$(get_opt_val_allow_empty "$1" "${2-}")"; shift 2 ;;
      --description) DESCRIPTION="$(get_opt_val_allow_empty "$1" "${2-}")"; shift 2 ;;
      --posting) POSTINGS+=("$(get_opt_val_allow_empty "$1" "${2-}")"); shift 2 ;;
      --meta) BLOCK_META+=("$(get_opt_val_allow_empty "$1" "${2-}")"); shift 2 ;;
      --dry-run) DRY_RUN=1; shift ;;
      --yes) YES=1; shift ;;
      --post-check) POST_CHECK="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      *) echo "ERROR: unknown journal multi-add argument: $1" >&2; exit 2 ;;
    esac
  done
  [[ -n "$DATE" ]] || { echo "ERROR: missing required option: --date" >&2; exit 2; }
  [[ -n "$DESCRIPTION" ]] || { echo "ERROR: missing required option: --description" >&2; exit 2; }
  edit_bqn_validate_post_check "$POST_CHECK"

  ACTUAL_ROUTE="$(cd "$ROOT_DIR" && bqn src_edit/actual_source_route_cmd.bqn "$BASE_DIR")"
  IFS=$'\t' read -r ACTUAL_MODE ACTUAL_FILE ACTUAL_EXTRA <<< "$ACTUAL_ROUTE"
  [[ -z "${ACTUAL_EXTRA:-}" ]] || { echo "ERROR: invalid actual-source route" >&2; exit 1; }
  [[ "$ACTUAL_MODE" == "journal" ]] || { echo "ERROR: journal multi-add requires ACTUAL_SOURCE=journal; no files changed" >&2; exit 1; }

  native_args=(--base "$BASE_DIR" journal-block add --identity ordinary --journal-file "$ACTUAL_FILE" --date "$DATE" --description "$DESCRIPTION" --post-check "$POST_CHECK")
  for posting in "${POSTINGS[@]}"; do native_args+=(--posting "$posting"); done
  for item in "${BLOCK_META[@]}"; do native_args+=(--meta "$item"); done
  [[ "$DRY_RUN" -eq 1 ]] && native_args+=(--dry-run)
  [[ "$YES" -eq 1 ]] && native_args+=(--yes)
  exec "$0" "${native_args[@]}"
fi

if [[ "$1" == "journal-block" && "$2" == "add" ]]; then
  shift 2
  JOURNAL_REL=""; JOURNAL_REL_SET=0; DATE=""; DESCRIPTION=""; IDENTITY_MODE="durable"; EVENT_ID=""; EVENT_ID_SET=0
  POSTINGS=(); BLOCK_META=(); DRY_RUN=0; YES=0; POST_CHECK="lint"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --journal-file) JOURNAL_REL="$(get_opt_val_allow_empty "$1" "${2-}")"; JOURNAL_REL_SET=1; shift 2 ;;
      --date) DATE="$(get_opt_val_allow_empty "$1" "${2-}")"; shift 2 ;;
      --description) DESCRIPTION="$(get_opt_val_allow_empty "$1" "${2-}")"; shift 2 ;;
      --identity) IDENTITY_MODE="$(get_opt_val_allow_empty "$1" "${2-}")"; shift 2 ;;
      --event-id) EVENT_ID="$(get_opt_val_allow_empty "$1" "${2-}")"; EVENT_ID_SET=1; shift 2 ;;
      --posting) POSTINGS+=("$(get_opt_val_allow_empty "$1" "${2-}")"); shift 2 ;;
      --meta) BLOCK_META+=("$(get_opt_val_allow_empty "$1" "${2-}")"); shift 2 ;;
      --dry-run) DRY_RUN=1; shift ;;
      --yes) YES=1; shift ;;
      --post-check) POST_CHECK="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      *) echo "ERROR: unknown journal-block add argument: $1" >&2; exit 2 ;;
    esac
  done
  [[ "$JOURNAL_REL_SET" -eq 1 && -n "$JOURNAL_REL" ]] || { echo "ERROR: missing required option: --journal-file" >&2; exit 2; }
  [[ -n "$DATE" ]] || { echo "ERROR: missing required option: --date" >&2; exit 2; }
  [[ "$IDENTITY_MODE" == "ordinary" || "$IDENTITY_MODE" == "durable" ]] || { echo "ERROR: --identity must be ordinary or durable" >&2; exit 2; }
  if [[ "$IDENTITY_MODE" == "ordinary" ]]; then
    [[ "$EVENT_ID_SET" -eq 0 ]] || { echo "ERROR: --event-id must not be supplied for ordinary Journal actuals" >&2; exit 2; }
    EVENT_ID=""
  else
    [[ "$EVENT_ID_SET" -eq 1 && -n "$EVENT_ID" ]] || { echo "ERROR: missing required option: --event-id" >&2; exit 2; }
  fi
  edit_bqn_validate_post_check "$POST_CHECK"

  # Portable fail-closed containment: canonicalize the base with cd -P and
  # reject every symlink and '..' component rather than depending on readlink -f.
  [[ -d "$BASE_DIR" ]] || { echo "ERROR: base directory does not exist: $BASE_DIR" >&2; exit 1; }
  [[ "$JOURNAL_REL" != /* ]] || { echo "ERROR: --journal-file must be relative to --base" >&2; exit 1; }
  [[ "$JOURNAL_REL" == *.journal ]] || { echo "ERROR: --journal-file must have lexical .journal suffix" >&2; exit 1; }
  [[ "$(basename "$JOURNAL_REL")" != "journal.tsv" ]] || { echo "ERROR: journal.tsv is not a native Journal target" >&2; exit 1; }
  CANONICAL_BASE="$(cd -P "$BASE_DIR" && pwd)"
  TARGET_PATH="$CANONICAL_BASE"
  IFS='/' read -r -a JOURNAL_COMPONENTS <<< "$JOURNAL_REL"
  for component in "${JOURNAL_COMPONENTS[@]}"; do
    [[ -z "$component" || "$component" == "." ]] && continue
    [[ "$component" != ".." ]] || { echo "ERROR: --journal-file must not contain a '..' component" >&2; exit 1; }
    TARGET_PATH="$TARGET_PATH/$component"
    [[ ! -L "$TARGET_PATH" ]] || { echo "ERROR: --journal-file symlink paths are rejected" >&2; exit 1; }
  done
  [[ -e "$TARGET_PATH" ]] || { echo "ERROR: native Journal target does not exist: $TARGET_PATH" >&2; exit 1; }
  [[ -f "$TARGET_PATH" ]] || { echo "ERROR: native Journal target is not a regular file: $TARGET_PATH" >&2; exit 1; }
  case "$TARGET_PATH" in "$CANONICAL_BASE"/*) ;; *) echo "ERROR: native Journal target resolves outside --base" >&2; exit 1 ;; esac

  SNAPSHOT_TOKEN="$(safe_snapshot_token "$TARGET_PATH")"
  IFS=$'\t' read -r SNAP_SIZE SNAP_MTIME SNAP_SHA256 <<< "$SNAPSHOT_TOKEN"
  BQN_STDERR="$(mktemp)"
  trap 'rm -f "$BQN_STDERR"' EXIT
  BQN_OUT=""
  if ! BQN_OUT="$(cd "$ROOT_DIR" && bqn src_edit/journal_block_add_cmd.bqn "$CANONICAL_BASE" "$TARGET_PATH" "$DATE" "$DESCRIPTION" "$IDENTITY_MODE" "$EVENT_ID" "${#POSTINGS[@]}" "${POSTINGS[@]}" "${BLOCK_META[@]}" 2>"$BQN_STDERR")"; then
    [[ -n "$BQN_OUT" ]] && printf '%s\n' "$BQN_OUT" >&2
    [[ -s "$BQN_STDERR" ]] && cat "$BQN_STDERR" >&2
    exit 1
  fi
  if ! edit_bqn_split_protocol_output "$BQN_OUT"; then exit 1; fi
  IFS=$'\t' read -r status op transport_prefix protocol_identity protocol_event posting_count candidate_ordinal extra <<< "$EDIT_BQN_PROTOCOL_FIRST_LINE"
  expected_protocol_event="$EVENT_ID"; [[ "$IDENTITY_MODE" == "durable" ]] || expected_protocol_event="-"
  if [[ -n "${extra:-}" || "$status" != "OK" || "$op" != "APPEND_BLOCK" || "$protocol_identity" != "$IDENTITY_MODE" || "$protocol_event" != "$expected_protocol_event" || ! "$transport_prefix" =~ ^[01]$ || ! "$posting_count" =~ ^[0-9]+$ || "$posting_count" -ne "${#POSTINGS[@]}" || ! "$candidate_ordinal" =~ ^[0-9]+$ ]]; then
    echo "ERROR: invalid native Journal BQN protocol header: $EDIT_BQN_PROTOCOL_FIRST_LINE" >&2
    exit 1
  fi
  CANDIDATE_BLOCK="$EDIT_BQN_PROTOCOL_PAYLOAD"
  [[ -n "$CANDIDATE_BLOCK" ]] || { echo "ERROR: native Journal protocol returned an empty block" >&2; exit 1; }
  if ! _safe_write_check_expected_snapshot "$TARGET_PATH" "$SNAP_SIZE" "$SNAP_MTIME" "$SNAP_SHA256"; then exit 1; fi

  MODE="$(edit_bqn_mode "$DRY_RUN" "$YES")"
  printf 'Native Journal block append preview\n'
  printf 'Target: %s\n' "$TARGET_PATH"
  printf 'Mode: %s\n' "$MODE"
  printf 'Post-check: %s\n' "$POST_CHECK"
  printf 'Candidate block:\n%s\n' "$CANDIDATE_BLOCK"
  if [[ "$DRY_RUN" -eq 1 ]]; then printf 'Dry-run only. No files were modified.\n'; exit 0; fi
  if [[ "$YES" -eq 0 ]]; then
    printf 'Append this transaction block? [y/N]: '
    reply=""; read -r reply || true
    case "$reply" in y|Y|yes|YES) ;; *) echo "Cancelled. No files were modified."; exit 0 ;; esac
  fi

  edit_bqn_run_test_hook EDIT_BQN_TEST_BEFORE_JOURNAL_BLOCK_APPEND_HOOK
  TRANSPORT_PAYLOAD="$CANDIDATE_BLOCK"
  [[ "$transport_prefix" -eq 0 ]] || TRANSPORT_PAYLOAD=$'\n'"$CANDIDATE_BLOCK"
  WRITE_OUT=""
  if ! WRITE_OUT="$(safe_append_checked "$TARGET_PATH" "$TRANSPORT_PAYLOAD" "$SNAP_SIZE" "$SNAP_MTIME" "$SNAP_SHA256")"; then exit 1; fi
  printf '%s\n' "$WRITE_OUT"
  BACKUP_PATH="$(awk -F': ' '$1 == "Backup" {print $2}' <<< "$WRITE_OUT")"
  POST_WRITE_SHA="$(_safe_write_sha256 "$TARGET_PATH")"

  NATIVE_OK=1
  NATIVE_OUT=""
  if [[ "${BQN_LEDGER_TEST_MODE:-}" == "1" && "${EDIT_BQN_TEST_FORCE_NATIVE_POST_CHECK_FAIL:-}" == "1" ]]; then
    NATIVE_OK=0; NATIVE_OUT="forced mandatory native validation failure"
  elif ! NATIVE_OUT="$(cd "$ROOT_DIR" && bqn src_edit/journal_native_source_check.bqn "$CANONICAL_BASE" "$TARGET_PATH" "$DATE" "$DESCRIPTION" "$IDENTITY_MODE" "$EVENT_ID" "$candidate_ordinal" "${POSTINGS[@]}" 2>&1)"; then
    NATIVE_OK=0
  fi
  if [[ "$NATIVE_OK" -eq 1 ]]; then
    printf 'Mandatory native validation: OK\n'
    printf '%s\n' "$NATIVE_OUT"
  else
    printf 'Mandatory native validation: FAILED\n%s\n' "$NATIVE_OUT" >&2
  fi

  OPTIONAL_OK=1
  if [[ "$NATIVE_OK" -eq 1 && "$POST_CHECK" == "full" ]]; then
    printf 'Additional full check: starting\n'
    if [[ "${BQN_LEDGER_TEST_MODE:-}" == "1" && -n "${EDIT_BQN_JOURNAL_BLOCK_FULL_CHECK_HOOK:-}" ]]; then
      if ! edit_bqn_run_test_hook EDIT_BQN_JOURNAL_BLOCK_FULL_CHECK_HOOK; then OPTIONAL_OK=0; fi
    elif ! (cd "$ROOT_DIR" && bash tools/check.sh); then
      OPTIONAL_OK=0
    fi
    [[ "$OPTIONAL_OK" -eq 0 ]] || printf 'Additional full check: OK\n'
  elif [[ "$NATIVE_OK" -eq 1 ]]; then
    printf 'Additional check: none (%s mode)\n' "$POST_CHECK"
  fi

  if [[ "$NATIVE_OK" -eq 1 && "$OPTIONAL_OK" -eq 1 ]]; then exit 0; fi
  edit_bqn_run_test_hook EDIT_BQN_TEST_BEFORE_POSTCHECK_ROLLBACK_HOOK
  if safe_restore_backup_checked "$TARGET_PATH" "$BACKUP_PATH" "$POST_WRITE_SHA"; then
    if [[ "$(_safe_write_sha256 "$TARGET_PATH")" != "$SNAP_SHA256" ]]; then
      echo 'Rollback: restore digest mismatch; recovery required' >&2; exit 1
    fi
    echo 'Rollback: restored original bytes' >&2
    exit 1
  fi
  echo 'Rollback: refused; target changed after append; recovery required' >&2
  exit 1
fi

if [[ "$1" == "account" && "$2" == "add" ]]; then
  shift 2
  NAME=""
  ROLE=""
  TYPE=""
  CURRENCY=""
  DRY_RUN=0
  YES=0
  POST_CHECK="lint"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name) NAME="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      --role) ROLE="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      --type) TYPE="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      --currency) CURRENCY="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      --dry-run) DRY_RUN=1; shift ;;
      --yes) YES=1; shift ;;
      --post-check) POST_CHECK="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      *) echo "ERROR: unknown account add argument: $1" >&2; exit 2 ;;
    esac
  done
  [[ -n "$NAME" ]] || { echo "ERROR: missing required option: --name" >&2; exit 2; }
  [[ -n "$ROLE" ]] || { echo "ERROR: missing required option: --role" >&2; exit 2; }
  edit_bqn_validate_post_check "$POST_CHECK"

  TARGET_PATH="$BASE_DIR/$ACCOUNTS_FILE"
  SNAPSHOT_TOKEN="$(safe_snapshot_token "$TARGET_PATH")"
  IFS=$'\t' read -r SNAP_SIZE SNAP_MTIME SNAP_SHA256 <<< "$SNAPSHOT_TOKEN"
  BQN_STDERR="$(mktemp)"
  trap 'rm -f "$BQN_STDERR"' EXIT
  BQN_OUT=""
  if ! BQN_OUT="$(cd "$ROOT_DIR" && bqn src_edit/account_add_cmd.bqn "$BASE_DIR" "$NAME" "$ROLE" "$TYPE" "$CURRENCY" 2>"$BQN_STDERR")"; then
    [[ -n "$BQN_OUT" ]] && printf '%s\n' "$BQN_OUT" >&2
    [[ -s "$BQN_STDERR" ]] && cat "$BQN_STDERR" >&2
    exit 1
  fi
  if ! edit_bqn_split_protocol_output "$BQN_OUT"; then exit 1; fi
  FIRST_LINE="$EDIT_BQN_PROTOCOL_FIRST_LINE"
  PAYLOAD="$EDIT_BQN_PROTOCOL_PAYLOAD"
  if ! edit_bqn_require_append_protocol "$FIRST_LINE" "$ACCOUNTS_FILE"; then exit 1; fi
  MODE="$(edit_bqn_mode "$DRY_RUN" "$YES")"
  edit_bqn_print_append_preview "Account" "$TARGET_PATH" "$MODE" "$POST_CHECK" "Account row" "$PAYLOAD"
  if [[ "$DRY_RUN" -eq 1 ]]; then
    printf 'Dry-run only. No files were modified.\n'
    exit 0
  fi
  if [[ "$YES" -eq 0 ]] && ! confirm_append; then
    echo "Cancelled. No files were modified."
    exit 0
  fi
  edit_bqn_apply_append_checked "$BASE_DIR" "$POST_CHECK" "$TARGET_PATH" "$PAYLOAD" "$SNAP_SIZE" "$SNAP_MTIME" "$SNAP_SHA256" EDIT_BQN_TEST_BEFORE_APPEND_HOOK
  exit 0
fi

if [[ "$1" == "account" && "$2" == "list" ]]; then
  shift 2
  ROLE=""
  CURRENCY=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --role) ROLE="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      --currency) CURRENCY="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      *) echo "ERROR: unknown account list argument: $1" >&2; exit 2 ;;
    esac
  done
  cd "$ROOT_DIR" && bqn src_edit/account_list_cmd.bqn "$BASE_DIR" "$ROLE" "$CURRENCY"
  exit $?
fi

if [[ "$1" == "journal" && "$2" == "list" ]]; then
  shift 2
  FORMAT="text"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --format) FORMAT="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      *) echo "ERROR: unknown journal list argument: $1" >&2; exit 2 ;;
    esac
  done
  case "$FORMAT" in
    tsv|text) ;;
    *) echo "ERROR: invalid format: $FORMAT (expected 'tsv' or 'text')" >&2; exit 2 ;;
  esac
  cd "$ROOT_DIR" && bqn src_edit/journal_list_cmd.bqn "$BASE_DIR" "$FORMAT"
  exit $?
fi

if [[ "$1" == "journal" && "$2" == "cleanup-plan" ]]; then
  shift 2
  FORMAT="text"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --format) FORMAT="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      *) echo "ERROR: unknown journal cleanup-plan argument: $1" >&2; exit 2 ;;
    esac
  done
  case "$FORMAT" in
    tsv|text) ;;
    *) echo "ERROR: invalid format: $FORMAT (expected 'tsv' or 'text')" >&2; exit 2 ;;
  esac
  cd "$ROOT_DIR" && bqn src_edit/journal_cleanup_plan_cmd.bqn "$BASE_DIR" "$FORMAT"
  exit $?
fi

if [[ "$1" == "journal" && "$2" == "cleanup-apply" ]]; then
  shift 2
  DRY_RUN=0; YES=0; POST_CHECK="lint"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dry-run) DRY_RUN=1; shift ;;
      --yes) YES=1; shift ;;
      --post-check) POST_CHECK="$(get_opt_val "$1" "${2-}")"; shift 2 ;;
      *) echo "ERROR: unknown journal cleanup-apply argument: $1" >&2; exit 2 ;;
    esac
  done
  edit_bqn_validate_post_check "$POST_CHECK"

  ACTUAL_ROUTE="$(cd "$ROOT_DIR" && bqn src_edit/actual_source_route_cmd.bqn "$BASE_DIR")"
  IFS=$'\t' read -r ACTUAL_MODE ACTUAL_FILE ACTUAL_EXTRA <<< "$ACTUAL_ROUTE"
  [[ -z "${ACTUAL_EXTRA:-}" ]] || { echo "ERROR: invalid actual-source route" >&2; exit 1; }
  [[ "$ACTUAL_MODE" == "journal" ]] || { echo "ERROR: journal cleanup-apply requires ACTUAL_SOURCE=journal; no files changed" >&2; exit 1; }
  [[ -d "$BASE_DIR" ]] || { echo "ERROR: base directory does not exist: $BASE_DIR" >&2; exit 1; }
  [[ "$ACTUAL_FILE" != /* ]] || { echo "ERROR: configured Journal path is unsafe" >&2; exit 1; }
  CANONICAL_BASE="$(cd -P "$BASE_DIR" && pwd)"
  TARGET_PATH="$CANONICAL_BASE"
  IFS='/' read -r -a CLEANUP_COMPONENTS <<< "$ACTUAL_FILE"
  for component in "${CLEANUP_COMPONENTS[@]}"; do
    [[ -z "$component" || "$component" == "." ]] && continue
    [[ "$component" != ".." ]] || { echo "ERROR: configured Journal path is unsafe" >&2; exit 1; }
    TARGET_PATH="$TARGET_PATH/$component"
    [[ ! -L "$TARGET_PATH" ]] || { echo "ERROR: configured Journal symlink paths are rejected" >&2; exit 1; }
  done
  [[ -f "$TARGET_PATH" ]] || { echo "ERROR: configured Journal is not a regular file" >&2; exit 1; }
  case "$TARGET_PATH" in "$CANONICAL_BASE"/*) ;; *) echo "ERROR: configured Journal resolves outside --base" >&2; exit 1 ;; esac

  SNAPSHOT_TOKEN="$(safe_snapshot_token "$TARGET_PATH")"
  IFS=$'\t' read -r SNAP_SIZE SNAP_MTIME SNAP_SHA256 <<< "$SNAPSHOT_TOKEN"
  CANDIDATE_FILE="$(mktemp "${TMPDIR:-/tmp}/bqn-ledger-cleanup-candidate.XXXXXX")"
  BQN_STDERR="$(mktemp "${TMPDIR:-/tmp}/bqn-ledger-cleanup-stderr.XXXXXX")"
  trap 'rm -f "$CANDIDATE_FILE" "$BQN_STDERR"' EXIT
  BQN_OUT=""
  if ! BQN_OUT="$(cd "$ROOT_DIR" && bqn src_edit/journal_cleanup_apply_cmd.bqn "$CANONICAL_BASE" "$CANDIDATE_FILE" 2>"$BQN_STDERR")"; then
    [[ -n "$BQN_OUT" ]] && printf '%s\n' "$BQN_OUT" >&2
    [[ -s "$BQN_STDERR" ]] && cat "$BQN_STDERR" >&2
    exit 1
  fi
  mapfile -t CLEANUP_LINES <<< "$BQN_OUT"
  IFS=$'\t' read -r STATUS OP PROTOCOL_FILE REMOVAL_COUNT TOTAL_COUNT EXTRA <<< "${CLEANUP_LINES[0]}"
