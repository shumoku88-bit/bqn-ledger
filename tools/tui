#!/bin/bash
set -euo pipefail

# tools/tui — Terminal UI for bqn-ledger
#
# Single-pane report viewer with keyboard navigation.
# Uses Go + tview. Reads from BQN engine (read-only).
# Writes go through tools/edit (Go editor safe append).

DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" >/dev/null 2>&1 && pwd )"
ROOT_DIR="$(cd -- "$DIR/.." && pwd)"
cd "$ROOT_DIR"

# Load shared system defaults helper
source "$ROOT_DIR/tools/lib/system-defaults.sh"

base="${LEDGER_DATA_DIR:-$(get_default_base_dir)}"
if [[ $# -gt 0 && "$1" != --* ]]; then
  base="$1"
  shift
fi

ensure_ledger_report_base "$base"

# Build if needed
(cd "$ROOT_DIR/tui" && go build -o "$DIR/tui.bin" .)

exec "$DIR/tui.bin" "$base" "$@"
