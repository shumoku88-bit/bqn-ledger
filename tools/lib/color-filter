#!/usr/bin/env bash
# tools/lib/color-filter — Add terminal ANSI colors to plain text ledger reports.
# Read stdin, write colored text to stdout.

set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$( cd -P "$( dirname "$SOURCE" )" >/dev/null 2>&1 && pwd )"
  SOURCE="$(readlink "$SOURCE")"
  [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$( cd -P "$( dirname "$SOURCE" )" >/dev/null 2>&1 && pwd )"

# Initialize theme (which exports ESC_* variables)
# We assume base_dir might be set by the caller (e.g. main-ui.sh), but if not it will fallback.
source "$SCRIPT_DIR/theme.sh"

# If output is not a TTY or theme is plain, don't colorize
if [[ ! -t 1 || "$BL_THEME" == "plain" ]]; then
  exec cat
fi

# Colorize keywords and headers using the themed escape sequences
sed \
  -e "s/\<completed\>/${ESC_OK}completed${ESC_RESET}/g" \
  -e "s/\<paid\>/${ESC_OK}paid${ESC_RESET}/g" \
  -e "s/\<future\>/${ESC_FUTURE}future${ESC_RESET}/g" \
  -e "s/\<due\>/${ESC_WARN}due${ESC_RESET}/g" \
  -e "s/\<overdue\>/${ESC_ERROR}overdue${ESC_RESET}/g" \
  -e "s/== \(.*\) ==/${ESC_HEADER}== \1 ==${ESC_RESET}/g" \
  -e "s/── \(.*\) ──/${ESC_MUTED}── \1 ──${ESC_RESET}/g" \
  -e "s/^\([0-9]\{1,2\}\. .*\)/${ESC_NUM_HEADER}\1${ESC_RESET}/g"
