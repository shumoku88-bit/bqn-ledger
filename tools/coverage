#!/usr/bin/env bash
set -euo pipefail

# tools/coverage — BQN module inventory and direct editor-check map.

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$( cd -P "$( dirname "$SOURCE" )" >/dev/null 2>&1 && pwd )"
  SOURCE="$(readlink "$SOURCE")"
  [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$( cd -P "$( dirname "$SOURCE" )" >/dev/null 2>&1 && pwd )"
ROOT_DIR="$(cd -- "$SCRIPT_DIR/.." && pwd)"

cd "$ROOT_DIR"

shopt -s nullglob

src_next_modules=(src_next/*.bqn)
src_next_tests=(tests/test_src_next_*.bqn)

printf '=== src_next module inventory ===\n'
printf '  modules: %s\n' "${#src_next_modules[@]}"
printf '  matching test files: %s\n' "${#src_next_tests[@]}"
for test_file in "${src_next_tests[@]}"; do
  printf '    %s\n' "$(basename "$test_file")"
done

printf '=== src_edit module inventory ===\n'
covered=0
total=0
for mod in src_edit/*.bqn; do
  basename=$(basename "$mod" .bqn)
  total=$((total + 1))

  case "$basename" in
    account_add_cmd)
      coverage=(checks/check-edit-bqn-account-list.sh)
      ;;
    validate|render|plan_id)
      coverage=(tests/test_edit_validate.bqn)
      ;;
    editor_cmd)
      coverage=(
        checks/check-edit-bqn-journal-add.sh
        checks/check-edit-bqn-journal-reverse.sh
        checks/check-edit-bqn-plan-add.sh
        checks/check-edit-bqn-plan-edit.sh
        checks/check-edit-bqn-plan-finish.sh
        checks/check-edit-bqn-plan-list.sh
      )
      ;;
    journal_add_cmd)
      coverage=(checks/check-edit-bqn-journal-add.sh)
      ;;
    issue_add_cmd)
      coverage=(checks/check-edit-bqn-journal-add.sh)
      ;;
    plan_add_cmd)
      coverage=(checks/check-edit-bqn-plan-add.sh)
      ;;
    plan_finish_cmd)
      coverage=(checks/check-edit-bqn-plan-finish.sh)
      ;;
    plan_list_cmd)
      coverage=(checks/check-edit-bqn-plan-list.sh)
      ;;
    *)
      coverage=()
      ;;
  esac

  if ((${#coverage[@]} > 0)); then
    covered=$((covered + 1))
    printf '  covered: %s <- %s\n' "$basename" "${coverage[*]}"
  else
    printf '  untested: %s\n' "$basename"
  fi
done

printf '  covered: %s / %s BQN modules\n' "$covered" "$total"
