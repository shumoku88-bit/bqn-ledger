#!/usr/bin/env bash
# tools/report — daily household report using src_next engine
#
# Default production report entrypoint.
# Uses src_next/report.bqn and defaults to LEDGER_DATA_DIR, then config/system_defaults.tsv.
#
# Usage:
#   tools/report                 → uses LEDGER_DATA_DIR or configured default (data/ sandbox)
#   tools/report data            → explicit sandbox
#   tools/report fixtures/basic  → fixture mode
#   tools/report --no-color      → suppress ANSI color
#   tools/report --color=always  → force ANSI color
#   tools/report <base> --section balances [--currency JPY|ILS]
#                                → selected human balances (default from config.tsv)

set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$( cd -P "$( dirname "$SOURCE" )" >/dev/null 2>&1 && pwd )"
  SOURCE="$(readlink "$SOURCE")"
  [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$( cd -P "$( dirname "$SOURCE" )" >/dev/null 2>&1 && pwd )"
ROOT_DIR="$(cd -- "$SCRIPT_DIR/.." && pwd)"
cd "$ROOT_DIR"
source "$ROOT_DIR/tools/lib/system-defaults.sh"

base="${LEDGER_DATA_DIR:-$(get_default_base_dir)}"
if [[ $# -gt 0 && "$1" != --* ]]; then
  base="$1"
  shift
fi

color_args=()
has_color_arg=0
while [[ $# -gt 0 ]]; do
  case "$1" in
    --write-section-cache)
      if [[ $# -lt 2 ]]; then
        echo "Error: --write-section-cache requires a directory" >&2
        exit 1
      fi
      dir_arg="$2"
      if [[ "$dir_arg" != /* ]]; then
        dir_arg="$PWD/$dir_arg"
      fi
      color_args+=("--write-section-cache" "$dir_arg")
      shift 2
      ;;
    --no-color|--color=never|--color=always)
      has_color_arg=1
      color_args+=("$1")
      shift
      ;;
    *)
      color_args+=("$1")
      shift
      ;;
  esac
done

if [[ "$has_color_arg" -eq 0 ]]; then
  if [[ -n "${NO_COLOR:-}" || ! -t 1 ]]; then
    color_args+=(--no-color)
  fi
fi

ensure_ledger_report_base "$base"

exec bqn src_next/report.bqn "$base" "${color_args[@]}"
