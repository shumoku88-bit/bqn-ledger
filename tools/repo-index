#!/usr/bin/env bash
# tools/repo-index
# Lightweight repository indexer MVP
#
# Usage:
#   tools/repo-index                  print TSV index to stdout
#   tools/repo-index --baseline       save current index as baseline
#   tools/repo-index --diff           show diff from saved baseline
set -euo pipefail

# Always run from the repo root
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
cd "$SCRIPT_DIR/.."

BASELINE_FILE="$SCRIPT_DIR/.repo-index-baseline.tsv"
MODE="print"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --baseline) MODE="baseline"; shift ;;
    --diff)     MODE="diff"; shift ;;
    -h|--help)
      echo "Usage: tools/repo-index [--baseline|--diff]" >&2
      echo "  (no flag)   print TSV index to stdout" >&2
      echo "  --baseline  save current index as baseline ($BASELINE_FILE)" >&2
      echo "  --diff      show added/removed lines vs baseline" >&2
      exit 0
      ;;
    *) echo "Unknown option: $1" >&2; exit 1 ;;
  esac
done

# For --diff, we need a baseline to exist
if [ "$MODE" = "diff" ] && [ ! -f "$BASELINE_FILE" ]; then
  echo "ERROR: no baseline found. Run 'tools/repo-index --baseline' first." >&2
  exit 1
fi

# Generate index to temp file for baseline/diff modes
if [ "$MODE" != "print" ]; then
  TMP_IDX="$(mktemp)"
  trap 'rm -f "$TMP_IDX"' EXIT
  exec 3>&1  # save stdout
  exec > "$TMP_IDX"
fi

# Print TSV header
echo -e "path\tkind\tname\ttarget\tnote"

# 1. BQN imports
find src_next tests tools -name "*.bqn" -type f 2>/dev/null | sort | while read -r file; do
  grep -v '^[[:space:]]*#' "$file" 2>/dev/null | while read -r line; do
    if [[ "$line" =~ ^[[:space:]]*([a-zA-Z0-9_]+)[[:space:]]*(←|⇐)[[:space:]]*•Import[[:space:]]*\"([^\"]+)\" ]]; then
      name="${BASH_REMATCH[1]}"
      target="${BASH_REMATCH[3]}"
      echo -e "${file}\tbqn-import\t${name}\t${target}\tfrom •Import"
    fi
  done || true
done

# 2. BQN definition candidates
find src_next tests tools -name "*.bqn" -type f 2>/dev/null | sort | while read -r file; do
  # Collect exported symbols in the file to determine "exported" note (safe with || true)
  exported_symbols=$( (grep -v '^[[:space:]]*#' "$file" | grep -oE '[a-zA-Z0-9_]+[[:space:]]*⇐' | sed -E 's/[[:space:]]*⇐//' | sort -u) 2>/dev/null || true )
  
  grep -v '^[[:space:]]*#' "$file" 2>/dev/null | grep -v '•Import' | while read -r line; do
    if [[ "$line" =~ ^[[:space:]]*([A-Z][a-zA-Z0-9_]*)[[:space:]]*(←|⇐) ]]; then
      name="${BASH_REMATCH[1]}"
      arrow="${BASH_REMATCH[2]}"
      note=""
      if [ "$arrow" = "⇐" ] || ( [ -n "$exported_symbols" ] && echo "$exported_symbols" | grep -qFx "$name" ); then
        note="exported"
      fi
      echo -e "${file}\tbqn-def\t${name}\t\t${note}"
    fi
  done || true
done

# 3. check scripts
find checks \( -name "check-*.sh" -o -name "check-*.bqn" -o -name "*check*.bqn" \) -type f 2>/dev/null | sort | while read -r file; do
  basename=$(basename "$file")
  name="${basename%.*}"
  ext="${basename##*.}"
  target=""
  if [ "$ext" = "sh" ]; then
    target="shell"
  elif [ "$ext" = "bqn" ]; then
    target="bqn"
  fi
  echo -e "${file}\tcheck\t${name}\t${target}\t"
done

# 4. checks/check.sh calls
if [ -f checks/check.sh ]; then
  grep -v '^[[:space:]]*#' checks/check.sh 2>/dev/null | grep -v '^[[:space:]]*$' | while read -r line; do
    if [[ "$line" =~ ^[[:space:]]*(bash|bqn|tools/sqz-report)[[:space:]]+([^[:space:]<>|&;]+)(.*) ]]; then
      cmd="${BASH_REMATCH[1]}"
      called_path="${BASH_REMATCH[2]}"
      rest="${BASH_REMATCH[3]}"
      called_basename=$(basename "$called_path")
      
      note="$cmd"
      if [[ "$rest" =~ fixtures/([^[:space:]/>|&;]+) ]]; then
        fixture="fixtures/${BASH_REMATCH[1]}"
        as_of=""
        if [[ "$rest" =~ ([0-9]{4}-[0-9]{2}-[0-9]{2}) ]]; then
          as_of="${BASH_REMATCH[1]}"
        fi
        if [ -n "$as_of" ]; then
          note="$note fixture=$fixture as_of=$as_of"
        else
          note="$note fixture=$fixture"
        fi
      fi
      echo -e "checks/check.sh\tcheck-call\t${called_basename}\t${called_path}\t${note}"
    fi
  done || true
fi

# 5. fixtures
find fixtures -maxdepth 1 -mindepth 1 -type d 2>/dev/null | sort | while read -r dir; do
  name=$(basename "$dir")
  note=""
  if [ -f "${dir}/README.md" ]; then
    note=$( (grep -E '^#[[:space:]]' "${dir}/README.md" | head -n 1 | sed -E 's/^#[[:space:]]*//' | xargs) 2>/dev/null || true )
  fi
  
  files=()
  for tsv in journal.tsv plan.tsv budget_alloc.tsv accounts.tsv; do
    if [ -f "${dir}/${tsv}" ]; then
      files+=("$tsv")
    fi
  done
  
  if [ ${#files[@]} -gt 0 ]; then
    tsv_list=$(IFS=,; echo "${files[*]}")
    if [ -n "$note" ]; then
      note="${note} [has: ${tsv_list}]"
    else
      note="[has: ${tsv_list}]"
    fi
  fi
  echo -e "${dir}\tfixture\t${name}\t\t${note}"
done

# 6. exporters (reserved for future machine-output entrypoints)
find tools -maxdepth 1 -name "export-*" -type f 2>/dev/null | sort | while read -r file; do
  basename=$(basename "$file")
  name="${basename%.*}"
  echo -e "${file}\texporter\t${name}\t\tmachine output"
done

# 7. docs
find docs -name "*.md" -type f 2>/dev/null | sort | while read -r file; do
  kind="doc"
  basename=$(basename "$file")
  if [[ "$basename" =~ _HANDOFF\.md$ ]]; then
    kind="handoff-doc"
  elif [[ "$basename" =~ _TASK\.md$ ]]; then
    kind="task-doc"
  elif [[ "$basename" =~ _PLAN\.md$ ]]; then
    kind="plan-doc"
  elif [[ "$basename" =~ _DESIGN\.md$ ]]; then
    kind="design-doc"
  elif [[ "$basename" =~ _POLICY\.md$ ]]; then
    kind="policy-doc"
  elif [[ "$file" =~ ^docs/archive/ ]]; then
    kind="archive-doc"
  fi
  
  first_heading=""
  if [ -f "$file" ]; then
    first_heading=$( (grep -E '^#[[:space:]]' "$file" | head -n 1 | sed -E 's/^#[[:space:]]*//' | xargs) 2>/dev/null || true )
  fi
  echo -e "${file}\t${kind}\t${first_heading}\t\t"
done

for doc_file in TODO.md AGENTS.md; do
  if [ -f "$doc_file" ]; then
    first_heading=$( (grep -E '^#[[:space:]]' "$doc_file" | head -n 1 | sed -E 's/^#[[:space:]]*//' | xargs) 2>/dev/null || true )
    echo -e "${doc_file}\tdoc\t${first_heading}\t\t"
  fi
done

# ── Baseline / Diff handling ──
if [ "$MODE" = "baseline" ]; then
  exec 1>&3  # restore stdout
  cp "$TMP_IDX" "$BASELINE_FILE"
  echo "Baseline saved: $BASELINE_FILE ($(wc -l < "$BASELINE_FILE" | tr -d ' ') lines)" >&2
elif [ "$MODE" = "diff" ]; then
  exec 1>&3  # restore stdout
  echo "=== Added (in current, not in baseline) ==="
  comm -13 <(sort "$BASELINE_FILE") <(sort "$TMP_IDX") || true
  echo ""
  echo "=== Removed (in baseline, not in current) ==="
  comm -23 <(sort "$BASELINE_FILE") <(sort "$TMP_IDX") || true
fi
