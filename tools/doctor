#!/usr/bin/env bash
set -euo pipefail

# tools/doctor — dependency health check and SBOM for bqn-ledger

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$( cd -P "$( dirname "$SOURCE" )" >/dev/null 2>&1 && pwd )"
  SOURCE="$(readlink "$SOURCE")"
  [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$( cd -P "$( dirname "$SOURCE" )" >/dev/null 2>&1 && pwd )"
ROOT_DIR="$(cd -- "$SCRIPT_DIR/.." && pwd)"
cd "$ROOT_DIR"
source "$ROOT_DIR/tools/lib/system-defaults.sh"

red=''
green=''
yellow=''
reset=''
if [[ -t 1 && -z "${NO_COLOR:-}" ]]; then
  red='\033[31m' green='\033[32m' yellow='\033[33m' reset='\033[0m'
fi

pass()  { printf "  ${green}PASS${reset} %s\n" "$*"; }
warn()  { printf "  ${yellow}WARN${reset} %s\n" "$*"; }
fail()  { printf "  ${red}FAIL${reset} %s\n" "$*"; all_ok=0; }
info()  { printf "  %s\n" "$*"; }

all_ok=1
failures=0

echo "=== bqn-ledger doctor ==="
echo ""

# ── Required dependencies ──
echo "Required:"

# CBQN
if command -v bqn >/dev/null 2>&1; then
  ver=$(bqn --version 2>&1 | head -1)
  pass "CBQN: $ver"
else
  fail "CBQN not found (install: https://github.com/dzaima/CBQN)"
  failures=$((failures + 1))
fi
echo ""

# ── Optional dependencies ──
echo "Optional:"

for tool in fzf gum rg; do
  if command -v "$tool" >/dev/null 2>&1; then
    pass "$tool: $(command -v "$tool")"
  else
    warn "$tool: not installed"
  fi
done

echo ""

# ── Data directory ──
echo "Data:"
base_source="config/system_defaults.tsv DEFAULT_BASE_DIR"
if [[ -n "${LEDGER_DATA_DIR:-}" ]]; then
  base_source="LEDGER_DATA_DIR"
fi
base_dir="${LEDGER_DATA_DIR:-$(get_default_base_dir)}"
data_ok=1
info "base dir ($base_source): $base_dir"

if [[ -d "$base_dir" ]]; then
  mapfile -t missing_required < <(ledger_base_missing_required "$base_dir")
  if [[ ${#missing_required[@]} -eq 0 ]]; then
    pass "report-required TSV present: accounts.tsv journal.tsv cycle.tsv"
  else
    fail "missing report-required TSV: ${missing_required[*]}"
    failures=$((failures + 1))
    data_ok=0
  fi

  for f in plan.tsv budget_alloc.tsv config.tsv; do
    if [[ -f "$base_dir/$f" ]]; then
      pass "$f"
    else
      warn "$f missing (some views or write paths may be unavailable)"
    fi
  done
else
  fail "base dir not found: $base_dir"
  failures=$((failures + 1))
  data_ok=0
fi

if [[ "$data_ok" -eq 0 ]]; then
  if suggestion="$(ledger_suggest_base_dir)"; then
    warn "candidate data directory found: $suggestion"
    info "try: export LEDGER_DATA_DIR=$suggestion"
  else
    warn "no local candidate data directory found"
  fi
fi

echo ""

# ── Quick engine smoke test ──
echo "Engine:"
if [[ "$data_ok" -ne 1 ]]; then
  warn "src_next engine smoke skipped because data directory is not usable"
elif out=$(bqn src_next/summary.bqn "$base_dir" 2>&1); then
  if echo "$out" | grep -q "as_of:"; then
    pass "src_next engine produces valid summary"
  else
    fail "src_next engine output missing expected fields"
    failures=$((failures + 1))
  fi
else
  fail "src_next engine failed: $out"
  failures=$((failures + 1))
fi

echo ""

# ── SBOM ──
echo "=== SBOM (Software Bill of Materials) ==="
echo ""
echo "Runtime dependencies:"
echo "  CBQN (dzaima/BQN)  — BQN implementation, commit 12a4fb9f+"
echo ""
echo "Optional tools:"
echo "  fzf  — fuzzy selector for add-ui.sh / main-ui.sh"
echo "  gum  — terminal widgets for add-ui.sh"
echo "  rg   — ripgrep for check scripts"
echo ""
echo "Dev tools (bundled):"
echo "  bqn-eval, bqn-dump, query, envelope-calc, scaffold-check.sh, repo-index"
echo ""

# ── Result ──
echo "=== Result ==="
if [[ "$all_ok" -eq 1 ]]; then
  echo "${green}All checks passed.${reset}"
  exit 0
else
  echo "${red}$failures issue(s) found.${reset}"
  exit 1
fi
