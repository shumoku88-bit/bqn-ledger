#!/usr/bin/env bash
# tools/edit — Shell wrapper for BQN editor commands
#
# Replicates the Go editor interface and atomic write behavior.
# Uses BQN for pure TSV validations/rendering and Bash for IO/backups.

set -euo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$DIR/lib/safe-write.sh"

# ── Load defaults ───────────────────────────────────────────────

DEFAULT_BASE_DIR="data"
DEFAULT_ACCOUNTS_FILE="accounts.tsv"
DEFAULT_JOURNAL_FILE="journal.tsv"
DEFAULT_PLAN_FILE="plan.tsv"
DEFAULT_BUDGET_ALLOC_FILE="budget_alloc.tsv"
DEFAULT_CYCLE_FILE="cycle.tsv"
DEFAULT_CONFIG_FILE="config.tsv"

if [[ -f "config/system_defaults.tsv" ]]; then
  while IFS=$'\t' read -r key val || [[ -n "$key" ]]; do
    [[ "$key" =~ ^# ]] || [[ -z "$key" ]] && continue
    declare "$key"="$val"
  done < "config/system_defaults.tsv"
fi

BASE_DIR="${LEDGER_DATA_DIR:-$DEFAULT_BASE_DIR}"

# ── Extract --base option anywhere in args ──────────────────────

REM_ARGS=()
while [[ $# -gt 0 ]]; do
  if [[ "$1" == "--base" ]]; then
    if [[ $# -lt 2 ]]; then
      echo "ERROR: missing value for --base" >&2
      exit 2
    fi
    BASE_DIR="$2"
    shift 2
  else
    REM_ARGS+=("$1")
    shift
  fi
done

# Export base dir for BQN editor command
export LEDGER_DATA_DIR="$BASE_DIR"

# Restore remaining arguments
set -- "${REM_ARGS[@]}"

if [[ $# -lt 1 ]]; then
  echo "ERROR: command is required" >&2
  echo "Usage: tools/edit <command> [subcommand] [options]" >&2
  exit 2
fi

CMD="$1"
shift

# ── Option Defaults ─────────────────────────────────────────────

DATE=""
MEMO=""
FROM=""
TO=""
AMOUNT=""
META=()
DRY_RUN="0"
YES="0"
POST_CHECK="lint"
ID=""
INDEX="0"
STATUS="open"
TITLE=""
FORMAT="text"
ALL="0"
APPLY="0"
ACTUAL_DATE=""

# Helper to parse option values
get_opt_val() {
  local opt="$1"
  local val="${2:-}"
  if [[ -z "$val" ]] || [[ "$val" == --* ]]; then
    echo "ERROR: missing value for $opt" >&2
    exit 2
  fi
  printf '%s\n' "$val"
}

get_opt_val_allow_empty() {
  local opt="$1"
  if [[ $# -lt 2 ]]; then
    echo "ERROR: missing value for $opt" >&2
    exit 2
  fi
  printf '%s\n' "$2"
}

# ── Parse subcommands ───────────────────────────────────────────

case "$CMD" in
  journal|budget|plan)
    if [[ $# -lt 1 ]]; then
      echo "ERROR: $CMD subcommand is required" >&2
      exit 2
    fi
    SUBCMD="$1"
    shift
    
    # Parse options
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --date) DATE="$(get_opt_val "$1" "${2:-}")"; shift 2 ;;
        --memo) MEMO="$(get_opt_val_allow_empty "$1" "$2")"; shift 2 ;;
        --from) FROM="$(get_opt_val "$1" "${2:-}")"; shift 2 ;;
        --to) TO="$(get_opt_val "$1" "${2:-}")"; shift 2 ;;
        --amount) AMOUNT="$(get_opt_val "$1" "${2:-}")"; shift 2 ;;
        --meta) val="$(get_opt_val "$1" "${2:-}")"; META+=("$val"); shift 2 ;;
        --dry-run) DRY_RUN="1"; shift ;;
        --yes) YES="1"; shift ;;
        --post-check) POST_CHECK="$(get_opt_val "$1" "${2:-}")"; shift 2 ;;
        --id) ID="$(get_opt_val "$1" "${2:-}")"; shift 2 ;;
        --index) INDEX="$(get_opt_val "$1" "${2:-}")"; shift 2 ;;
        --all) ALL="1"; shift ;;
        --format) FORMAT="$(get_opt_val "$1" "${2:-}")"; shift 2 ;;
        --apply) APPLY="1"; shift ;;
        --actual-date) ACTUAL_DATE="$(get_opt_val "$1" "${2:-}")"; shift 2 ;;
        *) echo "ERROR: unknown option $1" >&2; exit 2 ;;
      esac
    done
    ;;
    
  issue)
    if [[ $# -lt 1 ]] || [[ "$1" != "add" ]]; then
      echo "ERROR: unknown issue subcommand" >&2
      exit 2
    fi
    SUBCMD="$1"
    shift
    
    # Parse issue add options
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --date) DATE="$(get_opt_val "$1" "${2:-}")"; shift 2 ;;
        --status) STATUS="$(get_opt_val "$1" "${2:-}")"; shift 2 ;;
        --title) TITLE="$(get_opt_val "$1" "${2:-}")"; shift 2 ;;
        --amount) AMOUNT="$(get_opt_val "$1" "${2:-}")"; shift 2 ;;
        --memo) MEMO="$(get_opt_val_allow_empty "$1" "$2")"; shift 2 ;;
        --dry-run) DRY_RUN="1"; shift ;;
        --yes) YES="1"; shift ;;
        *) echo "ERROR: unknown option $1" >&2; exit 2 ;;
      esac
    done
    ;;
    
  help)
    echo "Usage: tools/edit <command> [subcommand] [options]"
    exit 0
    ;;
    
  *)
    echo "ERROR: unknown command: $CMD" >&2
    exit 2
    ;;
esac

# ── Execute BQN command ─────────────────────────────────────────

# Default date to today if not provided (only for issue add)
if [[ -z "$DATE" ]] && [[ "$CMD" == "issue" ]]; then
  DATE="$(date +%Y-%m-%d)"
fi

# Form arguments to call BQN dispatcher
BQN_ARGS=("$BASE_DIR" "$CMD" "$SUBCMD")

case "$CMD" in
  journal|budget)
    if [[ "$SUBCMD" == "add" ]]; then
      # Join meta by space
      META_STR="${META[*]:-}"
      BQN_ARGS+=("$DATE" "$MEMO" "$FROM" "$TO" "$AMOUNT" "$META_STR" "$POST_CHECK" "")
    elif [[ "$SUBCMD" == "reverse" ]]; then
      BQN_ARGS+=("$ID" "$INDEX" "$DATE" "$YES")
    else
      echo "ERROR: unknown journal subcommand: $SUBCMD" >&2
      exit 2
    fi
    ;;
    
  issue)
    BQN_ARGS+=("$DATE" "$STATUS" "$TITLE" "$AMOUNT" "$MEMO")
    ;;
    
  plan)
    if [[ "$SUBCMD" == "add" ]]; then
      META_STR="${META[*]:-}"
      BQN_ARGS+=("$DATE" "$MEMO" "$FROM" "$TO" "$AMOUNT" "$META_STR" "$POST_CHECK" "$ID")
    elif [[ "$SUBCMD" == "list" ]]; then
      BQN_ARGS+=("$ALL" "$FORMAT")
    elif [[ "$SUBCMD" == "finish" ]]; then
      # If actual date not specified, we prompt later in Bash, so we send empty actualDate for now
      BQN_ARGS+=("$INDEX" "$ID" "$ACTUAL_DATE" "$ALL" "$APPLY")
    elif [[ "$SUBCMD" == "edit" ]]; then
      BQN_ARGS+=("$INDEX" "$ID" "$DATE" "$AMOUNT" "$ALL" "$DRY_RUN" "$YES" "$POST_CHECK")
    else
      echo "ERROR: unknown plan subcommand: $SUBCMD" >&2
      exit 2
    fi
    ;;
esac

# Run BQN dispatcher
BQN_OUT="$(bqn "$DIR/../src_edit/editor_cmd.bqn" "${BQN_ARGS[@]}" 2>&1)" || {
  # BQN exited with error status
  echo "$BQN_OUT" >&2
  exit 1
}

# ── Process BQN dispatcher outputs ──────────────────────────────

# Parse output header
IFS=$'\t' read -r HEADER REMAINDER <<< "$BQN_OUT"

if [[ "$HEADER" == "ERROR" ]]; then
  echo "ERROR: $REMAINDER" >&2
  exit 2
fi

# Determine target file and details based on command type
case "$CMD" in
  journal)
    TARGET_FILE="$DEFAULT_JOURNAL_FILE"
    TITLE="Journal"
    ROW_TITLE="Journal row"
    ;;
  budget)
    TARGET_FILE="$DEFAULT_BUDGET_ALLOC_FILE"
    TITLE="Budget allocation"
    ROW_TITLE="Budget row"
    ;;
  plan)
    TARGET_FILE="$DEFAULT_PLAN_FILE"
    TITLE="Plan"
    ROW_TITLE="Plan row"
    ;;
  issue)
    TARGET_FILE="issues.tsv"
    TITLE="Issue"
    ROW_TITLE="Issue row"
    ;;
esac

TARGET_PATH="$BASE_DIR/$TARGET_FILE"

# Make sure target file directory exists
mkdir -p "$(dirname "$TARGET_PATH")"

if [[ "$HEADER" == "OK" ]]; then
  # Semicolon separated row returned
  ROW="$REMAINDER"
  BACKUP_PATH="$(_choose_backup_path "$BASE_DIR" "$TARGET_FILE")"
  
  MODE="confirm"
  if [[ "$DRY_RUN" == "1" ]]; then
    MODE="dry-run"
  elif [[ "$YES" == "1" ]]; then
    MODE="yes"
  fi
  
  # Special header for issues
  if [[ "$CMD" == "issue" ]]; then
    # If issue file does not exist, initialize it
    if [[ ! -f "$TARGET_PATH" ]]; then
      echo -e "date\tstatus\ttitle\tamount\tmemo" > "$TARGET_PATH"
    fi
    
    if [[ "$DRY_RUN" == "1" ]]; then
      echo "Proposed row:"
      echo "$ROW"
      echo "(Dry-run mode, no changes saved)"
      exit 0
    fi
    
    echo "File: $TARGET_PATH"
    echo "Proposed row:"
    echo "$ROW"
    
    if [[ "$YES" == "0" ]]; then
      if ! confirm_append; then
        echo "Cancelled. No files were modified."
        exit 0
      fi
    fi
    
    safe_append "$TARGET_PATH" "$ROW" >/dev/null
    echo "OK: Issue row appended."
    exit 0
  fi
  
  # For journal/budget/plan
  print_append_preview "$TITLE" "$TARGET_PATH" "$MODE" "$POST_CHECK" "$BACKUP_PATH" "$ROW_TITLE" "$ROW"
  
  if [[ "$DRY_RUN" == "1" ]]; then
    echo "Dry-run only. No files were modified."
    exit 0
  fi
  
  if [[ "$YES" == "0" ]]; then
    if ! confirm_append; then
      echo "Cancelled. No files were modified."
      exit 0
    fi
  fi
  
  # Write row atomically
  safe_append "$TARGET_PATH" "$ROW"
  
  # Run post check
  run_post_check "$BASE_DIR" "$POST_CHECK" "$TARGET_PATH" "$BACKUP_PATH"
  exit 0
fi

if [[ "$HEADER" == "REVERSE" ]]; then
  # journal reverse output format:
  # REVERSE tab targetIdx tab originalDate tab originalMemo tab originalFrom tab originalTo tab originalAmount tab renderedReverse
  IFS=$'\t' read -r TARGET_IDX ORIG_DATE ORIG_MEMO ORIG_FROM ORIG_TO ORIG_AMOUNT ROW <<< "$REMAINDER"
  
  BACKUP_PATH="$(_choose_backup_path "$BASE_DIR" "$TARGET_FILE")"
  
  echo "Reversing journal row $TARGET_IDX (date=$ORIG_DATE, memo=$ORIG_MEMO)"
  echo "  Original: $ORIG_FROM -> $ORIG_TO  $ORIG_AMOUNT"
  echo "  Reversed: $ORIG_TO -> $ORIG_FROM  $ORIG_AMOUNT"
  
  MODE="confirm"
  if [[ "$YES" == "1" ]]; then
    MODE="yes"
  fi
  
  print_append_preview "Journal reverse" "$TARGET_PATH" "$MODE" "$POST_CHECK" "$BACKUP_PATH" "Reversed row" "$ROW"
  
  if [[ "$YES" == "0" ]]; then
    if ! confirm_append; then
      echo "Cancelled. No files were modified."
      exit 0
    fi
  fi
  
  safe_append "$TARGET_PATH" "$ROW"
  run_post_check "$BASE_DIR" "$POST_CHECK" "$TARGET_PATH" "$BACKUP_PATH"
  exit 0
fi

if [[ "$HEADER" == "CANDIDATE" ]]; then
  # plan finish candidate output format:
  # CANDIDATE tab renderedCandidate
  ROW="$REMAINDER"
  
  # If actual date is empty, we must prompt for it in Bash!
  if [[ -z "$ACTUAL_DATE" ]]; then
    TODAY="$(date +%Y-%m-%d)"
    while true; do
      read -p "Use today's payment date ($TODAY)? [Y/n]: " ans < /dev/tty || true
      ans="$(echo "$ans" | tr '[:upper:]' '[:lower:]')"
      case "$ans" in
        ""|y|yes)
          ACTUAL_DATE="$TODAY"
          break
          ;;
        n|no)
          while true; do
            read -p "Payment date (YYYY-MM-DD, today or earlier): " input < /dev/tty || true
            input="$(echo "$input" | xargs)"
            if [[ -z "$input" ]]; then
              echo "Payment date is required."
              continue
            fi
            
            # Validate input date
            valCheck=$(bqn -e 'validate ← •Import "'"$DIR"'/../src_edit/validate.bqn" ⋄ validate.ValidateDate "'"$input"'"')
            if [[ "$valCheck" == *"0 "* ]]; then
              echo "invalid date: $input"
              continue
            fi
            
            # payment date cannot be in the future
            if [[ "$input" > "$TODAY" ]]; then
              echo "payment date cannot be in the future: $input"
              continue
            fi
            
            ACTUAL_DATE="$input"
            break
          done
          break
          ;;
        *)
          echo "Please answer y or n."
          ;;
      esac
    done
    
    # Re-run BQN dispatcher with resolved actual date!
    BQN_ARGS[4]="$ACTUAL_DATE"
    BQN_OUT="$(bqn "$DIR/../src_edit/editor_cmd.bqn" "${BQN_ARGS[@]}" 2>&1)" || {
      echo "$BQN_OUT" >&2
      exit 1
    }
    IFS=$'\t' read -r HEADER REMAINDER <<< "$BQN_OUT"
    if [[ "$HEADER" == "ERROR" ]]; then
      echo "ERROR: $REMAINDER" >&2
      exit 2
    fi
    ROW="$REMAINDER"
  fi
  
  # Now append candidate to journal.tsv
  JOURNAL_PATH="$BASE_DIR/$DEFAULT_JOURNAL_FILE"
  BACKUP_PATH="$(_choose_backup_path "$BASE_DIR" "$DEFAULT_JOURNAL_FILE")"
  
  MODE="confirm"
  if [[ "$APPLY" == "1" ]]; then
    MODE="yes"
  fi
  
  print_append_preview "Journal (from plan)" "$JOURNAL_PATH" "$MODE" "lint" "$BACKUP_PATH" "Journal row" "$ROW"
  
  if [[ "$APPLY" == "0" ]]; then
    if ! confirm_append; then
      echo "Cancelled. No files were modified."
      exit 0
    fi
  fi
  
  safe_append "$JOURNAL_PATH" "$ROW"
  run_post_check "$BASE_DIR" "lint" "$JOURNAL_PATH" "$BACKUP_PATH"
  exit 0
fi

if [[ "$HEADER" == "REPLACE" ]]; then
  # plan edit output format:
  # REPLACE tab lineNum tab oldLine tab newLine tab planID
  IFS=$'\t' read -r LINENUM OLD_LINE NEW_LINE PLAN_ID <<< "$REMAINDER"
  
  PLAN_PATH="$BASE_DIR/$DEFAULT_PLAN_FILE"
  BACKUP_PATH="$(_choose_backup_path "$BASE_DIR" "$DEFAULT_PLAN_FILE")"
  
  MODE="confirm"
  if [[ "$DRY_RUN" == "1" ]]; then
    MODE="dry-run"
  elif [[ "$YES" == "1" ]]; then
    MODE="yes"
  fi
  
  # Print plan edit preview
  echo "Plan edit preview"
  echo "Target: $PLAN_PATH"
  echo "Line: $LINENUM"
  echo "Plan ID: $PLAN_ID"
  echo "Mode: $MODE"
  echo "Post-check: $POST_CHECK"
  echo "Backup: $BACKUP_PATH"
  echo "Diff:"
  echo "- $OLD_LINE"
  echo "+ $NEW_LINE"
  
  if [[ "$DRY_RUN" == "1" ]]; then
    echo "Dry-run only. No files were modified."
    exit 0
  fi
  
  if [[ "$YES" == "0" ]]; then
    read -p "Rewrite this plan row? [y/N]: " ans < /dev/tty || true
    ans="$(echo "$ans" | tr '[:upper:]' '[:lower:]')"
    if [[ "$ans" != "y" ]] && [[ "$ans" != "yes" ]]; then
      echo "Cancelled. No files were modified."
      exit 0
    fi
  fi
  
  # Rewrite file atomically
  # We read the raw file, verify the exact line, replace it, and write it back.
  # Sourced safe_rewrite function does this atomic replace.
  TMP_REWRITE="$(mktemp)"
  # shellcheck disable=SC2064
  trap "rm -f '$TMP_REWRITE'" EXIT
  
  # Perform line replacement in Bash
  awk -v target_ln="$LINENUM" -v new_l="$NEW_LINE" 'FNR == target_ln {print new_l; next} {print}' "$PLAN_PATH" > "$TMP_REWRITE"
  
  safe_rewrite "$PLAN_PATH" "$TMP_REWRITE" "$BACKUP_PATH"
  trap - EXIT
  
  run_post_check "$BASE_DIR" "$POST_CHECK" "$PLAN_PATH" "$BACKUP_PATH"
  exit 0
fi

# If it is plan list, we just print the BQN output directly!
echo "$BQN_OUT"
exit 0
