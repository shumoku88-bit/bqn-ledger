#!/usr/bin/env bqn

lib ÔåÉ ÔÇóImport "test_lib.bqn"
assembler ÔåÉ ÔÇóImport "daily_capacity_evidence_assembler_reference.bqn"

Observation ÔåÉ {­Øòè:
  { date ÔçÉ "2026-07-01", source ÔçÉ "synthetic_test" }
}

Horizon ÔåÉ {­Øòè state:
  {
    state ÔçÉ state,
    kind ÔçÉ "cycle",
    start ÔçÉ "2026-07-01",
    end_exclusive ÔçÉ "2026-07-11",
    source_ref ÔçÉ "synthetic:cycle"
  }
}

Proof ÔåÉ {­Øòè state:
  {
    state ÔçÉ state,
    domain ÔçÉ "JPY",
    amount_scale ÔçÉ 0,
    basis ÔçÉ "synthetic:proof",
    message ÔçÉ ""
  }
}

AssetCandidate ÔåÉ {­Øòè idÔÇ┐amount:
  {
    asset_id ÔçÉ id,
    source_kind ÔçÉ "account_balance",
    source_ref ÔçÉ "synthetic:asset:" Ôê¥ id,
    currency ÔçÉ "JPY",
    amount ÔçÉ amount
  }
}

AssetBasis ÔåÉ {­Øòè state:
  { state ÔçÉ state, basis_kind ÔçÉ "account_balance", scope_id ÔçÉ "synthetic:assets" }
}

AssetDecision ÔåÉ {­Øòè idÔÇ┐decision:
  { asset_id ÔçÉ id, decision ÔçÉ decision, decision_basis ÔçÉ "owner:asset-policy" }
}

ObligationCandidate ÔåÉ {­Øòè idÔÇ┐amount:
  {
    obligation_id ÔçÉ id,
    source_ref ÔçÉ "synthetic:obligation:" Ôê¥ id,
    due_on ÔçÉ "2026-07-05",
    currency ÔçÉ "JPY",
    amount ÔçÉ amount
  }
}

Settlement ÔåÉ {­Øòè idÔÇ┐state:
  { obligation_id ÔçÉ id, settlement_state ÔçÉ state, evidence_ref ÔçÉ "synthetic:settlement:" Ôê¥ id }
}

ObligationDecision ÔåÉ {­Øòè idÔÇ┐decision:
  { obligation_id ÔçÉ id, decision ÔçÉ decision, decision_basis ÔçÉ "owner:obligation-policy" }
}

Reservation ÔåÉ {­Øòè idÔÇ┐stateÔÇ┐excludedÔÇ┐ref:
  {
    obligation_id ÔçÉ id,
    reservation_state ÔçÉ state,
    excluded_from_asset_basis ÔçÉ excluded,
    reservation_ref ÔçÉ ref,
    evidence_ref ÔçÉ "synthetic:reservation:" Ôê¥ id
  }
}

baseAssets ÔåÉ Ôş¿AssetCandidate Ôş¿"checking", 10000Ôş®, AssetCandidate Ôş¿"emergency", 5000Ôş®Ôş®
baseAssetDecisions ÔåÉ Ôş¿AssetDecision Ôş¿"checking", "include"Ôş®, AssetDecision Ôş¿"emergency", "exclude"Ôş®Ôş®
baseObligations ÔåÉ Ôş¿ObligationCandidate Ôş¿"rent", 2000Ôş®, ObligationCandidate Ôş¿"optional", 700Ôş®Ôş®
baseSettlements ÔåÉ Ôş¿Settlement Ôş¿"rent", "open"Ôş®, Settlement Ôş¿"optional", "open"Ôş®Ôş®
baseObligationDecisions ÔåÉ Ôş¿ObligationDecision Ôş¿"rent", "include"Ôş®, ObligationDecision Ôş¿"optional", "exclude"Ôş®Ôş®
baseReservations ÔåÉ Ôş¿Reservation Ôş¿"rent", "none", 0, ""Ôş®, Reservation Ôş¿"optional", "none", 0, ""Ôş®Ôş®

Request ÔåÉ {­Øòè proofÔÇ┐assetCandidatesÔÇ┐assetBasisÔÇ┐assetDecisionsÔÇ┐obligationCandidatesÔÇ┐settlementsÔÇ┐obligationDecisionsÔÇ┐reservations:
  {
    observation_with_source ÔçÉ Observation @,
    resolved_horizon_evidence ÔçÉ Horizon "resolved",
    arithmetic_domain_proof ÔçÉ proof,
    asset_candidates ÔçÉ assetCandidates,
    asset_basis_decision ÔçÉ assetBasis,
    per_asset_decisions ÔçÉ assetDecisions,
    asset_policy_ref ÔçÉ "owner:asset-policy",
    obligation_candidates ÔçÉ obligationCandidates,
    settlement_evidence ÔçÉ settlements,
    per_obligation_decisions ÔçÉ obligationDecisions,
    obligation_policy_ref ÔçÉ { scope_id ÔçÉ "synthetic:obligations", policy_ref ÔçÉ "owner:obligation-policy" },
    reservation_evidence ÔçÉ reservations
  }
}

BaseRequest ÔåÉ {­Øòè:
  Request Ôş¿Proof "proven", baseAssets, AssetBasis "selected", baseAssetDecisions, baseObligations, baseSettlements, baseObligationDecisions, baseReservationsÔş®
}

Codes ÔåÉ { {­Øò®.code}┬¿ ­Øò®.diagnostics }
CheckDiagnostic ÔåÉ {­Øòè resultÔÇ┐stateÔÇ┐code:
  state lib.AssertEq result.state
  0 lib.AssertEq Ôëá result.input
  1 lib.AssertEq Ôê¿┬┤ 0 Ôê¥ (codeÔè©Ôëí┬¿ Codes result)
}

# 1. Complete facts plus explicit decisions produce the contract-shaped input.
r1 ÔåÉ assembler.AssembleDailyCapacityInputFromResolvedEvidence BaseRequest @
"resolved" lib.AssertEq r1.state
0 lib.AssertEq Ôëá r1.diagnostics
"JPY" lib.AssertEq r1.input.arithmetic_domain.currency
"include" lib.AssertEq (Ôèæ r1.input.asset_scope.rows).decision
"open" lib.AssertEq (Ôèæ r1.input.obligation_scope.rows).settlement_state
"none" lib.AssertEq (Ôèæ r1.input.obligation_scope.rows).reservation_state

# 2. An omitted asset decision is unavailable, never inferred from candidate facts.
r2 ÔåÉ assembler.AssembleDailyCapacityInputFromResolvedEvidence Request Ôş¿Proof "proven", baseAssets, AssetBasis "selected", Ôş¿AssetDecision Ôş¿"checking", "include"Ôş®Ôş®, baseObligations, baseSettlements, baseObligationDecisions, baseReservationsÔş®
CheckDiagnostic Ôş¿r2, "unavailable", "asset_decision_missing"Ôş®

# 3. An omitted obligation decision is unavailable, never inferred from settlement facts.
r3 ÔåÉ assembler.AssembleDailyCapacityInputFromResolvedEvidence Request Ôş¿Proof "proven", baseAssets, AssetBasis "selected", baseAssetDecisions, baseObligations, baseSettlements, Ôş¿ObligationDecision Ôş¿"rent", "include"Ôş®Ôş®, baseReservationsÔş®
CheckDiagnostic Ôş¿r3, "unavailable", "obligation_decision_missing"Ôş®

# 4. A decision for no candidate is a structural error.
r4 ÔåÉ assembler.AssembleDailyCapacityInputFromResolvedEvidence Request Ôş¿Proof "proven", baseAssets, AssetBasis "selected", baseAssetDecisions Ôê¥ Ôş¿AssetDecision Ôş¿"unknown", "include"Ôş®Ôş®, baseObligations, baseSettlements, baseObligationDecisions, baseReservationsÔş®
CheckDiagnostic Ôş¿r4, "error", "unknown_asset_decision_id"Ôş®

# 5. Duplicate decisions for one stable identity are an error.
r5 ÔåÉ assembler.AssembleDailyCapacityInputFromResolvedEvidence Request Ôş¿Proof "proven", baseAssets, AssetBasis "selected", baseAssetDecisions, baseObligations, baseSettlements, baseObligationDecisions Ôê¥ Ôş¿ObligationDecision Ôş¿"rent", "exclude"Ôş®Ôş®, baseReservationsÔş®
CheckDiagnostic Ôş¿r5, "error", "duplicate_obligation_decision_id"Ôş®

# 6. Basis absence is unavailable rather than a liquid-account fallback.
r6 ÔåÉ assembler.AssembleDailyCapacityInputFromResolvedEvidence Request Ôş¿Proof "proven", baseAssets, AssetBasis "unavailable", baseAssetDecisions, baseObligations, baseSettlements, baseObligationDecisions, baseReservationsÔş®
CheckDiagnostic Ôş¿r6, "unavailable", "asset_basis_unselected"Ôş®

# 7. A domain assertion must be proven before assembly.
r7 ÔåÉ assembler.AssembleDailyCapacityInputFromResolvedEvidence Request Ôş¿Proof "unsupported", baseAssets, AssetBasis "selected", baseAssetDecisions, baseObligations, baseSettlements, baseObligationDecisions, baseReservationsÔş®
CheckDiagnostic Ôş¿r7, "error", "arithmetic_domain_unproven"Ôş®

# 8. Ambiguous reservation evidence is unavailable and produces no input.
r8 ÔåÉ assembler.AssembleDailyCapacityInputFromResolvedEvidence Request Ôş¿Proof "proven", baseAssets, AssetBasis "selected", baseAssetDecisions, baseObligations, baseSettlements, baseObligationDecisions, Ôş¿Reservation Ôş¿"rent", "ambiguous", 0, ""Ôş®, Reservation Ôş¿"optional", "none", 0, ""Ôş®Ôş®Ôş®
CheckDiagnostic Ôş¿r8, "unavailable", "reservation_evidence_ambiguous"Ôş®

# 9. A reservation cannot point at an absent obligation.
r9 ÔåÉ assembler.AssembleDailyCapacityInputFromResolvedEvidence Request Ôş¿Proof "proven", baseAssets, AssetBasis "selected", baseAssetDecisions, baseObligations, baseSettlements, baseObligationDecisions, baseReservations Ôê¥ Ôş¿Reservation Ôş¿"unknown", "proven", 10, "reservation:unknown"Ôş®Ôş®Ôş®
CheckDiagnostic Ôş¿r9, "error", "unknown_reservation_obligation_id"Ôş®

# 10. One positive reservation identity cannot link two obligations.
r10 ÔåÉ assembler.AssembleDailyCapacityInputFromResolvedEvidence Request Ôş¿Proof "proven", baseAssets, AssetBasis "selected", baseAssetDecisions, baseObligations, baseSettlements, baseObligationDecisions, Ôş¿Reservation Ôş¿"rent", "proven", 100, "reservation:same"Ôş®, Reservation Ôş¿"optional", "proven", 100, "reservation:same"Ôş®Ôş®Ôş®
CheckDiagnostic Ôş¿r10, "error", "duplicate_reservation_linkage"Ôş®

# 11. Candidate order, not decision/evidence order, is the deterministic output order.
r11 ÔåÉ assembler.AssembleDailyCapacityInputFromResolvedEvidence Request Ôş¿Proof "proven", Ôî¢ baseAssets, AssetBasis "selected", Ôî¢ baseAssetDecisions, Ôî¢ baseObligations, Ôî¢ baseSettlements, Ôî¢ baseObligationDecisions, Ôî¢ baseReservationsÔş®
"resolved" lib.AssertEq r11.state
Ôş¿"emergency", "checking"Ôş® lib.AssertEq {­Øò®.asset_id}┬¿ r11.input.asset_scope.rows
Ôş¿"optional", "rent"Ôş® lib.AssertEq {­Øò®.obligation_id}┬¿ r11.input.obligation_scope.rows

# 12. Error precedence suppresses otherwise explanatory unavailable input.
r12 ÔåÉ assembler.AssembleDailyCapacityInputFromResolvedEvidence Request Ôş¿Proof "proven", baseAssets, AssetBasis "unavailable", baseAssetDecisions Ôê¥ Ôş¿AssetDecision Ôş¿"unknown", "include"Ôş®Ôş®, baseObligations, baseSettlements, baseObligationDecisions, baseReservationsÔş®
CheckDiagnostic Ôş¿r12, "error", "unknown_asset_decision_id"Ôş®

ÔÇóOut "test_daily_capacity_evidence_assembler_characterization.bqn: OK"
