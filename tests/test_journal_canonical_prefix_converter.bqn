#!/usr/bin/env bqn

lib ‚Üź ‚ÄĘImport "test_lib.bqn"
converter ‚Üź ‚ÄĘImport "../src_next/journal_canonical_prefix_converter.bqn"
ak ‚Üź ‚ÄĘImport "../src_next/account_key.bqn"
context ‚Üź ‚ÄĘImport "../src_next/context.bqn"
cube ‚Üź ‚ÄĘImport "../src_next/cube.bqn"
trial ‚Üź ‚ÄĘImport "../src_next/trial_balance.bqn"
balances ‚Üź ‚ÄĘImport "../src_next/balances.bqn"
parser ‚Üź ‚ÄĘImport "../src_next/journal_profile_stage1.bqn"

lf ‚Üź @+10 ‚čĄ tab ‚Üź @+9
JoinFields ‚Üź {ūĚēä fields: ‚ąĺ (((¬Į1‚Üďfields) ‚ąĺ¬® <tab) ‚ąĺ ¬Į1‚ÜĎfields)}
accounts ‚Üź ‚ü®
  "assets:orchard"‚ąĺtab‚ąĺ"role=asset"‚ąĺtab‚ąĺ"type=liquid",
  "expenses:market"‚ąĺtab‚ąĺ"role=expense"‚ąĺtab‚ąĺ"budget=daily",
  "expenses:studio"‚ąĺtab‚ąĺ"role=expense",
  "income:workshop"‚ąĺtab‚ąĺ"role=income"
‚ü©
resolved ‚Üź ak.Resolve accounts
cycleStart ‚Üź "2042-03-01"

metaAll ‚Üź ‚ü®
  "income_budget=exclude", "currency=JPY", "cashflow=fixed_obligation",
  "plan_id=plan-orchard-2042", "party=Public Cooperative",
  "txn_id=txn-shared-public", "receipt=receipt-public-7",
  "due_on=2042-03-20", "note=synthetic note", "invoice=ok",
  "biz=1", "tax=business"
‚ü©
row1 ‚Üź JoinFields (‚ü®"2042-03-03", "ťĚíÁ©ļ  ŚłāŚ†ī, morning!", "assets:orchard", "expenses:market", "1200"‚ü© ‚ąĺ metaAll)
row2 ‚Üź JoinFields ‚ü®"2042-03-04", "Shared linkage second", "assets:orchard", "expenses:studio", "300", "txn_id=txn-shared-public", "currency=JPY"‚ü©
row3 ‚Üź JoinFields ‚ü®"2042-03-05", "Workshop income", "income:workshop", "assets:orchard", "5000"‚ü©
snapshot ‚Üź "# invented comment"‚ąĺlf‚ąĺlf‚ąĺrow1‚ąĺlf‚ąĺ"\\ another invented comment"‚ąĺlf‚ąĺrow2‚ąĺlf‚ąĺrow3‚ąĺlf

converted ‚Üź converter.Convert ‚ü®snapshot,"journal.tsv",accounts,cycleStart‚ü©
"ok" lib.AssertEq converted.state
0 lib.AssertEq ‚Č†converted.diagnostics
3 lib.AssertEq converted.validation_summary.source_row_count
3 lib.AssertEq converted.validation_summary.transaction_count
6 lib.AssertEq converted.validation_summary.posting_count
1 lib.AssertEq converted.validation_summary.parser_pass
1 lib.AssertEq converted.validation_summary.account_resolver_pass
1 lib.AssertEq converted.validation_summary.stage2a_pass
1 lib.AssertEq converted.validation_summary.stage2b_pass
1 lib.AssertEq converted.validation_summary.accounting_parity_pass
1 lib.AssertEq converted.validation_summary.identity_parity_pass
1 lib.AssertEq converted.validation_summary.metadata_parity_pass

prefix ‚Üź converted.canonical_prefix_bytes
lf lib.AssertEq ¬Į1‚äĎprefix
lib.Assert ¬¨ ‚ą®¬ī (@+13) = prefix
lib.Assert 0 < +¬ī "commodity JPY" ‚ć∑ prefix
1 lib.AssertEq +¬ī "commodity JPY" ‚ć∑ prefix
3 lib.AssertEq +¬ī " * " ‚ć∑ prefix
lib.Assert 0 < +¬ī "2042-03-03 * ťĚíÁ©ļ  ŚłāŚ†ī, morning!" ‚ć∑ prefix
lib.Assert 0 < +¬ī "    ; event-id: legacy:journal.tsv:0" ‚ć∑ prefix
lib.Assert 0 < +¬ī "    ; event-id: legacy:journal.tsv:1" ‚ć∑ prefix
lib.Assert 0 < +¬ī "    ; event-id: legacy:journal.tsv:2" ‚ć∑ prefix
‚ü®"legacy:journal.tsv:0","legacy:journal.tsv:1","legacy:journal.tsv:2"‚ü© lib.AssertEq {ūĚē©.source_event_id}¬®converted.transactions
‚ü®"txn-shared-public","txn-shared-public",""‚ü© lib.AssertEq {ūĚē©.txn_id}¬®converted.transactions
‚ü®0,1,0,1,0,1‚ü© lib.AssertEq {ūĚē©.posting_index}¬®converted.provenance_rows
lib.Assert ‚ąß¬ī {ūĚē©.identity_kind‚Č°"durable"}¬®converted.provenance_rows
lib.Assert ‚ąß¬ī {ūĚē©.status‚Č°"ok"}¬®converted.posting_rows
lib.Assert ‚ąß¬ī {ūĚē©.layer_name‚Č°"actual"}¬®converted.posting_rows
lib.Assert ‚ąß¬ī {0=+¬ī{ūĚē©.delta}¬®ūĚē©.postings}¬®converted.transactions
expectedMetadataKeys ‚Üź ‚ü®"event-id","layer","tax","biz","invoice","note","due-on","receipt","txn-id","party","plan-id","cashflow","currency","income-budget"‚ü©
expectedMetadataKeys lib.AssertEq {ūĚē©.key}¬®(‚äĎconverted.transactions).metadata
parsedDeclarations ‚Üź parser.ParseWithProfile ‚ü®prefix,"historical_external_plan"‚ü©
‚ü®"asset","expense","expense","income"‚ü© lib.AssertEq {ūĚē©.role}¬®parsedDeclarations.accounts
‚ü®"daily"‚ü© lib.AssertEq ({ūĚē©.account_key‚Č°"expenses:market"}¬®parsedDeclarations.accounts)/{ūĚē©.default_envelope}¬®parsedDeclarations.accounts
duplicateIdentityDiagnostics ‚Üź converter.SourceIdentityDiagnostics ‚ü®‚ü®{source_row‚áź4},{source_row‚áź4}‚ü©,"journal.tsv"‚ü©
1 lib.AssertEq ‚Č†duplicateIdentityDiagnostics
"source_identity_duplicate" lib.AssertEq (‚äĎduplicateIdentityDiagnostics).code

# Fixed metadata order is independent of TSV metadata input order.
row1Reordered ‚Üź JoinFields (‚ü®"2042-03-03", "ťĚíÁ©ļ  ŚłāŚ†ī, morning!", "assets:orchard", "expenses:market", "1200"‚ü© ‚ąĺ ‚ĆĹmetaAll)
reorderedSnapshot ‚Üź "# invented comment"‚ąĺlf‚ąĺlf‚ąĺrow1Reordered‚ąĺlf‚ąĺ"\\ another invented comment"‚ąĺlf‚ąĺrow2‚ąĺlf‚ąĺrow3‚ąĺlf
reordered ‚Üź converter.Convert ‚ü®reorderedSnapshot,"journal.tsv",accounts,cycleStart‚ü©
"ok" lib.AssertEq reordered.state
prefix lib.AssertEq reordered.canonical_prefix_bytes
prefix lib.AssertEq (converter.Convert ‚ü®snapshot,"journal.tsv",accounts,cycleStart‚ü©).canonical_prefix_bytes

# Existing strict behavior remains strict while converter validation uses the
# explicit historical profile for the synthetic external plan reference.
"error" lib.AssertEq (parser.Parse prefix).state
"ok" lib.AssertEq (parser.ParseWithProfile ‚ü®prefix,"historical_external_plan"‚ü©).state

# Cube, TBDS, Trial Balance, and Balances parity over independent route rows.
cy ‚Üź {start‚áź"2042-03-01",end_exclusive‚áź"2042-04-01",day_count‚áź31,mode‚áź"fixed"}
legacyView ‚Üź context.BuildPeriodView ‚ü®converted.legacy_posting_rows,resolved,cy‚ü©
journalView ‚Üź context.BuildPeriodView ‚ü®converted.posting_rows,resolved,cy‚ü©
legacyView.cube.cube lib.AssertEq journalView.cube.cube
TbdsFields ‚Üź {ūĚēä row: ‚ü®<row.account_key,row.layer_index,row.opening,row.debit_movement,row.credit_movement,row.movement,row.closing‚ü©}
(TbdsFields¬®legacyView.tbds) lib.AssertEq TbdsFields¬®journalView.tbds
legacyCtx ‚Üź {cy‚áźcy,resolved‚áźresolved,tbds‚áźlegacyView.tbds}
journalCtx ‚Üź {cy‚áźcy,resolved‚áźresolved,tbds‚áźjournalView.tbds}
legacyTrial ‚Üź trial.Build ‚ü®legacyCtx,cube.layer_actual‚ü©
journalTrial ‚Üź trial.Build ‚ü®journalCtx,cube.layer_actual‚ü©
‚ü®<legacyTrial.accounts,<legacyTrial.openings,<legacyTrial.debits,<legacyTrial.credits,<legacyTrial.closings‚ü© lib.AssertEq ‚ü®<journalTrial.accounts,<journalTrial.openings,<journalTrial.debits,<journalTrial.credits,<journalTrial.closings‚ü©
(balances.Build legacyCtx) lib.AssertEq balances.Build journalCtx

HasCode ‚Üź {ūĚēä code‚ÄŅresult: ‚ą®¬ī0‚ąĺ{ūĚē©.code‚Č°code}¬®result.diagnostics}
AssertFailure ‚Üź {ūĚēä badSnapshot‚ÄŅcode:
  failed ‚Üź converter.Convert ‚ü®badSnapshot,"journal.tsv",accounts,cycleStart‚ü©
  "error" lib.AssertEq failed.state
  "" lib.AssertEq failed.canonical_prefix_bytes
  0 lib.AssertEq ‚Č†failed.posting_rows
  lib.Assert HasCode ‚ü®code,failed‚ü©
}
MakeOne ‚Üź {ūĚēä date‚ÄŅdescription‚ÄŅfrom‚ÄŅto‚ÄŅamount‚ÄŅmetas:
  (JoinFields ‚ü®date,description,from,to,amount‚ü©‚ąĺmetas)‚ąĺlf
}
AssertFailure ‚ü®"broken"‚ąĺlf,"tsv_required_fields_missing"‚ü©
AssertFailure ‚ü®MakeOne ‚ü®"2042-02-30","Bad date","assets:orchard","expenses:market","1",‚ü®‚ü©‚ü©,"date_invalid"‚ü©
AssertFailure ‚ü®MakeOne ‚ü®"2042-03-01","Bad amount","assets:orchard","expenses:market","1.5",‚ü®‚ü©‚ü©,"amount_not_exact_integer_jpy"‚ü©
AssertFailure ‚ü®MakeOne ‚ü®"2042-03-01","Unknown account","assets:missing","expenses:market","1",‚ü®‚ü©‚ü©,"account_unresolved"‚ü©
incompatibleAccounts ‚Üź ‚ü®"assets:orchard"‚ąĺtab‚ąĺ"role=asset"‚ąĺtab‚ąĺ"currency=ILS","expenses:market"‚ąĺtab‚ąĺ"role=expense"‚ü©
incompatible ‚Üź converter.Convert ‚ü®MakeOne ‚ü®"2042-03-01","Incompatible account currency","assets:orchard","expenses:market","1",‚ü®‚ü©‚ü©,"journal.tsv",incompatibleAccounts,cycleStart‚ü©
"error" lib.AssertEq incompatible.state
lib.Assert HasCode ‚ü®"account_currency_incompatible",incompatible‚ü©
duplicateAccountMetadata ‚Üź ‚ü®"assets:orchard"‚ąĺtab‚ąĺ"role=asset"‚ąĺtab‚ąĺ"role=expense","expenses:market"‚ąĺtab‚ąĺ"role=expense"‚ü©
duplicateRegistry ‚Üź converter.Convert ‚ü®MakeOne ‚ü®"2042-03-01","Duplicate account metadata","assets:orchard","expenses:market","1",‚ü®‚ü©‚ü©,"journal.tsv",duplicateAccountMetadata,cycleStart‚ü©
"error" lib.AssertEq duplicateRegistry.state
lib.Assert HasCode ‚ü®"account_metadata_duplicate",duplicateRegistry‚ü©
AssertFailure ‚ü®MakeOne ‚ü®"2042-03-01","","assets:orchard","expenses:market","1",‚ü®‚ü©‚ü©,"description_not_canonically_representable"‚ü©
AssertFailure ‚ü®MakeOne ‚ü®"2042-03-01"," leading","assets:orchard","expenses:market","1",‚ü®‚ü©‚ü©,"description_not_canonically_representable"‚ü©
AssertFailure ‚ü®MakeOne ‚ü®"2042-03-01","trailing ","assets:orchard","expenses:market","1",‚ü®‚ü©‚ü©,"description_not_canonically_representable"‚ü©
lib.Assert ¬¨converter.DescriptionRepresentable "tab"‚ąĺtab‚ąĺ"inside"
lib.Assert ¬¨converter.DescriptionRepresentable "line"‚ąĺlf‚ąĺ"inside"
lib.Assert ¬¨converter.DescriptionRepresentable "carriage"‚ąĺ(@+13)‚ąĺ"inside"
AssertFailure ‚ü®MakeOne ‚ü®"2042-03-01","carriage"‚ąĺ(@+13)‚ąĺ"inside","assets:orchard","expenses:market","1",‚ü®‚ü©‚ü©,"description_not_canonically_representable"‚ü©
lib.Assert ¬¨converter.DescriptionRepresentable "nul"‚ąĺ(@+0)‚ąĺ"inside"
lib.Assert ¬¨converter.DescriptionRepresentable "del"‚ąĺ(@+127)‚ąĺ"inside"
AssertFailure ‚ü®MakeOne ‚ü®"2042-03-01","Unknown metadata","assets:orchard","expenses:market","1",‚ü®"mystery=value"‚ü©‚ü©,"metadata_unknown"‚ü©
AssertFailure ‚ü®MakeOne ‚ü®"2042-03-01","Duplicate metadata","assets:orchard","expenses:market","1",‚ü®"tax=private","tax=business"‚ü©‚ü©,"metadata_duplicate"‚ü©
AssertFailure ‚ü®MakeOne ‚ü®"2042-03-01","Empty metadata","assets:orchard","expenses:market","1",‚ü®"note="‚ü©‚ü©,"metadata_value_invalid"‚ü©
AssertFailure ‚ü®MakeOne ‚ü®"2042-03-01","Controlled metadata","assets:orchard","expenses:market","1",‚ü®"biz=yes"‚ü©‚ü©,"metadata_value_invalid"‚ü©
AssertFailure ‚ü®MakeOne ‚ü®"2042-03-01","Foreign currency","assets:orchard","expenses:market","1",‚ü®"currency=ILS"‚ü©‚ü©,"metadata_value_invalid"‚ü©

# A native three-posting suffix is copied, not rendered. It starts with one LF,
# creating the required blank line without changing either operand.
suffix ‚Üź lf ‚ąĺ "2042-03-06 * Native split suffix" ‚ąĺ lf ‚ąĺ "    ; event-id: native-suffix-public-001" ‚ąĺ lf ‚ąĺ "    ; layer: actual" ‚ąĺ lf ‚ąĺ "    expenses:market 40 JPY" ‚ąĺ lf ‚ąĺ "    expenses:studio 60 JPY" ‚ąĺ lf ‚ąĺ "    assets:orchard -100 JPY" ‚ąĺ lf
reconstructed ‚Üź converter.Reconstruct ‚ü®converted,suffix,resolved,cycleStart‚ü©
"ok" lib.AssertEq reconstructed.state
(prefix‚ąĺsuffix) lib.AssertEq reconstructed.reconstructed_candidate_bytes
1 lib.AssertEq +¬ī suffix ‚ć∑ reconstructed.reconstructed_candidate_bytes
4 lib.AssertEq reconstructed.validation_summary.transaction_count
9 lib.AssertEq reconstructed.validation_summary.posting_count
suffix lib.AssertEq (‚Č†prefix)‚Üďreconstructed.reconstructed_candidate_bytes
mixedAccounts ‚Üź accounts ‚ąĺ ‚ü®"assets:foreign"‚ąĺtab‚ąĺ"role=asset"‚ąĺtab‚ąĺ"currency=ILS"‚ü©
mixedConverted ‚Üź converter.Convert ‚ü®snapshot,"journal.tsv",mixedAccounts,cycleStart‚ü©
"ok" lib.AssertEq mixedConverted.state
foreignSuffix ‚Üź lf ‚ąĺ "2042-03-06 * Native foreign suffix" ‚ąĺ lf ‚ąĺ "    ; event-id: native-suffix-public-foreign" ‚ąĺ lf ‚ąĺ "    ; layer: actual" ‚ąĺ lf ‚ąĺ "    expenses:market 40 JPY" ‚ąĺ lf ‚ąĺ "    assets:foreign 60 JPY" ‚ąĺ lf ‚ąĺ "    assets:orchard -100 JPY" ‚ąĺ lf
foreignReconstruction ‚Üź converter.Reconstruct ‚ü®mixedConverted,foreignSuffix,ak.Resolve mixedAccounts,cycleStart‚ü©
"error" lib.AssertEq foreignReconstruction.state
"" lib.AssertEq foreignReconstruction.reconstructed_candidate_bytes
lib.Assert HasCode ‚ü®"account_currency_incompatible",foreignReconstruction‚ü©

badVerified ‚Üź {state‚áź"error",canonical_prefix_bytes‚áź""}
failedReconstruction ‚Üź converter.Reconstruct ‚ü®badVerified,suffix,resolved,cycleStart‚ü©
"error" lib.AssertEq failedReconstruction.state
"" lib.AssertEq failedReconstruction.reconstructed_candidate_bytes
lib.Assert HasCode ‚ü®"verified_prefix_required",failedReconstruction‚ü©
duplicateSuffix ‚Üź converter.Reconstruct ‚ü®converted,suffix‚ąĺsuffix,resolved,cycleStart‚ü©
"error" lib.AssertEq duplicateSuffix.state
"" lib.AssertEq duplicateSuffix.reconstructed_candidate_bytes

‚ÄĘOut "test_journal_canonical_prefix_converter.bqn: OK"
