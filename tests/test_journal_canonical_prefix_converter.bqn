#!/usr/bin/env bqn

lib ÔćÉ ÔÇóImport "test_lib.bqn"
converter ÔćÉ ÔÇóImport "../src_next/journal_canonical_prefix_converter.bqn"
ak ÔćÉ ÔÇóImport "../src_next/account_key.bqn"
context ÔćÉ ÔÇóImport "../src_next/context.bqn"
cube ÔćÉ ÔÇóImport "../src_next/cube.bqn"
trial ÔćÉ ÔÇóImport "../src_next/trial_balance.bqn"
balances ÔćÉ ÔÇóImport "../src_next/balances.bqn"
parser ÔćÉ ÔÇóImport "../src_next/journal_profile_stage1.bqn"

lf ÔćÉ @+10 Ôőä tab ÔćÉ @+9
JoinFields ÔćÉ {­ŁĽŐ fields: Ôłż (((┬»1Ôćôfields) Ôłż┬Ę <tab) Ôłż ┬»1ÔćĹfields)}
accounts ÔćÉ ÔčĘ
  "assets:orchard"ÔłżtabÔłż"role=asset"ÔłżtabÔłż"type=liquid"ÔłżtabÔłż"kind=liquid",
  "expenses:market"ÔłżtabÔłż"role=expense"ÔłżtabÔłż"budget=daily",
  "expenses:studio"ÔłżtabÔłż"role=expense",
  "income:workshop"ÔłżtabÔłż"role=income"
Ôčę
resolved ÔćÉ ak.Resolve accounts
cycleStart ÔćÉ "2042-03-01"

metaAll ÔćÉ ÔčĘ
  "income_budget=exclude", "currency=JPY", "cashflow=fixed_obligation",
  "plan_id=plan-orchard-2042", "party=Public Cooperative",
  "txn_id=txn-shared-public", "receipt=receipt-public-7",
  "due_on=2042-03-20", "note=synthetic note", "invoice=ok",
  "biz=1", "tax=business"
Ôčę
row1 ÔćÉ JoinFields (ÔčĘ"2042-03-03", "ÚŁĺšę║  ňŞéňá┤, morning!", "assets:orchard", "expenses:market", "1200"Ôčę Ôłż metaAll)
row2 ÔćÉ JoinFields ÔčĘ"2042-03-04", "Shared linkage second", "assets:orchard", "expenses:studio", "300", "txn_id=txn-shared-public", "currency=JPY"Ôčę
row3 ÔćÉ JoinFields ÔčĘ"2042-03-05", "Workshop income", "income:workshop", "assets:orchard", "5000"Ôčę
snapshot ÔćÉ "# invented comment"ÔłżlfÔłżlfÔłżrow1ÔłżlfÔłż"\\ another invented comment"ÔłżlfÔłżrow2ÔłżlfÔłżrow3Ôłżlf

converted ÔćÉ converter.Convert ÔčĘsnapshot,"journal.tsv",accounts,cycleStartÔčę
"ok" lib.AssertEq converted.state
0 lib.AssertEq Ôëáconverted.diagnostics
3 lib.AssertEq converted.validation_summary.source_row_count
3 lib.AssertEq converted.validation_summary.transaction_count
6 lib.AssertEq converted.validation_summary.posting_count
1 lib.AssertEq converted.validation_summary.parser_pass
1 lib.AssertEq converted.validation_summary.account_resolver_pass
1 lib.AssertEq converted.validation_summary.stage2a_pass
1 lib.AssertEq converted.validation_summary.stage2b_pass
1 lib.AssertEq converted.validation_summary.accounting_parity_pass
1 lib.AssertEq converted.validation_summary.identity_parity_pass
1 lib.AssertEq converted.validation_summary.metadata_parity_pass

prefix ÔćÉ converted.canonical_prefix_bytes
lf lib.AssertEq ┬»1ÔŐĹprefix
lib.Assert ┬Č ÔłĘ┬┤ (@+13) = prefix
lib.Assert 0 < +┬┤ "commodity JPY" ÔŹĚ prefix
1 lib.AssertEq +┬┤ "commodity JPY" ÔŹĚ prefix
3 lib.AssertEq +┬┤ " * " ÔŹĚ prefix
lib.Assert 0 < +┬┤ "2042-03-03 * ÚŁĺšę║  ňŞéňá┤, morning!" ÔŹĚ prefix
lib.Assert 0 < +┬┤ "    ; event-id: legacy:journal.tsv:0" ÔŹĚ prefix
lib.Assert 0 < +┬┤ "    ; event-id: legacy:journal.tsv:1" ÔŹĚ prefix
lib.Assert 0 < +┬┤ "    ; event-id: legacy:journal.tsv:2" ÔŹĚ prefix
ÔčĘ"legacy:journal.tsv:0","legacy:journal.tsv:1","legacy:journal.tsv:2"Ôčę lib.AssertEq {­ŁĽę.source_event_id}┬Ęconverted.transactions
ÔčĘ"txn-shared-public","txn-shared-public",""Ôčę lib.AssertEq {­ŁĽę.txn_id}┬Ęconverted.transactions
ÔčĘ0,1,0,1,0,1Ôčę lib.AssertEq {­ŁĽę.posting_index}┬Ęconverted.provenance_rows
lib.Assert Ôłž┬┤ {­ŁĽę.identity_kindÔëí"durable"}┬Ęconverted.provenance_rows
lib.Assert Ôłž┬┤ {­ŁĽę.statusÔëí"ok"}┬Ęconverted.posting_rows
lib.Assert Ôłž┬┤ {­ŁĽę.layer_nameÔëí"actual"}┬Ęconverted.posting_rows
lib.Assert Ôłž┬┤ {0=+┬┤{­ŁĽę.delta}┬Ę­ŁĽę.postings}┬Ęconverted.transactions
expectedMetadataKeys ÔćÉ ÔčĘ"event-id","layer","tax","biz","invoice","note","due-on","receipt","txn-id","party","plan-id","cashflow","currency","income-budget"Ôčę
expectedMetadataValues ÔćÉ ÔčĘ
  "legacy:journal.tsv:0","actual","business","1","ok","synthetic note","2042-03-20",
  "receipt-public-7","txn-shared-public","Public Cooperative","plan-orchard-2042",
  "fixed_obligation","JPY","exclude"
Ôčę
expectedMetadataKeys lib.AssertEq {­ŁĽę.key}┬Ę(ÔŐĹconverted.transactions).metadata
expectedMetadataValues lib.AssertEq {­ŁĽę.value}┬Ę(ÔŐĹconverted.transactions).metadata
ÔčĘ"event-id","layer"Ôčę lib.AssertEq {­ŁĽę.key}┬Ę(2ÔŐĹconverted.transactions).metadata
ÔčĘ"legacy:journal.tsv:2","actual"Ôčę lib.AssertEq {­ŁĽę.value}┬Ę(2ÔŐĹconverted.transactions).metadata

# The exact metadata parity seam rejects changed values, keys, and extras.
actualMetadata ÔćÉ (ÔŐĹconverted.transactions).metadata
valueMismatch ÔćÉ ÔčĘÔŐĹactualMetadata,{keyÔçÉ"layer",valueÔçÉ"plan",source_lineÔçÉ0}Ôčę Ôłż 2ÔćôactualMetadata
lib.Assert ┬Čconverter.MetadataEntriesEqual ÔčĘactualMetadata,valueMismatchÔčę
keyMismatch ÔćÉ ÔčĘÔŐĹactualMetadata,{keyÔçÉ"action",valueÔçÉ"actual",source_lineÔçÉ0}Ôčę Ôłż 2ÔćôactualMetadata
lib.Assert ┬Čconverter.MetadataEntriesEqual ÔčĘactualMetadata,keyMismatchÔčę
unexpectedMetadata ÔćÉ actualMetadata Ôłż ÔčĘ{keyÔçÉ"action",valueÔçÉ"extra",source_lineÔçÉ0}Ôčę
lib.Assert ┬Čconverter.MetadataEntriesEqual ÔčĘactualMetadata,unexpectedMetadataÔčę

parsedDeclarations ÔćÉ parser.ParseWithProfile ÔčĘprefix,"historical_external_plan"Ôčę
ÔčĘ"asset","expense","expense","income"Ôčę lib.AssertEq {­ŁĽę.role}┬ĘparsedDeclarations.accounts
ÔčĘ"liquid","","",""Ôčę lib.AssertEq {­ŁĽę.kind}┬ĘparsedDeclarations.accounts
ÔčĘ"daily"Ôčę lib.AssertEq ({­ŁĽę.account_keyÔëí"expenses:market"}┬ĘparsedDeclarations.accounts)/{­ŁĽę.default_envelope}┬ĘparsedDeclarations.accounts
"ok" lib.AssertEq (converter.DeclarationParity ÔčĘparsedDeclarations,resolvedÔčę).state

# Declaration parity is exact and independently detects each represented field.
Decl ÔćÉ {­ŁĽŐ keyÔÇ┐roleÔÇ┐kindÔÇ┐envelope: {account_keyÔçÉkey,roleÔçÉrole,kindÔçÉkind,default_envelopeÔçÉenvelope}}
expectedDecls ÔćÉ ÔčĘ
  Decl ÔčĘ"assets:orchard","asset","liquid",""Ôčę,
  Decl ÔčĘ"expenses:market","expense","","daily"Ôčę,
  Decl ÔčĘ"expenses:studio","expense","",""Ôčę,
  Decl ÔčĘ"income:workshop","income","",""Ôčę
Ôčę
Commodity ÔćÉ {­ŁĽŐ value: {commodityÔçÉvalue}}
AssertDeclarationFailure ÔćÉ {­ŁĽŐ declsÔÇ┐commoditiesÔÇ┐code:
  parity ÔćÉ converter.DeclarationParity ÔčĘ{accountsÔçÉdecls,commoditiesÔçÉcommodities},resolvedÔčę
  "error" lib.AssertEq parity.state
  lib.Assert ÔłĘ┬┤0Ôłż{­ŁĽę.codeÔëícode}┬Ęparity.diagnostics
}
roleMismatch ÔćÉ ÔčĘDecl ÔčĘ"assets:orchard","expense","liquid",""ÔčęÔčę Ôłż 1ÔćôexpectedDecls
AssertDeclarationFailure ÔčĘroleMismatch,ÔčĘCommodity "JPY"Ôčę,"account_declaration_parity_failed"Ôčę
kindMismatch ÔćÉ ÔčĘDecl ÔčĘ"assets:orchard","asset","other",""ÔčęÔčę Ôłż 1ÔćôexpectedDecls
AssertDeclarationFailure ÔčĘkindMismatch,ÔčĘCommodity "JPY"Ôčę,"account_declaration_parity_failed"Ôčę
envelopeMismatch ÔćÉ ÔčĘÔŐĹexpectedDecls,Decl ÔčĘ"expenses:market","expense","","other"ÔčęÔčę Ôłż 2ÔćôexpectedDecls
AssertDeclarationFailure ÔčĘenvelopeMismatch,ÔčĘCommodity "JPY"Ôčę,"account_declaration_parity_failed"Ôčę
AssertDeclarationFailure ÔčĘÔîŻexpectedDecls,ÔčĘCommodity "JPY"Ôčę,"account_declaration_parity_failed"Ôčę
AssertDeclarationFailure ÔčĘexpectedDecls,ÔčĘCommodity "JPY",Commodity "JPY"Ôčę,"commodity_declaration_parity_failed"Ôčę
duplicateIdentityDiagnostics ÔćÉ converter.SourceIdentityDiagnostics ÔčĘÔčĘ{source_rowÔçÉ4},{source_rowÔçÉ4}Ôčę,"journal.tsv"Ôčę
1 lib.AssertEq ÔëáduplicateIdentityDiagnostics
"source_identity_duplicate" lib.AssertEq (ÔŐĹduplicateIdentityDiagnostics).code

# Fixed metadata order is independent of TSV metadata input order.
row1Reordered ÔćÉ JoinFields (ÔčĘ"2042-03-03", "ÚŁĺšę║  ňŞéňá┤, morning!", "assets:orchard", "expenses:market", "1200"Ôčę Ôłż ÔîŻmetaAll)
reorderedSnapshot ÔćÉ "# invented comment"ÔłżlfÔłżlfÔłżrow1ReorderedÔłżlfÔłż"\\ another invented comment"ÔłżlfÔłżrow2ÔłżlfÔłżrow3Ôłżlf
reordered ÔćÉ converter.Convert ÔčĘreorderedSnapshot,"journal.tsv",accounts,cycleStartÔčę
"ok" lib.AssertEq reordered.state
prefix lib.AssertEq reordered.canonical_prefix_bytes
prefix lib.AssertEq (converter.Convert ÔčĘsnapshot,"journal.tsv",accounts,cycleStartÔčę).canonical_prefix_bytes
prefix lib.AssertEq (converter.Convert ÔčĘsnapshot,"journal.tsv",ÔîŻaccounts,cycleStartÔčę).canonical_prefix_bytes

# Existing strict behavior remains strict while converter validation uses the
# explicit historical profile for the synthetic external plan reference.
"error" lib.AssertEq (parser.Parse prefix).state
"ok" lib.AssertEq (parser.ParseWithProfile ÔčĘprefix,"historical_external_plan"Ôčę).state

# Cube, TBDS, Trial Balance, and Balances parity over independent route rows.
cy ÔćÉ {startÔçÉ"2042-03-01",end_exclusiveÔçÉ"2042-04-01",day_countÔçÉ31,modeÔçÉ"fixed"}
legacyView ÔćÉ context.BuildPeriodView ÔčĘconverted.legacy_posting_rows,resolved,cyÔčę
journalView ÔćÉ context.BuildPeriodView ÔčĘconverted.posting_rows,resolved,cyÔčę
legacyView.cube.cube lib.AssertEq journalView.cube.cube
TbdsFields ÔćÉ {­ŁĽŐ row: ÔčĘ<row.account_key,row.layer_index,row.opening,row.debit_movement,row.credit_movement,row.movement,row.closingÔčę}
(TbdsFields┬ĘlegacyView.tbds) lib.AssertEq TbdsFields┬ĘjournalView.tbds
legacyCtx ÔćÉ {cyÔçÉcy,resolvedÔçÉresolved,tbdsÔçÉlegacyView.tbds}
journalCtx ÔćÉ {cyÔçÉcy,resolvedÔçÉresolved,tbdsÔçÉjournalView.tbds}
legacyTrial ÔćÉ trial.Build ÔčĘlegacyCtx,cube.layer_actualÔčę
journalTrial ÔćÉ trial.Build ÔčĘjournalCtx,cube.layer_actualÔčę
ÔčĘ<legacyTrial.accounts,<legacyTrial.openings,<legacyTrial.debits,<legacyTrial.credits,<legacyTrial.closingsÔčę lib.AssertEq ÔčĘ<journalTrial.accounts,<journalTrial.openings,<journalTrial.debits,<journalTrial.credits,<journalTrial.closingsÔčę
(balances.Build legacyCtx) lib.AssertEq balances.Build journalCtx

HasCode ÔćÉ {­ŁĽŐ codeÔÇ┐result: ÔłĘ┬┤0Ôłż{­ŁĽę.codeÔëícode}┬Ęresult.diagnostics}
AssertFailure ÔćÉ {­ŁĽŐ badSnapshotÔÇ┐code:
  failed ÔćÉ converter.Convert ÔčĘbadSnapshot,"journal.tsv",accounts,cycleStartÔčę
  "error" lib.AssertEq failed.state
  "" lib.AssertEq failed.canonical_prefix_bytes
  0 lib.AssertEq Ôëáfailed.posting_rows
  lib.Assert HasCode ÔčĘcode,failedÔčę
}
MakeOne ÔćÉ {­ŁĽŐ dateÔÇ┐descriptionÔÇ┐fromÔÇ┐toÔÇ┐amountÔÇ┐metas:
  (JoinFields ÔčĘdate,description,from,to,amountÔčęÔłżmetas)Ôłżlf
}
AssertFailure ÔčĘ"broken"Ôłżlf,"tsv_required_fields_missing"Ôčę
"ok" lib.AssertEq (converter.Convert ÔčĘsnapshot,"journal.tsv",accounts,cycleStartÔčę).state
{­ŁĽŐ identity:
  failedIdentity ÔćÉ converter.Convert ÔčĘsnapshot,identity,accounts,cycleStartÔčę
  "error" lib.AssertEq failedIdentity.state
  lib.Assert HasCode ÔčĘ"source_file_identity_invalid",failedIdentityÔčę
}┬Ę ÔčĘ"directory/file","C:\path","\\server\share"Ôčę
AssertFailure ÔčĘMakeOne ÔčĘ"2042-02-30","Bad date","assets:orchard","expenses:market","1",ÔčĘÔčęÔčę,"date_invalid"Ôčę
AssertFailure ÔčĘMakeOne ÔčĘ"2042-03-01","Bad amount","assets:orchard","expenses:market","1.5",ÔčĘÔčęÔčę,"amount_not_exact_integer_jpy"Ôčę
AssertFailure ÔčĘMakeOne ÔčĘ"2042-03-01","Unknown account","assets:missing","expenses:market","1",ÔčĘÔčęÔčę,"account_unresolved"Ôčę
incompatibleAccounts ÔćÉ ÔčĘ"assets:orchard"ÔłżtabÔłż"role=asset"ÔłżtabÔłż"currency=ILS","expenses:market"ÔłżtabÔłż"role=expense"Ôčę
incompatible ÔćÉ converter.Convert ÔčĘMakeOne ÔčĘ"2042-03-01","Incompatible account currency","assets:orchard","expenses:market","1",ÔčĘÔčęÔčę,"journal.tsv",incompatibleAccounts,cycleStartÔčę
"error" lib.AssertEq incompatible.state
lib.Assert HasCode ÔčĘ"account_currency_incompatible",incompatibleÔčę
duplicateAccountMetadata ÔćÉ ÔčĘ"assets:orchard"ÔłżtabÔłż"role=asset"ÔłżtabÔłż"role=expense","expenses:market"ÔłżtabÔłż"role=expense"Ôčę
duplicateRegistry ÔćÉ converter.Convert ÔčĘMakeOne ÔčĘ"2042-03-01","Duplicate account metadata","assets:orchard","expenses:market","1",ÔčĘÔčęÔčę,"journal.tsv",duplicateAccountMetadata,cycleStartÔčę
"error" lib.AssertEq duplicateRegistry.state
lib.Assert HasCode ÔčĘ"account_metadata_duplicate",duplicateRegistryÔčę
# Description admission is intentionally distinct from SafeValue: leading ASCII
# SPACE is source-owned and must survive converter rendering and Stage 1 exactly.
AssertLeadingAdmission ÔćÉ {­ŁĽŐ descriptionÔÇ┐dateText:
  leadingSnapshot ÔćÉ MakeOne ÔčĘdateText,description,"assets:orchard","expenses:market","1",ÔčĘÔčęÔčę
  leading ÔćÉ converter.Convert ÔčĘleadingSnapshot,"journal.tsv",accounts,cycleStartÔčę
  "ok" lib.AssertEq leading.state
  0 lib.AssertEq Ôëáleading.diagnostics
  lib.Assert 0 < +┬┤ (dateTextÔłż" * "ÔłżdescriptionÔłżlf) ÔŹĚ leading.canonical_prefix_bytes
  leadingParsed ÔćÉ parser.ParseWithProfile ÔčĘleading.canonical_prefix_bytes,"historical_external_plan"Ôčę
  "ok" lib.AssertEq leadingParsed.state
  0 lib.AssertEq ÔëáleadingParsed.diagnostics
  description lib.AssertEq (ÔŐĹleadingParsed.transactions).description
  description lib.AssertEq (ÔŐĹleading.transactions).description
  1 lib.AssertEq leading.validation_summary.parser_pass
  1 lib.AssertEq leading.validation_summary.stage2a_pass
  1 lib.AssertEq leading.validation_summary.stage2b_pass
  1 lib.AssertEq leading.validation_summary.accounting_parity_pass
  1 lib.AssertEq leading.validation_summary.identity_parity_pass
  1 lib.AssertEq leading.validation_summary.metadata_parity_pass
}
oneLeadingSynthetic ÔćÉ " Leading synthetic description"
twoLeadingSynthetic ÔćÉ "  Leading synthetic description"
lib.Assert converter.DescriptionRepresentable oneLeadingSynthetic
lib.Assert converter.DescriptionRepresentable twoLeadingSynthetic
AssertLeadingAdmission ÔčĘoneLeadingSynthetic,"2042-03-06"Ôčę
AssertLeadingAdmission ÔčĘtwoLeadingSynthetic,"2042-03-07"Ôčę

# Empty, trailing ASCII SPACE, C0 controls, and DEL remain rejected.
AssertFailure ÔčĘMakeOne ÔčĘ"2042-03-01","","assets:orchard","expenses:market","1",ÔčĘÔčęÔčę,"description_not_canonically_representable"Ôčę
AssertFailure ÔčĘMakeOne ÔčĘ"2042-03-01","trailing ","assets:orchard","expenses:market","1",ÔčĘÔčęÔčę,"description_not_canonically_representable"Ôčę
lib.Assert ┬Čconverter.DescriptionRepresentable "tab"ÔłżtabÔłż"inside"
lib.Assert ┬Čconverter.DescriptionRepresentable "line"ÔłżlfÔłż"inside"
lib.Assert ┬Čconverter.DescriptionRepresentable "carriage"Ôłż(@+13)Ôłż"inside"
AssertFailure ÔčĘMakeOne ÔčĘ"2042-03-01","carriage"Ôłż(@+13)Ôłż"inside","assets:orchard","expenses:market","1",ÔčĘÔčęÔčę,"description_not_canonically_representable"Ôčę
lib.Assert ┬Čconverter.DescriptionRepresentable "nul"Ôłż(@+0)Ôłż"inside"
AssertFailure ÔčĘMakeOne ÔčĘ"2042-03-01","nul"Ôłż(@+0)Ôłż"inside","assets:orchard","expenses:market","1",ÔčĘÔčęÔčę,"description_not_canonically_representable"Ôčę
lib.Assert ┬Čconverter.DescriptionRepresentable "del"Ôłż(@+127)Ôłż"inside"
AssertFailure ÔčĘMakeOne ÔčĘ"2042-03-01","del"Ôłż(@+127)Ôłż"inside","assets:orchard","expenses:market","1",ÔčĘÔčęÔčę,"description_not_canonically_representable"Ôčę
AssertFailure ÔčĘMakeOne ÔčĘ"2042-03-01","Unknown metadata","assets:orchard","expenses:market","1",ÔčĘ"mystery=value"ÔčęÔčę,"metadata_unknown"Ôčę
AssertFailure ÔčĘMakeOne ÔčĘ"2042-03-01","Duplicate metadata","assets:orchard","expenses:market","1",ÔčĘ"tax=private","tax=business"ÔčęÔčę,"metadata_duplicate"Ôčę
AssertFailure ÔčĘMakeOne ÔčĘ"2042-03-01","Empty metadata","assets:orchard","expenses:market","1",ÔčĘ"note="ÔčęÔčę,"metadata_value_invalid"Ôčę
AssertFailure ÔčĘMakeOne ÔčĘ"2042-03-01","Leading metadata remains unsafe","assets:orchard","expenses:market","1",ÔčĘ"note= leading"ÔčęÔčę,"metadata_value_invalid"Ôčę
AssertFailure ÔčĘMakeOne ÔčĘ"2042-03-01","Controlled metadata","assets:orchard","expenses:market","1",ÔčĘ"biz=yes"ÔčęÔčę,"metadata_value_invalid"Ôčę
AssertFailure ÔčĘMakeOne ÔčĘ"2042-03-01","Foreign currency","assets:orchard","expenses:market","1",ÔčĘ"currency=ILS"ÔčęÔčę,"metadata_value_invalid"Ôčę

# A native three-posting suffix is copied, not rendered. It starts with one LF,
# creating the required blank line without changing either operand.
suffix ÔćÉ lf Ôłż "2042-03-06 * Native split suffix" Ôłż lf Ôłż "    ; event-id: native-suffix-public-001" Ôłż lf Ôłż "    ; layer: actual" Ôłż lf Ôłż "    expenses:market 40 JPY" Ôłż lf Ôłż "    expenses:studio 60 JPY" Ôłż lf Ôłż "    assets:orchard -100 JPY" Ôłż lf
reconstructed ÔćÉ converter.Reconstruct ÔčĘconverted,suffix,resolved,cycleStartÔčę
"ok" lib.AssertEq reconstructed.state
(prefixÔłżsuffix) lib.AssertEq reconstructed.reconstructed_candidate_bytes
1 lib.AssertEq +┬┤ suffix ÔŹĚ reconstructed.reconstructed_candidate_bytes
4 lib.AssertEq reconstructed.validation_summary.transaction_count
9 lib.AssertEq reconstructed.validation_summary.posting_count
suffix lib.AssertEq (Ôëáprefix)Ôćôreconstructed.reconstructed_candidate_bytes
mixedAccounts ÔćÉ accounts Ôłż ÔčĘ"assets:foreign"ÔłżtabÔłż"role=asset"ÔłżtabÔłż"currency=ILS"Ôčę
mixedConverted ÔćÉ converter.Convert ÔčĘsnapshot,"journal.tsv",mixedAccounts,cycleStartÔčę
"ok" lib.AssertEq mixedConverted.state
foreignSuffix ÔćÉ lf Ôłż "2042-03-06 * Native foreign suffix" Ôłż lf Ôłż "    ; event-id: native-suffix-public-foreign" Ôłż lf Ôłż "    ; layer: actual" Ôłż lf Ôłż "    expenses:market 40 JPY" Ôłż lf Ôłż "    assets:foreign 60 JPY" Ôłż lf Ôłż "    assets:orchard -100 JPY" Ôłż lf
foreignReconstruction ÔćÉ converter.Reconstruct ÔčĘmixedConverted,foreignSuffix,ak.Resolve mixedAccounts,cycleStartÔčę
"error" lib.AssertEq foreignReconstruction.state
"" lib.AssertEq foreignReconstruction.reconstructed_candidate_bytes
lib.Assert HasCode ÔčĘ"account_currency_incompatible",foreignReconstructionÔčę

badVerified ÔćÉ {stateÔçÉ"error",canonical_prefix_bytesÔçÉ""}
failedReconstruction ÔćÉ converter.Reconstruct ÔčĘbadVerified,suffix,resolved,cycleStartÔčę
"error" lib.AssertEq failedReconstruction.state
"" lib.AssertEq failedReconstruction.reconstructed_candidate_bytes
lib.Assert HasCode ÔčĘ"verified_prefix_required",failedReconstructionÔčę
duplicateSuffix ÔćÉ converter.Reconstruct ÔčĘconverted,suffixÔłżsuffix,resolved,cycleStartÔčę
"error" lib.AssertEq duplicateSuffix.state
"" lib.AssertEq duplicateSuffix.reconstructed_candidate_bytes
lib.Assert HasCode ÔčĘ"suffix_transaction_duplicate",duplicateSuffixÔčę

SuffixTransaction ÔćÉ {­ŁĽŐ eventIdÔÇ┐description:
  Ôłż ÔčĘ
    lf, "2042-03-07 * ", description, lf,
    "    ; event-id: ", eventId, lf, "    ; layer: actual", lf,
    "    expenses:market 1 JPY", lf, "    assets:orchard -1 JPY", lf
  Ôčę
}
prefixIdentitySuffix ÔćÉ SuffixTransaction ÔčĘ"legacy:journal.tsv:0","Prefix identity duplicate"Ôčę
prefixIdentityDuplicate ÔćÉ converter.Reconstruct ÔčĘconverted,prefixIdentitySuffix,resolved,cycleStartÔčę
