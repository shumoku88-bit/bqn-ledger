raw в†ђ вЂўFChars "../fixtures/journal-posting-ir-stage2b/profile.journal"
parsed в†ђ parser.Parse raw
"ok" lib.AssertEq parsed.state
0 lib.AssertEq в‰  parsed.diagnostics
2 lib.AssertEq в‰  parsed.transactions
вџЁ<"plan", <"actual"вџ© lib.AssertEq {<рќ•©.layer_name}ВЁ parsed.transactions
вџЁ2, 2вџ© lib.AssertEq {в‰ рќ•©.postings}ВЁ parsed.transactions

accountLines в†ђ loader.ReadLines (base в€ѕ "/accounts.tsv")
resolved в†ђ ak.Resolve accountLines
resolved.accounts lib.AssertEq {рќ•©.account_key}ВЁ parsed.accounts

stage2a в†ђ adapter.Build вџЁparsed.transactions, resolved, cycleStartвџ©
"ok" lib.AssertEq stage2a.state
4 lib.AssertEq в‰  stage2a.posting_rows
rowsBefore в†ђ stage2a.posting_rows
built в†ђ identity.Build вџЁparsed.transactions, rowsBeforeвџ©
"ok" lib.AssertEq built.state
0 lib.AssertEq в‰  built.diagnostics
4 lib.AssertEq в‰  built.posting_rows
4 lib.AssertEq в‰  built.provenance_rows
rowsBefore lib.AssertEq built.posting_rows
({<рќ•©.posting_id}ВЁ built.posting_rows) lib.AssertEq {<рќ•©.posting_id}ВЁ built.provenance_rows

planCarrier в†ђ 0вЂї1 вЉЏ built.provenance_rows
actualCarrier в†ђ 2вЂї3 вЉЏ built.provenance_rows
lib.Assert в€§Вґ {рќ•©.source_event_id в‰Ў "event-plan-service-2026-09"}ВЁ planCarrier
lib.Assert в€§Вґ {рќ•©.identity_kind в‰Ў "durable"}ВЁ planCarrier
lib.Assert в€§Вґ {рќ•©.source_id в‰Ў "event-plan-service-2026-09"}ВЁ 0вЂї1 вЉЏ built.posting_rows
lib.Assert в€§Вґ {рќ•©.tx_id в‰Ў "event-plan-service-2026-09"}ВЁ 0вЂї1 вЉЏ built.posting_rows
lib.Assert в€§Вґ {рќ•©.source_event_id в‰Ў (вЉ‘ actualCarrier).source_event_id}ВЁ actualCarrier
lib.Assert в€§Вґ {рќ•©.identity_kind в‰Ў "physical_fallback"}ВЁ actualCarrier
0вЂї1 lib.AssertEq {рќ•©.posting_index}ВЁ planCarrier
0вЂї1 lib.AssertEq {рќ•©.posting_index}ВЁ actualCarrier
lib.Assert в€§Вґ {рќ•©.posting_id в‰Ў рќ•©.source_event_id в€ѕ ":" в€ѕ вЂўFmt рќ•©.posting_index}ВЁ built.provenance_rows
4 lib.AssertEq в‰  вЌ· {<рќ•©.posting_id}ВЁ built.provenance_rows

# Reparse and rebuild identical source evidence to prove deterministic identity.
parsedAgain в†ђ parser.Parse raw
stage2aAgain в†ђ adapter.Build вџЁparsedAgain.transactions, resolved, cycleStartвџ©
builtAgain в†ђ identity.Build вџЁparsedAgain.transactions, stage2aAgain.posting_rowsвџ©
({<рќ•©.source_event_id}ВЁ built.provenance_rows) lib.AssertEq {<рќ•©.source_event_id}ВЁ builtAgain.provenance_rows
({<рќ•©.posting_id}ВЁ built.provenance_rows) lib.AssertEq {<рќ•©.posting_id}ВЁ builtAgain.provenance_rows

# Source transaction/posting order remains plan then actual and debit then credit.
вџЁ<"expenses:service/JPY", <"assets:cash/JPY", <"expenses:service/JPY", <"assets:cash/JPY"вџ© lib.AssertEq {<рќ•©.account_key}ВЁ built.posting_rows
2400вЂїВЇ2400вЂї900вЂїВЇ900 lib.AssertEq {рќ•©.delta}ВЁ built.posting_rows

# Project every established field: Stage 2B returns, rather than reconstructs,
# each current 16-field row.
Fields16 в†ђ {рќ•Љ row: вџЁ
  <row.source_file, row.source_row, <row.source_id, <row.tx_id,
  <row.posting_id, <row.date, row.day_index, <row.account_key,
  row.account_key_index, <row.layer_name, row.layer_index, <row.side,
  row.delta, <row.kind, <row.status, <row.message
вџ©}
lib.Assert в€§Вґ {16 = в‰  Fields16 рќ•©}ВЁ built.posting_rows
(Fields16ВЁ rowsBefore) lib.AssertEq Fields16ВЁ built.posting_rows

# Move the durable plan block below the actual in memory. Its physical span
# changes, but explicit semantic identity and deterministic posting IDs do not.
variantRaw в†ђ в€ѕ вџЁ
  "; In-memory movement variant", lf, lf,
  "commodity JPY", lf, lf,
  "account assets:cash", lf, "    ; role: asset", lf, lf,
  "account expenses:service", lf, "    ; role: expense", lf, lf,
  "2026-09-11 * Anonymous ordinary actual", lf,
  "    expenses:service 900 JPY", lf,
  "    assets:cash -900 JPY", lf, lf,
  "2026-09-10 ! Anonymous service plan", lf,
  "    ; event-id: event-plan-service-2026-09", lf,
  "    ; layer: plan", lf,
  "    ; plan-id: plan-service-2026-09", lf,
  "    ; execution-envelope: reserve", lf,
  "    expenses:service 2400 JPY", lf,
  "    assets:cash -2400 JPY", lf
вџ©
variantParsed в†ђ parser.Parse variantRaw
"ok" lib.AssertEq variantParsed.state
variantStage2a в†ђ adapter.Build вџЁvariantParsed.transactions, resolved, cycleStartвџ©
variantBuilt в†ђ identity.Build вџЁvariantParsed.transactions, variantStage2a.posting_rowsвџ©
"ok" lib.AssertEq variantBuilt.state
originalPlan в†ђ 0 вЉ‘ parsed.transactions
variantPlan в†ђ вЉ‘ ({рќ•©.layer_name в‰Ў "plan"}ВЁ variantParsed.transactions) / variantParsed.transactions
lib.Assert originalPlan.source_start_line в‰  variantPlan.source_start_line
lib.Assert originalPlan.source_end_line в‰  variantPlan.source_end_line
"event-plan-service-2026-09" lib.AssertEq variantPlan.source_event_id
({<рќ•©.posting_id}ВЁ originalPlan.postings) lib.AssertEq {<рќ•©.posting_id}ВЁ variantPlan.postings
variantPlanCarrier в†ђ ({рќ•©.source_event_id в‰Ў "event-plan-service-2026-09"}ВЁ variantBuilt.provenance_rows) / variantBuilt.provenance_rows
lib.Assert в€§Вґ {рќ•©.identity_kind в‰Ў "durable"}ВЁ variantPlanCarrier
({<рќ•©.posting_id}ВЁ planCarrier) lib.AssertEq {<рќ•©.posting_id}ВЁ variantPlanCarrier

# Legacy comparison stays on unchanged current 16-field rows. Labels and
# ordinals are test-only observations of each source movement.
snapshot в†ђ {sourcesв‡ђвџЁ
  {source_fileв‡ђ"journal.tsv", requiredв‡ђ1, linesв‡ђloader.ReadLines (base в€ѕ "/journal.tsv")},
  {source_fileв‡ђ"plan.tsv", requiredв‡ђ0, linesв‡ђloader.ReadLines (base в€ѕ "/plan.tsv")},
  {source_fileв‡ђ"budget_alloc.tsv", requiredв‡ђ0, linesв‡ђвџЁвџ©}
вџ©}
legacy в†ђ context.BuildCheckedPostingProjectionFromSnapshot вџЁsnapshot, resolved, cycleStartвџ©
"ok" lib.AssertEq legacy.state
4 lib.AssertEq в‰  legacy.posting_rows
lib.Assert в€§Вґ {16 = в‰  Fields16 рќ•©}ВЁ legacy.posting_rows

{рќ•Љ sourceFile:
  movement в†ђ ({рќ•©.source_file в‰Ў sourceFile}ВЁ legacy.posting_rows) / legacy.posting_rows
  2 lib.AssertEq в‰  movement
  lib.Assert в€§Вґ {рќ•©.source_file в‰Ў sourceFile}ВЁ movement
  lib.Assert (0 вЉ‘ movement).source_row = (1 вЉ‘ movement).source_row
  labels в†ђ {<("legacy:" в€ѕ рќ•©.source_file в€ѕ ":" в€ѕ вЂўFmt рќ•©.source_row)}ВЁ movement
  lib.Assert (>0вЉ‘labels) в‰Ў >1вЉ‘labels
  2 lib.AssertEq в‰  вЌ· {<рќ•©.posting_id}ВЁ movement
  0вЂї1 lib.AssertEq в†• в‰  movement
  lib.Assert В¬ в€ЁВґ 0 в€ѕ {(>вЉ‘labels) в‰Ў рќ•©.posting_id}ВЁ built.provenance_rows
}ВЁ вџЁ"journal.tsv", "plan.tsv"вџ©

HasCode в†ђ {рќ•Љ codeвЂїresult: в€ЁВґ 0 в€ѕ {code в‰Ў рќ•©.code}ВЁ result.diagnostics}
CheckFail в†ђ {рќ•Љ transactionsвЂїpostingRowsвЂїexpectedCode:
  failed в†ђ identity.Build вџЁtransactions, postingRowsвџ©
  "error" lib.AssertEq failed.state
