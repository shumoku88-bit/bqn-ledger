}}
Rows в†ђ {рќ•Љ boxedIds: {{posting_idв‡ђ>рќ•©}}ВЁ boxedIds}

validTx в†ђ Tx вџЁ"event-a", "durable", 1, 4, вџЁP вџЁ0,"event-a:0"вџ©, P вџЁ1,"event-a:1"вџ©вџ©вџ©
validRows в†ђ Rows вџЁ<"event-a:0", <"event-a:1"вџ©

# Duplicate posting IDs (across events with the same event identity).
duplicateTxs в†ђ вџЁvalidTx, Tx вџЁ"event-a", "durable", 5, 8, вџЁP вџЁ0,"event-a:0"вџ©, P вџЁ1,"event-a:1"вџ©вџ©вџ©вџ©
CheckFail вџЁduplicateTxs, Rows вџЁ<"event-a:0", <"event-a:1", <"event-a:0", <"event-a:1"вџ©, "posting_id_duplicate"вџ©

nonContiguous в†ђ Tx вџЁ"event-a", "durable", 1, 4, вџЁP вџЁ0,"event-a:0"вџ©, P вџЁ2,"event-a:2"вџ©вџ©вџ©
CheckFail вџЁвџЁnonContiguousвџ©, Rows вџЁ<"event-a:0", <"event-a:2"вџ©, "posting_index_non_contiguous"вџ©

