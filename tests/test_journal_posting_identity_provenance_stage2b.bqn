  0 lib.AssertEq в‰  failed.provenance_rows
  lib.Assert 0 < в‰  failed.diagnostics
  lib.Assert HasCode вџЁexpectedCode, failedвџ©
}
P в†ђ {рќ•Љ indexвЂїpostingId: {posting_indexв‡ђindex, posting_idв‡ђpostingId}}
