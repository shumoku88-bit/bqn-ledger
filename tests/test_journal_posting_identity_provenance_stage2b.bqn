#!/usr/bin/env bqn

lib тЖР тАвImport "test_lib.bqn"
parser тЖР тАвImport "../src_next/journal_profile_stage1.bqn"
adapter тЖР тАвImport "../src_next/journal_posting_ir_stage2a.bqn"
identity тЖР тАвImport "../src_next/journal_posting_identity_provenance_stage2b.bqn"
context тЖР тАвImport "../src_next/context.bqn"
ak тЖР тАвImport "../src_next/account_key.bqn"
loader тЖР тАвImport "../src_next/loader.bqn"

lf тЖР @+10
base тЖР "fixtures/journal-posting-ir-stage2b"
cycleStart тЖР "2026-09-01"

raw тЖР тАвFChars "../fixtures/journal-posting-ir-stage2b/profile.journal"
parsed тЖР parser.Parse raw
"ok" lib.AssertEq parsed.state
0 lib.AssertEq тЙа parsed.diagnostics
2 lib.AssertEq тЙа parsed.transactions
тЯи<"plan", <"actual"тЯй lib.AssertEq {<ЁЭХй.layer_name}┬и parsed.transactions
тЯи2, 2тЯй lib.AssertEq {тЙаЁЭХй.postings}┬и parsed.transactions

accountLines тЖР loader.ReadLines (base тИ╛ "/accounts.tsv")
resolved тЖР ak.Resolve accountLines
resolved.accounts lib.AssertEq {ЁЭХй.account_key}┬и parsed.accounts

stage2a тЖР adapter.Build тЯиparsed.transactions, resolved, cycleStartтЯй
"ok" lib.AssertEq stage2a.state
4 lib.AssertEq тЙа stage2a.posting_rows
rowsBefore тЖР stage2a.posting_rows
built тЖР identity.Build тЯиparsed.transactions, rowsBeforeтЯй
"ok" lib.AssertEq built.state
0 lib.AssertEq тЙа built.diagnostics
4 lib.AssertEq тЙа built.posting_rows
4 lib.AssertEq тЙа built.provenance_rows
rowsBefore lib.AssertEq built.posting_rows
({<ЁЭХй.posting_id}┬и built.posting_rows) lib.AssertEq {<ЁЭХй.posting_id}┬и built.provenance_rows

planCarrier тЖР 0тА┐1 тКП built.provenance_rows
actualCarrier тЖР 2тА┐3 тКП built.provenance_rows
lib.Assert тИз┬┤ {ЁЭХй.source_event_id тЙб "event-plan-service-2026-09"}┬и planCarrier
lib.Assert тИз┬┤ {ЁЭХй.identity_kind тЙб "durable"}┬и planCarrier
lib.Assert тИз┬┤ {ЁЭХй.source_id тЙб "event-plan-service-2026-09"}┬и 0тА┐1 тКП built.posting_rows
lib.Assert тИз┬┤ {ЁЭХй.tx_id тЙб "event-plan-service-2026-09"}┬и 0тА┐1 тКП built.posting_rows
lib.Assert тИз┬┤ {ЁЭХй.source_event_id тЙб (тКС actualCarrier).source_event_id}┬и actualCarrier
lib.Assert тИз┬┤ {ЁЭХй.identity_kind тЙб "physical_fallback"}┬и actualCarrier
0тА┐1 lib.AssertEq {ЁЭХй.posting_index}┬и planCarrier
0тА┐1 lib.AssertEq {ЁЭХй.posting_index}┬и actualCarrier
lib.Assert тИз┬┤ {ЁЭХй.posting_id тЙб ЁЭХй.source_event_id тИ╛ ":" тИ╛ тАвFmt ЁЭХй.posting_index}┬и built.provenance_rows
4 lib.AssertEq тЙа тН╖ {<ЁЭХй.posting_id}┬и built.provenance_rows

# Reparse and rebuild identical source evidence to prove deterministic identity.
parsedAgain тЖР parser.Parse raw
stage2aAgain тЖР adapter.Build тЯиparsedAgain.transactions, resolved, cycleStartтЯй
builtAgain тЖР identity.Build тЯиparsedAgain.transactions, stage2aAgain.posting_rowsтЯй
({<ЁЭХй.source_event_id}┬и built.provenance_rows) lib.AssertEq {<ЁЭХй.source_event_id}┬и builtAgain.provenance_rows
({<ЁЭХй.posting_id}┬и built.provenance_rows) lib.AssertEq {<ЁЭХй.posting_id}┬и builtAgain.provenance_rows

# Source transaction/posting order remains plan then actual and debit then credit.
тЯи<"expenses:service/JPY", <"assets:cash/JPY", <"expenses:service/JPY", <"assets:cash/JPY"тЯй lib.AssertEq {<ЁЭХй.account_key}┬и built.posting_rows
2400тА┐┬п2400тА┐900тА┐┬п900 lib.AssertEq {ЁЭХй.delta}┬и built.posting_rows

# Project every established field: Stage 2B returns, rather than reconstructs,
# each current 16-field row.
Fields16 тЖР {ЁЭХК row: тЯи
  <row.source_file, row.source_row, <row.source_id, <row.tx_id,
  <row.posting_id, <row.date, row.day_index, <row.account_key,
  row.account_key_index, <row.layer_name, row.layer_index, <row.side,
  row.delta, <row.kind, <row.status, <row.message
тЯй}
lib.Assert тИз┬┤ {16 = тЙа Fields16 ЁЭХй}┬и built.posting_rows
(Fields16┬и rowsBefore) lib.AssertEq Fields16┬и built.posting_rows

# Move the durable plan block below the actual in memory. Its physical span
# changes, but explicit semantic identity and deterministic posting IDs do not.
variantRaw тЖР тИ╛ тЯи
  "; In-memory movement variant", lf, lf,
  "commodity JPY", lf, lf,
  "account assets:cash", lf, "    ; role: asset", lf, lf,
  "account expenses:service", lf, "    ; role: expense", lf, lf,
  "2026-09-11 * Anonymous ordinary actual", lf,
  "    expenses:service 900 JPY", lf,
  "    assets:cash -900 JPY", lf, lf,
  "2026-09-10 ! Anonymous service plan", lf,
  "    ; event-id: event-plan-service-2026-09", lf,
  "    ; layer: plan", lf,
  "    ; plan-id: plan-service-2026-09", lf,
  "    ; execution-envelope: reserve", lf,
  "    expenses:service 2400 JPY", lf,
  "    assets:cash -2400 JPY", lf
тЯй
variantParsed тЖР parser.Parse variantRaw
"ok" lib.AssertEq variantParsed.state
variantStage2a тЖР adapter.Build тЯиvariantParsed.transactions, resolved, cycleStartтЯй
variantBuilt тЖР identity.Build тЯиvariantParsed.transactions, variantStage2a.posting_rowsтЯй
"ok" lib.AssertEq variantBuilt.state
originalPlan тЖР 0 тКС parsed.transactions
variantPlan тЖР тКС ({ЁЭХй.layer_name тЙб "plan"}┬и variantParsed.transactions) / variantParsed.transactions
lib.Assert originalPlan.source_start_line тЙа variantPlan.source_start_line
lib.Assert originalPlan.source_end_line тЙа variantPlan.source_end_line
"event-plan-service-2026-09" lib.AssertEq variantPlan.source_event_id
({<ЁЭХй.posting_id}┬и originalPlan.postings) lib.AssertEq {<ЁЭХй.posting_id}┬и variantPlan.postings
variantPlanCarrier тЖР ({ЁЭХй.source_event_id тЙб "event-plan-service-2026-09"}┬и variantBuilt.provenance_rows) / variantBuilt.provenance_rows
lib.Assert тИз┬┤ {ЁЭХй.identity_kind тЙб "durable"}┬и variantPlanCarrier
lib.Assert тИз┬┤ {(ЁЭХй.source_start_line = originalPlan.source_start_line) тИз ЁЭХй.source_end_line = originalPlan.source_end_line}┬и planCarrier
lib.Assert тИз┬┤ {(ЁЭХй.source_start_line = variantPlan.source_start_line) тИз ЁЭХй.source_end_line = variantPlan.source_end_line}┬и variantPlanCarrier
lib.Assert (тКС planCarrier).source_start_line тЙа (тКС variantPlanCarrier).source_start_line
lib.Assert (тКС planCarrier).source_end_line тЙа (тКС variantPlanCarrier).source_end_line
lib.Assert тИз┬┤ {ЁЭХй.source_event_id тЙб "event-plan-service-2026-09"}┬и variantPlanCarrier
({<ЁЭХй.posting_id}┬и planCarrier) lib.AssertEq {<ЁЭХй.posting_id}┬и variantPlanCarrier

# Legacy comparison stays on unchanged current 16-field rows. Labels and
# ordinals are test-only observations of each source movement.
snapshot тЖР {sourcesтЗРтЯи
  {source_fileтЗР"journal.tsv", requiredтЗР1, linesтЗРloader.ReadLines (base тИ╛ "/journal.tsv")},
  {source_fileтЗР"plan.tsv", requiredтЗР0, linesтЗРloader.ReadLines (base тИ╛ "/plan.tsv")},
  {source_fileтЗР"budget_alloc.tsv", requiredтЗР0, linesтЗРтЯитЯй}
тЯй}
legacy тЖР context.BuildCheckedPostingProjectionFromSnapshot тЯиsnapshot, resolved, cycleStartтЯй
"ok" lib.AssertEq legacy.state
4 lib.AssertEq тЙа legacy.posting_rows
lib.Assert тИз┬┤ {16 = тЙа Fields16 ЁЭХй}┬и legacy.posting_rows

{ЁЭХК sourceFile:
  movement тЖР ({ЁЭХй.source_file тЙб sourceFile}┬и legacy.posting_rows) / legacy.posting_rows
  2 lib.AssertEq тЙа movement
  lib.Assert тИз┬┤ {ЁЭХй.source_file тЙб sourceFile}┬и movement
  lib.Assert (0 тКС movement).source_row = (1 тКС movement).source_row
  labels тЖР {<("legacy:" тИ╛ ЁЭХй.source_file тИ╛ ":" тИ╛ тАвFmt ЁЭХй.source_row)}┬и movement
  lib.Assert (>0тКСlabels) тЙб >1тКСlabels
  2 lib.AssertEq тЙа тН╖ {<ЁЭХй.posting_id}┬и movement
  0тА┐1 lib.AssertEq тЖХ тЙа movement
  lib.Assert ┬м тИи┬┤ 0 тИ╛ {(>тКСlabels) тЙб ЁЭХй.posting_id}┬и built.provenance_rows
}┬и тЯи"journal.tsv", "plan.tsv"тЯй

HasCode тЖР {ЁЭХК codeтА┐result: тИи┬┤ 0 тИ╛ {code тЙб ЁЭХй.code}┬и result.diagnostics}
CheckFail тЖР {ЁЭХК transactionsтА┐postingRowsтА┐expectedCode:
  failed тЖР identity.Build тЯиtransactions, postingRowsтЯй
  "error" lib.AssertEq failed.state
  0 lib.AssertEq тЙа failed.posting_rows
  0 lib.AssertEq тЙа failed.provenance_rows
  lib.Assert 0 < тЙа failed.diagnostics
  lib.Assert HasCode тЯиexpectedCode, failedтЯй
}
P тЖР {ЁЭХК indexтА┐postingId: {posting_indexтЗРindex, posting_idтЗРpostingId}}
Tx тЖР {ЁЭХК eventIdтА┐kindтА┐startLineтА┐endLineтА┐postings: {
  source_event_idтЗРeventId, identity_kindтЗРkind,
  source_start_lineтЗРstartLine, source_end_lineтЗРendLine,
  txn_idтЗРeventId, postingsтЗРpostings
}}
Rows тЖР {ЁЭХК boxedIds: {{posting_idтЗР>ЁЭХй, source_idтЗР"event-a", tx_idтЗР"event-a"}}┬и boxedIds}

validTx тЖР Tx тЯи"event-a", "durable", 1, 4, тЯиP тЯи0,"event-a:0"тЯй, P тЯи1,"event-a:1"тЯйтЯйтЯй
validRows тЖР Rows тЯи<"event-a:0", <"event-a:1"тЯй

# The Posting IR row carries the same malformed ID, so alignment still holds;
# the deterministic event-id/index encoding is the only violated invariant.
invalidPostingId тЖР Tx тЯи"event-a", "durable", 1, 4, тЯиP тЯи0,"event-a:not-zero"тЯй, P тЯи1,"event-a:1"тЯйтЯйтЯй
invalidPostingIdRows тЖР Rows тЯи<"event-a:not-zero", <"event-a:1"тЯй
CheckFail тЯитЯиinvalidPostingIdтЯй, invalidPostingIdRows, "posting_id_invalid"тЯй

# Duplicate posting IDs (across events with the same event identity).
duplicateTxs тЖР тЯиvalidTx, Tx тЯи"event-a", "durable", 5, 8, тЯиP тЯи0,"event-a:0"тЯй, P тЯи1,"event-a:1"тЯйтЯйтЯйтЯй
CheckFail тЯиduplicateTxs, Rows тЯи<"event-a:0", <"event-a:1", <"event-a:0", <"event-a:1"тЯй, "posting_id_duplicate"тЯй

nonContiguous тЖР Tx тЯи"event-a", "durable", 1, 4, тЯиP тЯи0,"event-a:0"тЯй, P тЯи2,"event-a:2"тЯйтЯйтЯй
CheckFail тЯитЯиnonContiguousтЯй, Rows тЯи<"event-a:0", <"event-a:2"тЯй, "posting_index_non_contiguous"тЯй

duplicateIndex тЖР Tx тЯи"event-a", "durable", 1, 4, тЯиP тЯи0,"event-a:0"тЯй, P тЯи0,"event-a:0"тЯйтЯйтЯй
CheckFail тЯитЯиduplicateIndexтЯй, Rows тЯи<"event-a:0", <"event-a:0"тЯй, "posting_index_duplicate"тЯй

emptyIdentity тЖР Tx тЯи"", "physical_fallback", 1, 4, тЯиP тЯи0,":0"тЯй, P тЯи1,":1"тЯйтЯйтЯй
CheckFail тЯитЯиemptyIdentityтЯй, Rows тЯи<":0", <":1"тЯй, "event_identity_missing"тЯй

unknownKind тЖР Tx тЯи"event-a", "temporary", 1, 4, validTx.postingsтЯй
CheckFail тЯитЯиunknownKindтЯй, validRows, "identity_kind_unknown"тЯй

invalidSpan тЖР Tx тЯи"event-a", "durable", 0, ┬п1, validTx.postingsтЯй
CheckFail тЯитЯиinvalidSpanтЯй, validRows, "source_span_invalid"тЯй

CheckFail тЯитЯиvalidTxтЯй, 1 тЖС validRows, "posting_count_mismatch"тЯй
CheckFail тЯитЯиvalidTxтЯй, 1тА┐0 тКП validRows, "posting_id_alignment_mismatch"тЯй

тАвOut "test_journal_posting_identity_provenance_stage2b.bqn: OK"
