#!/usr/bin/env bqn

lib έΗΡ έΑλImport "test_lib.bqn"
exchange έΗΡ έΑλImport "../src_next/travel_exchange_event.bqn"

tab έΗΡ @+9
lf έΗΡ @+10
Account έΗΡ {ΏζΧΛ nameέΑ┐existsέΑ┐currency: {nameέΘΡname, existsέΘΡexists, currencyέΘΡcurrency} }
Request έΗΡ {ΏζΧΛ dateέΑ┐memoέΑ┐sourceAccountέΑ┐sourceAmountέΑ┐sourceCurrencyέΑ┐targetAccountέΑ┐targetAmountέΑ┐targetCurrencyέΑ┐exchangeIdέΑ┐tripIdέΑ┐existingIds:
  {dateέΘΡdate, memoέΘΡmemo, source_accountέΘΡsourceAccount, source_amountέΘΡsourceAmount, source_currencyέΘΡsourceCurrency,
   target_accountέΘΡtargetAccount, target_amountέΘΡtargetAmount, target_currencyέΘΡtargetCurrency,
   exchange_idέΘΡexchangeId, trip_idέΘΡtripId, existing_exchange_idsέΘΡexistingIds}
}
Source έΗΡ {ΏζΧΛ: Account έθρ"assets:bank-jpy", 1, "JPY"έθσ }
Target έΗΡ {ΏζΧΛ: Account έθρ"assets:cash-ils", 1, "ILS"έθσ }
Valid έΗΡ {ΏζΧΛ: Request έθρ"2026-07-20", "airport exchange", Source @, "10000", "JPY", Target @, "250.00", "ILS", "israel-2026-exchange-0001", "israel-2026", έθρέθσέθσ }

accepted έΗΡ exchange.ValidateAndPreview Valid @
"ok" lib.AssertEq accepted.state
0 lib.AssertEq έΚιaccepted.diagnostics
1 lib.AssertEq έΚιaccepted.preview_events
preview έΗΡ έΛΣaccepted.preview_events
"ok" lib.AssertEq preview.state
"10000" lib.AssertEq preview.source_amount
"JPY" lib.AssertEq preview.source_currency
"250.00" lib.AssertEq preview.target_amount
"ILS" lib.AssertEq preview.target_currency
"israel-2026-exchange-0001" lib.AssertEq preview.exchange_id
"israel-2026" lib.AssertEq preview.trip_id

CheckRejected έΗΡ {ΏζΧΛ request:
  result έΗΡ exchange.ValidateAndPreview request
  "error" lib.AssertEq result.state
  0 lib.AssertEq έΚιresult.preview_events
  lib.Assert 0<έΚιresult.diagnostics
  result
}
shape έΗΡ CheckRejected {dateέΘΡ"private-date", memoέΘΡ"private-memo"}
"request_shape_invalid" lib.AssertEq (έΛΣshape.diagnostics).code
CheckRejected Request έθρ"bad", "memo", Source @, "100", "JPY", Target @, "2", "ILS", "id", "israel-2026", έθρέθσέθσ
CheckRejected Request έθρ"2026-07-20", "bad"έΙ╛tabέΙ╛"memo", Source @, "100", "JPY", Target @, "2", "ILS", "id", "israel-2026", έθρέθσέθσ
CheckRejected Request έθρ"2026-07-20", "memo", Source @, "100", "ILS", Target @, "2", "ILS", "id", "israel-2026", έθρέθσέθσ
CheckRejected Request έθρ"2026-07-20", "memo", Source @, "100", "ILS", Target @, "2", "JPY", "id", "israel-2026", έθρέθσέθσ
CheckRejected Request έθρ"2026-07-20", "memo", Account έθρ"unknown", 0, "JPY"έθσ, "100", "JPY", Target @, "2", "ILS", "id", "israel-2026", έθρέθσέθσ
CheckRejected Request έθρ"2026-07-20", "memo", Source @, "100", "JPY", Account έθρ"unknown", 0, "ILS"έθσ, "2", "ILS", "id", "israel-2026", έθρέθσέθσ
CheckRejected Request έθρ"2026-07-20", "memo", Account έθρ"wrong", 1, "ILS"έθσ, "100", "JPY", Target @, "2", "ILS", "id", "israel-2026", έθρέθσέθσ
CheckRejected Request έθρ"2026-07-20", "memo", Source @, "100", "JPY", Account έθρ"wrong", 1, "JPY"έθσ, "2", "ILS", "id", "israel-2026", έθρέθσέθσ
CheckRejected Request έθρ"2026-07-20", "memo", Source @, "100", "JPY", Account έθρ"assets:bank-jpy", 1, "ILS"έθσ, "2", "ILS", "id", "israel-2026", έθρέθσέθσ
{ΏζΧσ έΜΕ CheckRejected Request έθρ"2026-07-20", "memo", Source @, ΏζΧσ, "JPY", Target @, "2", "ILS", "id", "israel-2026", έθρέθσέθσ}┬ρ έθρ"0", "-1", "12x", "1.5"έθσ
{ΏζΧσ έΜΕ CheckRejected Request έθρ"2026-07-20", "memo", Source @, "100", "JPY", Target @, ΏζΧσ, "ILS", "id", "israel-2026", έθρέθσέθσ}┬ρ έθρ"0", "-1", "12x", "1.001"έθσ
CheckRejected Request έθρ"2026-07-20", "memo", Source @, "100", "JPY", Target @, "2", "ILS", "", "israel-2026", έθρέθσέθσ
CheckRejected Request έθρ"2026-07-20", "memo", Source @, "100", "JPY", Target @, "2", "ILS", "id"έΙ╛lfέΙ╛"bad", "israel-2026", έθρέθσέθσ
duplicate έΗΡ CheckRejected Request έθρ"2026-07-20", "memo", Source @, "100", "JPY", Target @, "2", "ILS", "id", "israel-2026", έθρ"other", "id"έθσέθσ
"exchange_id_duplicate" lib.AssertEq (┬ψ1έΛΣduplicate.diagnostics).code
CheckRejected Request έθρ"2026-07-20", "memo", Source @, "100", "JPY", Target @, "2", "ILS", "id", "other", έθρέθσέθσ

# Full-source pure validation renders one exact fixed-ten-column candidate.
accounts έΗΡ έθρSource @, Target @έθσ
fields έΗΡ έθρ"2026-07-20", "airport exchange", "assets:bank-jpy", "10000", "JPY", "assets:cash-ils", "250.00", "ILS", "israel-2026-exchange-0001", "israel-2026"έθσ
sourceAccepted έΗΡ exchange.ValidateSourceAndPreview {candidate_fieldsέΘΡfields, existing_linesέΘΡέθρέθσ, accountsέΘΡaccounts}
"ok" lib.AssertEq sourceAccepted.state
1 lib.AssertEq έΚιsourceAccepted.preview_rows
("2026-07-20"έΙ╛tabέΙ╛"airport exchange"έΙ╛tabέΙ╛"assets:bank-jpy"έΙ╛tabέΙ╛"10000"έΙ╛tabέΙ╛"JPY"έΙ╛tabέΙ╛"assets:cash-ils"έΙ╛tabέΙ╛"250.00"έΙ╛tabέΙ╛"ILS"έΙ╛tabέΙ╛"israel-2026-exchange-0001"έΙ╛tabέΙ╛"israel-2026") lib.AssertEq έΛΣsourceAccepted.preview_rows
existingLine έΗΡ έΛΣsourceAccepted.preview_rows
"error" lib.AssertEq (exchange.ValidateSourceAndPreview {candidate_fieldsέΘΡfields, existing_linesέΘΡέθρexistingLineέθσ, accountsέΘΡaccounts}).state
"error" lib.AssertEq (exchange.ValidateExisting έθρέθρ"malformed"έΙ╛tabέΙ╛"row"έθσ, accountsέθσ).state
"error" lib.AssertEq (exchange.ValidateExisting έθρέθρexistingLine, existingLineέθσ, accountsέθσ).state

# The structured contract contains observations, not a rate or journal row.
1 lib.AssertEq ({ΏζΧσ.rate έΜΕ 0}έΟΛ{ΏζΧσέΜΕ1}) preview
1 lib.AssertEq ({ΏζΧσ.journal_row έΜΕ 0}έΟΛ{ΏζΧσέΜΕ1}) preview
lib.Assert preview.source_amount έΚλ preview.target_amount

# Diagnostics are fixed and privacy-safe.
privacy έΗΡ CheckRejected Request έθρ"private-date", "Private Memo"έΙ╛tabέΙ╛"x", Account έθρ"private-source", 0, "ILS"έθσ, "987x", "ILS", Account έθρ"private-target", 0, "JPY"έθσ, "654x", "JPY", "private-id"έΙ╛lfέΙ╛"x", "private-trip", έθρέθσέθσ
messages έΗΡ έΙ╛({ΏζΧσ.messageέΙ╛"\n"}┬ρprivacy.diagnostics)
{ΏζΧσ έΜΕ 0 lib.AssertEq έΙρ┬┤ΏζΧσέΞ╖messages}┬ρ έθρ"private-date", "Private Memo", "private-source", "private-target", "987x", "654x", "private-id", "private-trip"έθσ

έΑλOut "test_src_next_travel_exchange_event.bqn: OK"
