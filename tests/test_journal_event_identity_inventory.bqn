# tests/test_journal_event_identity_inventory.bqn
# Unit test for Journal event identity inventory multi-axis classifier,
# reference index, privacy boundary, and reference independence.

lib έΗΡ έΑλImport "test_lib.bqn"
inventory έΗΡ έΑλImport "../src_edit/journal_identity_inventory.bqn"

# έΦΑέΦΑέΦΑ 1. Lexical family tests έΦΑέΦΑέΦΑ
# Lexical family is a syntax observation; these tests verify shape classification only.
"LEGACY_ENTRY_24HEX" lib.AssertEq (inventory.ClassifyLexicalFamily "entry-0123456789abcdef01234567")
"PREFIXED_HEX" lib.AssertEq (inventory.ClassifyLexicalFamily "tx-123456")
"PREFIXED_HEX" lib.AssertEq (inventory.ClassifyLexicalFamily "reverse-abcdef012345")
"PREFIXED_OTHER" lib.AssertEq (inventory.ClassifyLexicalFamily "plan-2026-07-15-wifi")
"OPAQUE_HEX" lib.AssertEq (inventory.ClassifyLexicalFamily "0123456789abcdef")
"TEXTUAL_OTHER" lib.AssertEq (inventory.ClassifyLexicalFamily "semantic_id_test")
"TEXTUAL_OTHER" lib.AssertEq (inventory.ClassifyLexicalFamily "daily_groceries_july")
"NONE" lib.AssertEq (inventory.ClassifyLexicalFamily "")
"OTHER" lib.AssertEq (inventory.ClassifyLexicalFamily "___")
"OPAQUE_HEX" lib.AssertEq (inventory.ClassifyLexicalFamily "12345")

# έΦΑέΦΑέΦΑ 2. Privacy canary fixture έΦΑέΦΑέΦΑ
# Synthetic fixture with easily-searchable private canary values.
# These MUST NOT appear in summary or redacted TSV output.
canaryTxs έΗΡ έθρ
  {
    dateέΘΡ"2026-07-01", status_markerέΘΡ"*", descriptionέΘΡ"PRIVATE_DESCRIPTION_CANARY_852", layer_nameέΘΡ"actual",
    identity_kindέΘΡ"durable", source_event_idέΘΡ"PRIVATE_EVENT_CANARY_741", plan_idέΘΡ"PRIVATE_PLAN_CANARY_963", txn_idέΘΡ"PRIVATE_TXN_CANARY_159",
    allocation_idέΘΡ"", actual_event_idέΘΡ"", execution_envelopeέΘΡ"", postingsέΘΡέθρέθσ,
    metadataέΘΡέθρ{keyέΘΡ"event-id", valueέΘΡ"PRIVATE_EVENT_CANARY_741", source_lineέΘΡ5}, {keyέΘΡ"plan-id", valueέΘΡ"PRIVATE_PLAN_CANARY_963", source_lineέΘΡ6}, {keyέΘΡ"txn-id", valueέΘΡ"PRIVATE_TXN_CANARY_159", source_lineέΘΡ7}έθσ,
    source_start_lineέΘΡ4
  }
έθσ

canaryInv έΗΡ inventory.BuildInventory canaryTxs
canaryS έΗΡ inventory.Summarize canaryInv
summaryText έΗΡ inventory.FormatSummary canaryS
tsvText έΗΡ inventory.FormatTsv canaryInv

# Privacy: canary values MUST NOT appear in summary output
# We verify the canary substrings are not found anywhere in the output text
HasSubstring έΗΡ {
  needle έΗΡ ΏζΧρ έΜΕ haystack έΗΡ ΏζΧσ
  nLen έΗΡ έΚι needle έΜΕ hLen έΗΡ έΚι haystack
  (nLen > hLen) έΩ╢ έθρ
    {ΏζΧΛ: έΙρ┬┤ 0 έΙ╛ { needle έΚκ nLen έΗΣ ΏζΧσ έΗΥ haystack }┬ρ έΗΧ (hLen - nLen) + 1},
    {ΏζΧΛ: 0}
  έθσ @
}

# Summary must not contain any private canary values
0 lib.AssertEq ("PRIVATE_EVENT_CANARY_741" HasSubstring summaryText)
0 lib.AssertEq ("PRIVATE_DESCRIPTION_CANARY_852" HasSubstring summaryText)
0 lib.AssertEq ("PRIVATE_PLAN_CANARY_963" HasSubstring summaryText)
0 lib.AssertEq ("PRIVATE_TXN_CANARY_159" HasSubstring summaryText)

# Redacted TSV must not contain any private canary values
0 lib.AssertEq ("PRIVATE_EVENT_CANARY_741" HasSubstring tsvText)
0 lib.AssertEq ("PRIVATE_DESCRIPTION_CANARY_852" HasSubstring tsvText)
0 lib.AssertEq ("PRIVATE_PLAN_CANARY_963" HasSubstring tsvText)
0 lib.AssertEq ("PRIVATE_TXN_CANARY_159" HasSubstring tsvText)

# έΦΑέΦΑέΦΑ 3. Synthetic transaction inventory with comprehensive scenarios έΦΑέΦΑέΦΑ
txs έΗΡ έθρ
  # 1. Identity-free
  {
    dateέΘΡ"2026-07-01", status_markerέΘΡ"*", descriptionέΘΡ"item1", layer_nameέΘΡ"actual",
    identity_kindέΘΡ"physical_fallback", source_event_idέΘΡ"pos-1", plan_idέΘΡ"", txn_idέΘΡ"",
    allocation_idέΘΡ"", actual_event_idέΘΡ"", execution_envelopeέΘΡ"", postingsέΘΡέθρέθσ, metadataέΘΡέθρέθσ, source_start_lineέΘΡ1
  },
  # 2. Legacy entry-id (unreferenced)
  {
    dateέΘΡ"2026-07-02", status_markerέΘΡ"*", descriptionέΘΡ"item2", layer_nameέΘΡ"actual",
    identity_kindέΘΡ"durable", source_event_idέΘΡ"entry-0123456789abcdef01234567", plan_idέΘΡ"", txn_idέΘΡ"",
    allocation_idέΘΡ"", actual_event_idέΘΡ"", execution_envelopeέΘΡ"", postingsέΘΡέθρέθσ, metadataέΘΡέθρ{keyέΘΡ"event-id", valueέΘΡ"entry-0123456789abcdef01234567", source_lineέΘΡ5}έθσ, source_start_lineέΘΡ4
  },
  # 3. Durable tx-id (plan-linked) έΑΦ TEXTUAL_OTHER family, with plan-id
  {
    dateέΘΡ"2026-07-03", status_markerέΘΡ"*", descriptionέΘΡ"item3", layer_nameέΘΡ"actual",
    identity_kindέΘΡ"durable", source_event_idέΘΡ"daily_groceries_july", plan_idέΘΡ"plan-2026-07-03-wifi", txn_idέΘΡ"",
    allocation_idέΘΡ"", actual_event_idέΘΡ"", execution_envelopeέΘΡ"", postingsέΘΡέθρέθσ, metadataέΘΡέθρ{keyέΘΡ"event-id", valueέΘΡ"daily_groceries_july", source_lineέΘΡ10}, {keyέΘΡ"plan-id", valueέΘΡ"plan-2026-07-03-wifi", source_lineέΘΡ11}έθσ, source_start_lineέΘΡ9
  },
  # 4. Durable TEXTUAL_OTHER (referenced by budget layer row)
  {
    dateέΘΡ"2026-07-04", status_markerέΘΡ"*", descriptionέΘΡ"item4", layer_nameέΘΡ"actual",
    identity_kindέΘΡ"durable", source_event_idέΘΡ"rent_payment_july", plan_idέΘΡ"", txn_idέΘΡ"",
    allocation_idέΘΡ"", actual_event_idέΘΡ"", execution_envelopeέΘΡ"", postingsέΘΡέθρέθσ, metadataέΘΡέθρ{keyέΘΡ"event-id", valueέΘΡ"rent_payment_july", source_lineέΘΡ15}έθσ, source_start_lineέΘΡ14
  },
  # 5. Budget layer row referencing item4 via actual-event-id
  {
    dateέΘΡ"2026-07-04", status_markerέΘΡ"*", descriptionέΘΡ"item5", layer_nameέΘΡ"budget",
    identity_kindέΘΡ"durable", source_event_idέΘΡ"budget_alloc_july", plan_idέΘΡ"", txn_idέΘΡ"",
    allocation_idέΘΡ"", actual_event_idέΘΡ"rent_payment_july", execution_envelopeέΘΡ"", postingsέΘΡέθρέθσ, metadataέΘΡέθρ{keyέΘΡ"event-id", valueέΘΡ"budget_alloc_july", source_lineέΘΡ20}, {keyέΘΡ"actual-event-id", valueέΘΡ"rent_payment_july", source_lineέΘΡ21}έθσ, source_start_lineέΘΡ19
  },
  # 6. Reverse command ID
  {
    dateέΘΡ"2026-07-05", status_markerέΘΡ"*", descriptionέΘΡ"[reverse]item4", layer_nameέΘΡ"actual",
    identity_kindέΘΡ"durable", source_event_idέΘΡ"reverse-9876543210fe", plan_idέΘΡ"", txn_idέΘΡ"",
    allocation_idέΘΡ"", actual_event_idέΘΡ"", execution_envelopeέΘΡ"", postingsέΘΡέθρέθσ, metadataέΘΡέθρ{keyέΘΡ"event-id", valueέΘΡ"reverse-9876543210fe", source_lineέΘΡ25}έθσ, source_start_lineέΘΡ24
  },
  # 7. TEXTUAL_OTHER with source-event-id incoming reference
  {
    dateέΘΡ"2026-07-06", status_markerέΘΡ"*", descriptionέΘΡ"item7", layer_nameέΘΡ"actual",
    identity_kindέΘΡ"durable", source_event_idέΘΡ"subscription_monthly", plan_idέΘΡ"", txn_idέΘΡ"",
    allocation_idέΘΡ"", actual_event_idέΘΡ"", execution_envelopeέΘΡ"", postingsέΘΡέθρέθσ, metadataέΘΡέθρ{keyέΘΡ"event-id", valueέΘΡ"subscription_monthly", source_lineέΘΡ30}έθσ, source_start_lineέΘΡ29
  },
  # 8. Another row referencing item7 via source-event-id
  {
    dateέΘΡ"2026-07-06", status_markerέΘΡ"*", descriptionέΘΡ"item8_ref", layer_nameέΘΡ"actual",
    identity_kindέΘΡ"durable", source_event_idέΘΡ"follow_up_sub", plan_idέΘΡ"", txn_idέΘΡ"",
    allocation_idέΘΡ"", actual_event_idέΘΡ"", execution_envelopeέΘΡ"", postingsέΘΡέθρέθσ, metadataέΘΡέθρ{keyέΘΡ"event-id", valueέΘΡ"follow_up_sub", source_lineέΘΡ35}, {keyέΘΡ"source-event-id", valueέΘΡ"subscription_monthly", source_lineέΘΡ36}έθσ, source_start_lineέΘΡ34
  },
  # 9. TEXTUAL_OTHER with both plan-id and txn-id (several links)
  {
    dateέΘΡ"2026-07-07", status_markerέΘΡ"*", descriptionέΘΡ"item9_multi", layer_nameέΘΡ"actual",
    identity_kindέΘΡ"durable", source_event_idέΘΡ"multi_link_event", plan_idέΘΡ"plan-2026-07-07-rent", txn_idέΘΡ"txn-multi-001",
    allocation_idέΘΡ"", actual_event_idέΘΡ"", execution_envelopeέΘΡ"", postingsέΘΡέθρέθσ, metadataέΘΡέθρ{keyέΘΡ"event-id", valueέΘΡ"multi_link_event", source_lineέΘΡ40}, {keyέΘΡ"plan-id", valueέΘΡ"plan-2026-07-07-rent", source_lineέΘΡ41}, {keyέΘΡ"txn-id", valueέΘΡ"txn-multi-001", source_lineέΘΡ42}, {keyέΘΡ"series", valueέΘΡ"monthly", source_lineέΘΡ43}έθσ, source_start_lineέΘΡ39
  }
έθσ

inv έΗΡ inventory.BuildInventory txs
rows έΗΡ inv.rows
9 lib.AssertEq (έΚι rows)

# Row 1: Identity-free
r1 έΗΡ 0 έΛΣ rows
"IDENTITY_FREE" lib.AssertEq (r1.presence)
"IDENTITY_FREE" lib.AssertEq (r1.disposition)
"not_applicable" lib.AssertEq (r1.provenance_confidence)

# Row 2: Legacy entry-id
r2 έΗΡ 1 έΛΣ rows
"EXPLICIT_EVENT_ID" lib.AssertEq (r2.presence)
"LEGACY_ENTRY_24HEX" lib.AssertEq (r2.lexical_family)
"TSV_MIGRATION_CANDIDATE" lib.AssertEq (r2.provenance_class)
"inferred_from_prefix" lib.AssertEq (r2.provenance_confidence)
"NOT_RECONSTRUCTIBLE" lib.AssertEq (r2.reconstructibility)
"KEEP_NONRECONSTRUCTIBLE" lib.AssertEq (r2.disposition)

# Row 3: TEXTUAL_OTHER with plan-id έΑΦ lexical family does not suppress functional-link detection
r3 έΗΡ 2 έΛΣ rows
"TEXTUAL_OTHER" lib.AssertEq (r3.lexical_family)
1 lib.AssertEq (r3.has_plan_id)
1 lib.AssertEq (r3.has_functional_link)
"KEEP_FUNCTIONAL" lib.AssertEq (r3.disposition)
"PLAN_COMPLETION_CANDIDATE" lib.AssertEq (r3.provenance_class)
"inferred_from_plan_link" lib.AssertEq (r3.provenance_confidence)

# Row 4: TEXTUAL_OTHER referenced via actual-event-id έΑΦ lexical family does not suppress reference detection
r4 έΗΡ 3 έΛΣ rows
"TEXTUAL_OTHER" lib.AssertEq (r4.lexical_family)
1 lib.AssertEq (r4.incoming_reference_count)
"KEEP_REFERENCED" lib.AssertEq (r4.disposition)

# Row 5: Budget layer referencing item4
r5 έΗΡ 4 έΛΣ rows
"TEXTUAL_OTHER" lib.AssertEq (r5.lexical_family)

# Row 6: Reverse command
r6 έΗΡ 5 έΛΣ rows
"REVERSE_COMMAND_CANDIDATE" lib.AssertEq (r6.provenance_class)
"inferred_from_prefix" lib.AssertEq (r6.provenance_confidence)
"NOT_RECONSTRUCTIBLE" lib.AssertEq (r6.reconstructibility)

# Row 7: TEXTUAL_OTHER referenced via source-event-id έΑΦ reference detection is independent of lexical family
r7 έΗΡ 6 έΛΣ rows
"TEXTUAL_OTHER" lib.AssertEq (r7.lexical_family)
1 lib.AssertEq (r7.incoming_reference_count)
"KEEP_REFERENCED" lib.AssertEq (r7.disposition)

# Row 9: TEXTUAL_OTHER with several functional links (plan-id + txn-id + series)
r9 έΗΡ 8 έΛΣ rows
"TEXTUAL_OTHER" lib.AssertEq (r9.lexical_family)
1 lib.AssertEq (r9.has_plan_id)
1 lib.AssertEq (r9.has_txn_id)
1 lib.AssertEq (r9.has_series)
1 lib.AssertEq (r9.has_functional_link)
"KEEP_FUNCTIONAL" lib.AssertEq (r9.disposition)

# έΦΑέΦΑέΦΑ 4. Reference independence: incoming count is independent of lexical family έΦΑέΦΑέΦΑ
# Row 4 (TEXTUAL_OTHER) has exactly 1 incoming reference
# Row 7 (TEXTUAL_OTHER) has exactly 1 incoming reference via source-event-id
# This proves that TEXTUAL_OTHER family does not suppress reference detection
1 lib.AssertEq (r4.incoming_reference_count)
1 lib.AssertEq (r7.incoming_reference_count)
# Disposition is KEEP_REFERENCED regardless of lexical family
"KEEP_REFERENCED" lib.AssertEq (r4.disposition)
"KEEP_REFERENCED" lib.AssertEq (r7.disposition)

# έΦΑέΦΑέΦΑ 5. Duplicate and dangling reference tests έΦΑέΦΑέΦΑ
# No duplicates in the main test fixture
0 lib.AssertEq (inv.duplicate_identity_definitions)
# No dangling references (all reference targets exist as durable event-ids)
0 lib.AssertEq (inv.dangling_references)
# No self-references
0 lib.AssertEq (inv.self_references)

# Test duplicate detection with synthetic duplicate fixture
dupTxs έΗΡ έθρ
  {
    dateέΘΡ"2026-07-01", status_markerέΘΡ"*", descriptionέΘΡ"dup1", layer_nameέΘΡ"actual",
    identity_kindέΘΡ"durable", source_event_idέΘΡ"shared_id", plan_idέΘΡ"", txn_idέΘΡ"",
    allocation_idέΘΡ"", actual_event_idέΘΡ"", execution_envelopeέΘΡ"", postingsέΘΡέθρέθσ, metadataέΘΡέθρ{keyέΘΡ"event-id", valueέΘΡ"shared_id", source_lineέΘΡ5}έθσ, source_start_lineέΘΡ4
  },
  {
    dateέΘΡ"2026-07-02", status_markerέΘΡ"*", descriptionέΘΡ"dup2", layer_nameέΘΡ"actual",
    identity_kindέΘΡ"durable", source_event_idέΘΡ"shared_id", plan_idέΘΡ"", txn_idέΘΡ"",
    allocation_idέΘΡ"", actual_event_idέΘΡ"", execution_envelopeέΘΡ"", postingsέΘΡέθρέθσ, metadataέΘΡέθρ{keyέΘΡ"event-id", valueέΘΡ"shared_id", source_lineέΘΡ10}έθσ, source_start_lineέΘΡ9
  }
έθσ
dupInv έΗΡ inventory.BuildInventory dupTxs
1 lib.AssertEq (dupInv.duplicate_identity_definitions)

# Test dangling reference detection
dangTxs έΗΡ έθρ
  {
    dateέΘΡ"2026-07-01", status_markerέΘΡ"*", descriptionέΘΡ"dang1", layer_nameέΘΡ"actual",
    identity_kindέΘΡ"durable", source_event_idέΘΡ"real_id", plan_idέΘΡ"", txn_idέΘΡ"",
    allocation_idέΘΡ"", actual_event_idέΘΡ"", execution_envelopeέΘΡ"", postingsέΘΡέθρέθσ,
    metadataέΘΡέθρ{keyέΘΡ"event-id", valueέΘΡ"real_id", source_lineέΘΡ5}, {keyέΘΡ"actual-event-id", valueέΘΡ"nonexistent_target", source_lineέΘΡ6}έθσ, source_start_lineέΘΡ4
  }
έθσ
dangInv έΗΡ inventory.BuildInventory dangTxs
1 lib.AssertEq (dangInv.dangling_references)

έΑλOut "test_journal_event_identity_inventory: PASS"
