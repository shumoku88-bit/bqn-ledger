#!/usr/bin/env bqn

lib ÔćÉ ÔÇóImport "test_lib.bqn"
admission ÔćÉ ÔÇóImport "../src_next/source_currency_admission.bqn"

tab ÔćÉ @+9
Line ÔćÉ {­ŁĽŐ fields: Ôłż fields Ôłż┬Ę tab }
Snapshot ÔćÉ {­ŁĽŐ journalÔÇ┐planÔÇ┐budget:
  {
    sources ÔçÉ ÔčĘ
      {source_fileÔçÉ"journal.tsv", requiredÔçÉ1, linesÔçÉjournal},
      {source_fileÔçÉ"plan.tsv", requiredÔçÉ0, linesÔçÉplan},
      {source_fileÔçÉ"budget_alloc.tsv", requiredÔçÉ0, linesÔçÉbudget}
    Ôčę
  }
}
accounts ÔćÉ ÔčĘ"assets:bank"ÔłżtabÔłż"role=asset"ÔłżtabÔłż"currency=JPY", "expenses:food"ÔłżtabÔłż"role=expense"ÔłżtabÔłż"currency=ILS"Ôčę
policyCarrier ÔćÉ admission.policy
strictPolicy ÔćÉ policyCarrier.production_strict
compatibilityPolicy ÔćÉ policyCarrier.legacy_compatibility
explicitRows ÔćÉ Snapshot ÔčĘ
  ÔčĘLine ÔčĘ"2026-07-01", "safe memo", "assets:bank", "expenses:food", "10", "currency=JPY"ÔčęÔčę,
  ÔčĘLine ÔčĘ"2026-07-02", "safe plan", "assets:bank", "expenses:food", "20", "currency=ILS"ÔčęÔčę,
  ÔčĘLine ÔčĘ"2026-07-03", "safe budget", "assets:bank", "expenses:food", "30", "currency=JPY"ÔčęÔčę
Ôčę

strict ÔćÉ admission.Admit ÔčĘstrictPolicy, accounts, explicitRowsÔčę
"ok" lib.AssertEq strict.state
0 lib.AssertEq Ôëá strict.diagnostics
2 lib.AssertEq Ôëá strict.admitted_account_evidence
3 lib.AssertEq Ôëá strict.admitted_row_evidence
ÔčĘ"journal.tsv", "plan.tsv", "budget_alloc.tsv"Ôčę lib.AssertEq ({­ŁĽę.source_file}┬Ę strict.admitted_row_evidence)
ÔčĘ"explicit", "explicit", "explicit"Ôčę lib.AssertEq ({­ŁĽę.provenance}┬Ę strict.admitted_row_evidence)

CheckStrictError ÔćÉ {­ŁĽŐ accountLinesÔÇ┐snapshotÔÇ┐expectedCodeÔÇ┐expectedFileÔÇ┐expectedRow:
  result ÔćÉ admission.Admit ÔčĘstrictPolicy, accountLines, snapshotÔčę
  "error" lib.AssertEq result.state
  0 lib.AssertEq Ôëá result.admitted_account_evidence
  0 lib.AssertEq Ôëá result.admitted_row_evidence
  diagnostic ÔćÉ ÔŐĹ result.diagnostics
  "error" lib.AssertEq diagnostic.severity
  "source_currency_admission" lib.AssertEq diagnostic.stage
  expectedCode lib.AssertEq diagnostic.code
  expectedFile lib.AssertEq diagnostic.source_file
  expectedRow lib.AssertEq diagnostic.source_row
  1
}

# Account missing, empty, duplicate, and unsupported are independently classified.
CheckStrictError ÔčĘÔčĘ"assets:bank"Ôčę, explicitRows, "account_currency_missing", "accounts.tsv", 0Ôčę
CheckStrictError ÔčĘÔčĘ"assets:bank"ÔłżtabÔłż"currency="Ôčę, explicitRows, "account_currency_empty", "accounts.tsv", 0Ôčę
CheckStrictError ÔčĘÔčĘ"assets:bank"ÔłżtabÔłż"currency=JPY"ÔłżtabÔłż"currency=ILS"Ôčę, explicitRows, "account_currency_duplicate", "accounts.tsv", 0Ôčę
CheckStrictError ÔčĘÔčĘ"assets:bank"ÔłżtabÔłż"currency=USD"Ôčę, explicitRows, "account_currency_unsupported", "accounts.tsv", 0Ôčę

# Journal-like missing, empty, duplicate, and unsupported are independently classified.
baseRow ÔćÉ ÔčĘ"2026-07-01", "private memo", "assets:bank", "expenses:food", "999"Ôčę
CheckStrictError ÔčĘaccounts, Snapshot ÔčĘÔčĘLine baseRowÔčę, ÔčĘÔčę, ÔčĘÔčęÔčę, "row_currency_missing", "journal.tsv", 0Ôčę
CheckStrictError ÔčĘaccounts, Snapshot ÔčĘÔčĘLine (baseRow Ôłż ÔčĘ"currency="Ôčę)Ôčę, ÔčĘÔčę, ÔčĘÔčęÔčę, "row_currency_empty", "journal.tsv", 0Ôčę
CheckStrictError ÔčĘaccounts, Snapshot ÔčĘÔčĘLine (baseRow Ôłż ÔčĘ"currency=JPY", "currency=ILS"Ôčę)Ôčę, ÔčĘÔčę, ÔčĘÔčęÔčę, "row_currency_duplicate", "journal.tsv", 0Ôčę
CheckStrictError ÔčĘaccounts, Snapshot ÔčĘÔčĘLine (baseRow Ôłż ÔčĘ"currency=USD"Ôčę)Ôčę, ÔčĘÔčę, ÔčĘÔčęÔčę, "row_currency_unsupported", "journal.tsv", 0Ôčę

# All optional source rows are admitted and their zero-based row indices are retained.
planBad ÔćÉ Snapshot ÔčĘÔčĘÔčę, ÔčĘ"# ignored", Line baseRowÔčę, ÔčĘÔčęÔčę
CheckStrictError ÔčĘaccounts, planBad, "row_currency_missing", "plan.tsv", 1Ôčę
budgetBad ÔćÉ Snapshot ÔčĘÔčĘÔčę, ÔčĘÔčę, ÔčĘ"", Line baseRowÔčęÔčę
CheckStrictError ÔčĘaccounts, budgetBad, "row_currency_missing", "budget_alloc.tsv", 1Ôčę
emptyOptional ÔćÉ admission.Admit ÔčĘstrictPolicy, accounts, Snapshot ÔčĘÔčĘÔčę, ÔčĘÔčę, ÔčĘÔčęÔčęÔčę
"ok" lib.AssertEq emptyOptional.state
0 lib.AssertEq Ôëá emptyOptional.admitted_row_evidence

# Errors collect across supplied account and every journal-like source without partial admission.
multi ÔćÉ admission.Admit ÔčĘstrictPolicy, ÔčĘ"assets:bank"Ôčę, Snapshot ÔčĘÔčĘLine baseRowÔčę, ÔčĘLine (baseRow Ôłż ÔčĘ"currency="Ôčę)Ôčę, ÔčĘLine (baseRow Ôłż ÔčĘ"currency=USD"Ôčę)ÔčęÔčęÔčę
"error" lib.AssertEq multi.state
4 lib.AssertEq Ôëá multi.diagnostics
0 lib.AssertEq Ôëá multi.admitted_account_evidence
0 lib.AssertEq Ôëá multi.admitted_row_evidence

# Compatibility preserves only missing-as-JPY; malformed explicit source stays fatal.
compatMissing ÔćÉ admission.Admit ÔčĘcompatibilityPolicy, ÔčĘ"assets:bank"Ôčę, Snapshot ÔčĘÔčĘLine baseRowÔčę, ÔčĘÔčę, ÔčĘÔčęÔčęÔčę
"ok" lib.AssertEq compatMissing.state
"JPY" lib.AssertEq (ÔŐĹ compatMissing.admitted_account_evidence).currency
"legacy_compatibility" lib.AssertEq (ÔŐĹ compatMissing.admitted_account_evidence).provenance
"JPY" lib.AssertEq (ÔŐĹ compatMissing.admitted_row_evidence).currency
"legacy_compatibility" lib.AssertEq (ÔŐĹ compatMissing.admitted_row_evidence).provenance
compatIls ÔćÉ admission.Admit ÔčĘcompatibilityPolicy, ÔčĘ"assets:bank"ÔłżtabÔłż"currency=ILS"Ôčę, Snapshot ÔčĘÔčĘLine (baseRow Ôłż ÔčĘ"currency=ILS"Ôčę)Ôčę, ÔčĘÔčę, ÔčĘÔčęÔčęÔčę
"ok" lib.AssertEq compatIls.state
"ILS" lib.AssertEq (ÔŐĹ compatIls.admitted_account_evidence).currency
"explicit" lib.AssertEq (ÔŐĹ compatIls.admitted_row_evidence).provenance
compatBad ÔćÉ admission.Admit ÔčĘcompatibilityPolicy, ÔčĘ"assets:bank"ÔłżtabÔłż"currency="Ôčę, Snapshot ÔčĘÔčĘLine (baseRow Ôłż ÔčĘ"currency=USD"Ôčę)Ôčę, ÔčĘÔčę, ÔčĘÔčęÔčęÔčę
"error" lib.AssertEq compatBad.state
2 lib.AssertEq Ôëá compatBad.diagnostics
0 lib.AssertEq Ôëá compatBad.admitted_account_evidence
0 lib.AssertEq Ôëá compatBad.admitted_row_evidence
compatDuplicate ÔćÉ admission.Admit ÔčĘcompatibilityPolicy, ÔčĘ"assets:bank"ÔłżtabÔłż"currency=JPY"ÔłżtabÔłż"currency=ILS"Ôčę, Snapshot ÔčĘÔčĘLine (baseRow Ôłż ÔčĘ"currency=JPY", "currency=ILS"Ôčę)Ôčę, ÔčĘÔčę, ÔčĘÔčęÔčęÔčę
"error" lib.AssertEq compatDuplicate.state
ÔčĘ"account_currency_duplicate", "row_currency_duplicate"Ôčę lib.AssertEq ({­ŁĽę.code}┬Ę compatDuplicate.diagnostics)
0 lib.AssertEq Ôëá compatDuplicate.admitted_account_evidence
0 lib.AssertEq Ôëá compatDuplicate.admitted_row_evidence

# Unknown policy is checked and fail-closed.
unknown ÔćÉ admission.Admit ÔčĘ"future_policy", accounts, explicitRowsÔčę
"error" lib.AssertEq unknown.state
"source_currency_policy_unknown" lib.AssertEq (ÔŐĹ unknown.diagnostics).code
0 lib.AssertEq Ôëá unknown.admitted_account_evidence
0 lib.AssertEq Ôëá unknown.admitted_row_evidence

# Diagnostics are safe summaries: they retain only basename, row, and classification.
privateAccount ÔćÉ "private-account-name"
privateMemo ÔćÉ "private memo"
privateAmount ÔćÉ "999"
privateToken ÔćÉ "currency=SECRET"
privacy ÔćÉ admission.Admit ÔčĘstrictPolicy, ÔčĘprivateAccountÔłżtabÔłżprivateTokenÔčę, Snapshot ÔčĘÔčĘLine ÔčĘ"2026-07-01", privateMemo, "from", "to", privateAmount, privateTokenÔčęÔčę, ÔčĘÔčę, ÔčĘÔčęÔčęÔčę
message ÔćÉ (ÔŐĹ privacy.diagnostics).message
0 lib.AssertEq ÔłĘ┬┤ privateAccount ÔŹĚ message
0 lib.AssertEq ÔłĘ┬┤ privateMemo ÔŹĚ message
0 lib.AssertEq ÔłĘ┬┤ privateAmount ÔŹĚ message
0 lib.AssertEq ÔłĘ┬┤ "SECRET" ÔŹĚ message
"accounts.tsv row 0: account_currency_unsupported" lib.AssertEq message

# An unknown or path-shaped supplied source is rejected without reflecting its value.
privateSourceFile ÔćÉ "/private/example/journal.tsv"
privateSourceSnapshot ÔćÉ {
  sources ÔçÉ ÔčĘ{source_fileÔçÉprivateSourceFile, requiredÔçÉ1, linesÔçÉÔčĘLine (baseRow Ôłż ÔčĘ"currency=JPY"Ôčę)Ôčę}Ôčę
}
privateSource ÔćÉ admission.Admit ÔčĘstrictPolicy, accounts, privateSourceSnapshotÔčę
"error" lib.AssertEq privateSource.state
0 lib.AssertEq Ôëá privateSource.admitted_account_evidence
0 lib.AssertEq Ôëá privateSource.admitted_row_evidence
privateSourceDiagnostic ÔćÉ ÔŐĹ privateSource.diagnostics
"source_currency_source_file_invalid" lib.AssertEq privateSourceDiagnostic.code
"" lib.AssertEq privateSourceDiagnostic.source_kind
"" lib.AssertEq privateSourceDiagnostic.source_file
┬»1 lib.AssertEq privateSourceDiagnostic.source_row
"posting source file invalid" lib.AssertEq privateSourceDiagnostic.message
0 lib.AssertEq ÔłĘ┬┤ privateSourceFile ÔŹĚ privateSourceDiagnostic.message
0 lib.AssertEq ÔłĘ┬┤ privateSourceFile ÔŹĚ privateSourceDiagnostic.source_file

ÔÇóOut "test_src_next_source_currency_admission.bqn: OK"
