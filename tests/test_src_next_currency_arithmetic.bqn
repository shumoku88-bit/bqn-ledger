#!/usr/bin/env bqn

lib έΗΡ έΑλImport "test_lib.bqn"
arith έΗΡ έΑλImport "../src_next/currency_arithmetic.bqn"
dec έΗΡ έΑλImport "../src_next/exact_decimal.bqn"

Row έΗΡ {ΏζΧΛ currencyέΑ┐coefficientέΑ┐scale:
  {
    state έΘΡ "ok",
    currency έΘΡ currency,
    parsed έΘΡ {
      state έΘΡ "ok",
      coefficient έΘΡ coefficient,
      scale έΘΡ scale
    }
  }
}

AssertErrorEmpty έΗΡ {ΏζΧΛ resultέΑ┐message:
  "error" lib.AssertEq result.state
  έθρέθσ lib.AssertEq result.domain
  έθρέθσ lib.AssertEq result.amount_scale
  έθρέθσ lib.AssertEq result.normalized_coefficients
  message lib.AssertEq result.message
}

empty έΗΡ arith.Build έθρέθσ
"ok" lib.AssertEq empty.state
"JPY" lib.AssertEq empty.domain
0 lib.AssertEq empty.amount_scale
έθρέθσ lib.AssertEq empty.normalized_coefficients
"" lib.AssertEq empty.message

jpyRows έΗΡ έθρRow έθρ"JPY", 425, 1έθσ, Row έθρ"JPY", 5, 2έθσ, Row έθρ"JPY", 18, 0έθσέθσ
jpy έΗΡ arith.Build jpyRows
"ok" lib.AssertEq jpy.state
"JPY" lib.AssertEq jpy.domain
2 lib.AssertEq jpy.amount_scale
έθρ4250, 5, 1800έθσ lib.AssertEq jpy.normalized_coefficients

ilsRows έΗΡ έθρRow έθρ"ILS", 425, 1έθσ, Row έθρ"ILS", 5, 2έθσ, Row έθρ"ILS", 18, 0έθσέθσ
ils έΗΡ arith.Build ilsRows
"ok" lib.AssertEq ils.state
"ILS" lib.AssertEq ils.domain
2 lib.AssertEq ils.amount_scale
έθρ4250, 5, 1800έθσ lib.AssertEq ils.normalized_coefficients

# A non-sorted input makes one-to-one input-order preservation explicit.
ordered έΗΡ arith.Build έθρRow έθρ"JPY", 18, 0έθσ, Row έθρ"JPY", 425, 1έθσ, Row έθρ"JPY", 5, 2έθσέθσ
έθρ1800, 4250, 5έθσ lib.AssertEq ordered.normalized_coefficients

mixed έΗΡ arith.Build έθρRow έθρ"JPY", 1, 0έθσ, Row έθρ"ILS", 2, 0έθσέθσ
AssertErrorEmpty έθρmixed, "mixed_currency_domains"έθσ

invalidRow έΗΡ {stateέΘΡ"error", currencyέΘΡ"JPY", parsedέΘΡ{stateέΘΡ"ok", coefficientέΘΡ7, scaleέΘΡ0}}
invalid έΗΡ arith.Build έθρinvalidRow, Row έθρ"JPY", 2, 0έθσέθσ
AssertErrorEmpty έθρinvalid, "invalid_row_evidence"έθσ

invalidParsed έΗΡ {stateέΘΡ"ok", currencyέΘΡ"JPY", parsedέΘΡ{stateέΘΡ"out_of_exact_range", coefficientέΘΡέθρέθσ, scaleέΘΡέθρέθσ}}
invalidParsedResult έΗΡ arith.Build έθρinvalidParsedέθσ
AssertErrorEmpty έθρinvalidParsedResult, "invalid_row_evidence"έθσ

# Start from a coefficient executable evidence proves is exactly admitted by
# the current parser boundary. It remains valid without scale-up, but appending
# one decimal zero must fail closed.
largeParsed έΗΡ dec.Parse "999999999999999"
"ok" lib.AssertEq largeParsed.state
large έΗΡ largeParsed.coefficient
largeBoundary έΗΡ arith.Build έθρRow έθρ"JPY", large, largeParsed.scaleέθσέθσ
"ok" lib.AssertEq largeBoundary.state
έθρlargeέθσ lib.AssertEq largeBoundary.normalized_coefficients

overflow έΗΡ arith.Build έθρRow έθρ"JPY", large, 0έθσ, Row έθρ"JPY", 1, 1έθσέθσ
AssertErrorEmpty έθρoverflow, "normalized_amount_out_of_exact_range"έθσ

έΑλOut "test_src_next_currency_arithmetic.bqn: OK"
