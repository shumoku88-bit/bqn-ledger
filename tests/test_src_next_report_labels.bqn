#!/usr/bin/env bqn

lib ← •Import "test_lib.bqn"
labels ← •Import "../src_next/report_labels.bqn"

"1. 全体サマリ (Snapshot)" lib.AssertEq labels.Text "snapshot.section_title"
"future  : これから" lib.AssertEq labels.Text "planned.future_status"
"ペース診断" lib.AssertEq labels.Text "calc.pace_title"
"== Current Cycle Summary ==" lib.AssertEq labels.Text "cycle.section_title"
"== Planned Payments ==" lib.AssertEq labels.Text "planned.section_title"
"Unit" lib.AssertEq labels.Text "actual.table_unit"
"== Envelope & Budget ==" lib.AssertEq labels.Text "report.envelope_section_title"
"== Account Balances ==" lib.AssertEq labels.Text "balances.section_title"
"== Trial Balance (" lib.AssertEq labels.Text "trial_balance.section_title_prefix"
"食費" lib.AssertEq labels.Text "envelope.fixture_food_like_label"
"食費" lib.AssertEq labels.Text "envelope.fixture_food_like_selector_value"
"〜" lib.AssertEq labels.Text "outlook.range_separator"
"─────────────────────────────" lib.AssertEq labels.Text "outlook.daily_separator"
"envelope" lib.AssertEq labels.Text "outlook.envelope_name_header"
"remaining" lib.AssertEq labels.Text "outlook.envelope_remaining_header"
"/day" lib.AssertEq labels.Text "outlook.envelope_per_day_header"
"|" lib.AssertEq labels.Text "outlook.envelope_column_separator"
