debits в†ђ (({рқ•©.side}ВЁ inconsistentBuilt.rows) в‰ҰВЁ <"debit") / inconsistentBuilt.rows
100 lib.AssertEq (вЉ‘ debits).delta

0 lib.AssertEq proj.AuthorizeArithmeticCurrencyProof {stateв‡ђ"unsupported", domainв‡ђ"", basisв‡ђ"explicit_source_currency", messageв‡ђ"x"}
0 lib.AssertEq proj.AuthorizeArithmeticCurrencyProof {stateв‡ђ"unresolved", domainв‡ђ"JPY", basisв‡ђ"legacy_compatibility", messageв‡ђ"x"}
0 lib.AssertEq proj.AuthorizeArithmeticCurrencyProof {stateв‡ђ"proven", domainв‡ђ"", basisв‡ђ"legacy_compatibility", messageв‡ђ"x"}
0 lib.AssertEq proj.AuthorizeArithmeticCurrencyProof {stateв‡ђ"proven", domainв‡ђ"USD", basisв‡ђ"legacy_compatibility", messageв‡ђ"x"}
0 lib.AssertEq proj.AuthorizeArithmeticCurrencyProof {stateв‡ђ"proven", domainв‡ђ"JPY", basisв‡ђ"forged_basis", messageв‡ђ"x"}
0 lib.AssertEq proj.AuthorizeArithmeticCurrencyProof {domainв‡ђ"JPY", basisв‡ђ"legacy_compatibility", messageв‡ђ"message mentions state"}
0 lib.AssertEq proj.AuthorizeArithmeticCurrencyProof {stateв‡ђ"proven", basisв‡ђ"legacy_compatibility", messageв‡ђ"message mentions domain"}
