# Slice B1 Row Ingestion and Pre-Gate Row Evidence tests
CheckRowEvidence в†ђ {рқ•Љ args:
  lineвЂүexpectedCurrencyвЂүexpectedProvenanceвЂүexpectedStateвЂүexpectedCoefвЂүexpectedScale в†ђ args
  snapshot в†ђ ProofSnapshot вџЁвџЁlineвџ©, вџЁвџ©, вџЁвџ©вџ©
  ev в†ђ вЉ‘ ctx.BuildRowEvidenceFromSnapshot snapshot
  expectedCurrency lib.AssertEq ev.currency
  expectedProvenance lib.AssertEq ev.provenance
  expectedState lib.AssertEq ev.state
  expectedCoef lib.AssertEq ev.parsed.coefficient
  expectedScale lib.AssertEq ev.parsed.scale
  1
}

CheckProofGateFail в†ђ {рқ•Љ args:
  lineвЂүexpectedMsgSubstring в†ђ args
  snapshot в†ђ ProofSnapshot вџЁвџЁlineвџ©, вџЁвџ©, вџЁвџ©вџ©
  proof в†ђ ctx.ResolveArithmeticCurrencyProof snapshot
  "unsupported" lib.AssertEq proof.state
  1 lib.AssertEq в€ЁВө expectedMsgSubstring вҚ· proof.message
  1
}

# 1. Legacy integer JPY success
CheckRowEvidence вџЁLine вџЁ"2026-06-15", "memo", "assets:bank", "expenses:food", "1200"вџ©, "JPY", "legacy_compatibility", "ok", 1200, 0вџ©

# 2. Explicit JPY decimal internal evidence (fails proof gate)
CheckRowEvidence вџЁLine вџЁ"2026-06-15", "memo", "assets:bank", "expenses:food", "12.34", "currency=JPY"вџ©, "JPY", "explicit", "ok", 1234, 2вџ©
CheckProofGateFail вџЁLine вџЁ"2026-06-15", "memo", "assets:bank", "expenses:food", "12.34", "currency=JPY"вџ©, "explicit source currency unsupported"вџ©

# 3. Explicit ILS decimal internal evidence (fails proof gate)
CheckRowEvidence вџЁLine вџЁ"2026-06-15", "memo", "assets:bank", "expenses:food", "42.50", "currency=ILS"вџ©, "ILS", "explicit", "ok", 425, 1вџ©
CheckProofGateFail вџЁLine вџЁ"2026-06-15", "memo", "assets:bank", "expenses:food", "42.50", "currency=ILS"вџ©, "explicit source currency unsupported"вџ©

# 4. Implicit JPY decimal (fails proof gate due to scale > 0)
CheckRowEvidence вџЁLine вџЁ"2026-06-15", "memo", "assets:bank", "expenses:food", "12.34"вџ©, "JPY", "legacy_compatibility", "ok", 1234, 2вџ©
CheckProofGateFail вџЁLine вџЁ"2026-06-15", "memo", "assets:bank", "expenses:food", "12.34"вџ©, "explicit source currency unsupported"вџ©

# 5. Explicit JPY integer (fails proof gate because metadata is explicit)
CheckRowEvidence вџЁLine вџЁ"2026-06-15", "memo", "assets:bank", "expenses:food", "1200", "currency=JPY"вџ©, "JPY", "explicit", "ok", 1200, 0вџ©
CheckProofGateFail вџЁLine вџЁ"2026-06-15", "memo", "assets:bank", "expenses:food", "1200", "currency=JPY"вџ©, "explicit source currency unsupported"вџ©

# 6. Duplicate currency metadata (fails at row evidence stage)
CheckRowEvidence вџЁLine вџЁ"2026-06-15", "memo", "assets:bank", "expenses:food", "1200", "currency=JPY", "currency=JPY"вџ©, "JPY", "explicit", "error", 1200, 0вџ©
CheckProofGateFail вџЁLine вџЁ"2026-06-15", "memo", "assets:bank", "expenses:food", "1200", "currency=JPY", "currency=JPY"вџ©, "duplicate currency metadata"вџ©

# 7. Unsupported currency (fails at row evidence stage)
CheckRowEvidence вџЁLine вџЁ"2026-06-15", "memo", "assets:bank", "expenses:food", "1200", "currency=USD"вџ©, "JPY", "explicit", "error", 1200, 0вџ©
CheckProofGateFail вџЁLine вџЁ"2026-06-15", "memo", "assets:bank", "expenses:food", "1200", "currency=USD"вџ©, "unsupported currency: USD"вџ©

# 8. Invalid decimal syntax (propagates and fails gate on explicit currency)
CheckRowEvidence вџЁLine вџЁ"2026-06-15", "memo", "assets:bank", "expenses:food", "12x", "currency=JPY"вџ©, "JPY", "explicit", "error", вџЁвџ©, вџЁвџ©вџ©
CheckProofGateFail вџЁLine вџЁ"2026-06-15", "memo", "assets:bank", "expenses:food", "12x", "currency=JPY"вџ©, "invalid_decimal_syntax"вџ©

# 9. Parsed coefficient range failure (propagates and fails gate on explicit currency)
CheckRowEvidence вџЁLine вџЁ"2026-06-15", "memo", "assets:bank", "expenses:food", "9007199254740993", "currency=JPY"вџ©, "JPY", "explicit", "error", вџЁвџ©, вџЁвџ©вџ©
CheckProofGateFail вџЁLine вџЁ"2026-06-15", "memo", "assets:bank", "expenses:food", "9007199254740993", "currency=JPY"вџ©, "amount_out_of_exact_range"вџ©

# 10. Empty snapshot regression
emptyProof в†ђ ctx.ResolveArithmeticCurrencyProof ProofSnapshot вџЁвџЁвџ©, вџЁвџ©, вџЁвџ©вџ©
"proven" lib.AssertEq emptyProof.state
