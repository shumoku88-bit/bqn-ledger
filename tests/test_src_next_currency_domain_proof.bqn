#!/usr/bin/env bqn

lib έΗΡ έΑλImport "test_lib.bqn"
ctx έΗΡ έΑλImport "../src_next/context.bqn"
proj έΗΡ έΑλImport "../src_next/projection.bqn"
arith έΗΡ έΑλImport "../src_next/currency_arithmetic.bqn"

tab έΗΡ @+9
Line έΗΡ {ΏζΧΛ fields: έΙ╛ fields έΙ╛┬ρ tab}

ProofSnapshot έΗΡ {ΏζΧΛ jlinesέΑ┐plinesέΑ┐blines:
  {
    sources έΘΡ έθρ
      {source_fileέΘΡ"journal.tsv", requiredέΘΡ1, linesέΘΡjlines},
      {source_fileέΘΡ"plan.tsv", requiredέΘΡ0, linesέΘΡplines},
      {source_fileέΘΡ"budget_alloc.tsv", requiredέΘΡ0, linesέΘΡblines}
    έθσ
  }
}

ResolveProof έΗΡ { ev έΗΡ ctx.BuildRowEvidenceFromSnapshot ΏζΧσ έΜΕ ctx.ResolveArithmeticCurrencyProof έθρev, arith.Build evέθσ }

legacy έΗΡ ctx.BuildContext "fixtures/src-next-golden"
"proven" lib.AssertEq legacy.arithmetic_currency_proof.state
"JPY" lib.AssertEq legacy.arithmetic_currency_proof.domain
"legacy_compatibility" lib.AssertEq legacy.arithmetic_currency_proof.basis
1 lib.AssertEq proj.AuthorizeArithmeticCurrencyProof legacy.arithmetic_currency_proof
1 lib.AssertEq 0 < έΚι legacy.posting_rows

empty έΗΡ ctx.BuildContext "fixtures/src-next-empty-projection"
"proven" lib.AssertEq empty.arithmetic_currency_proof.state
"JPY" lib.AssertEq empty.arithmetic_currency_proof.domain
"empty_source_compatibility" lib.AssertEq empty.arithmetic_currency_proof.basis
1 lib.AssertEq proj.AuthorizeArithmeticCurrencyProof empty.arithmetic_currency_proof
0 lib.AssertEq έΚι empty.posting_rows

explicitJournal έΗΡ ResolveProof ProofSnapshot έθρέθρLine έθρ"2026-06-15", "memo", "assets:bank", "expenses:food", "100", "currency=JPY"έθσέθσ, έθρέθσ, έθρέθσέθσ
"proven" lib.AssertEq explicitJournal.state
"resolved_single_currency" lib.AssertEq explicitJournal.basis
0 lib.AssertEq explicitJournal.amount_scale
1 lib.AssertEq proj.AuthorizeArithmeticCurrencyProof explicitJournal

explicitPlan έΗΡ ResolveProof ProofSnapshot έθρέθρLine έθρ"2026-06-15", "memo", "assets:bank", "expenses:food", "100"έθσέθσ, έθρLine έθρ"2026-06-16", "plan", "assets:bank", "expenses:food", "20", "currency=USD"έθσέθσ, έθρέθσέθσ
"unsupported" lib.AssertEq explicitPlan.state
"explicit_source_currency" lib.AssertEq explicitPlan.basis

explicitBudget έΗΡ ResolveProof ProofSnapshot έθρέθρLine έθρ"2026-06-15", "memo", "assets:bank", "expenses:food", "100"έθσέθσ, έθρέθσ, έθρLine έθρ"2026-06-16", "budget", "assets:bank", "budget:food", "20", "currency="έθσέθσέθσ
"unsupported" lib.AssertEq explicitBudget.state
"explicit_source_currency" lib.AssertEq explicitBudget.basis


precision έΗΡ ResolveProof ProofSnapshot έθρ
  έθρ
    Line έθρ"2026-06-15", "memo currency=JPY", "assets:bank", "expenses:food", "100"έθσ,
    Line έθρ"2026-06-16", "memo", "assets:bank", "expenses:food", "100", "currency_hint=JPY"έθσ,
    Line έθρ"2026-06-17", "memo", "assets:bank", "expenses:food", "100", "note=currency=JPY"έθσ
  έθσ,
  έθρέθσ,
  έθρέθσ
έθσ
"proven" lib.AssertEq precision.state
"JPY" lib.AssertEq precision.domain
"legacy_compatibility" lib.AssertEq precision.basis
1 lib.AssertEq proj.AuthorizeArithmeticCurrencyProof precision

# The canonical snapshot source representation is sources. Extra legacy-looking
# fields must not become a second projection input that can diverge from proof input.
inconsistent έΗΡ {
  journal έΘΡ {source_fileέΘΡ"journal.tsv", requiredέΘΡ1, linesέΘΡέθρLine έθρ"2026-06-15", "dirty", "assets:bank", "expenses:food", "999", "currency=USD"έθσέθσ},
  sources έΘΡ έθρ
    {source_fileέΘΡ"journal.tsv", requiredέΘΡ1, linesέΘΡέθρLine έθρ"2026-06-15", "clean", "assets:bank", "expenses:food", "100"έθσέθσ},
    {source_fileέΘΡ"plan.tsv", requiredέΘΡ0, linesέΘΡέθρέθσ},
    {source_fileέΘΡ"budget_alloc.tsv", requiredέΘΡ0, linesέΘΡέθρέθσ}
  έθσ
}
inconsistentBuilt έΗΡ ctx.BuildAuthorizedRowsFromSnapshot έθρinconsistent, legacy.resolved, legacy.cy.startέθσ
"proven" lib.AssertEq inconsistentBuilt.arithmetic_currency_proof.state
debits έΗΡ (({ΏζΧσ.side}┬ρ inconsistentBuilt.rows) έΚκ┬ρ <"debit") / inconsistentBuilt.rows
100 lib.AssertEq (έΛΣ debits).delta

0 lib.AssertEq proj.AuthorizeArithmeticCurrencyProof {stateέΘΡ"unsupported", domainέΘΡ"", basisέΘΡ"explicit_source_currency", messageέΘΡ"x"}
0 lib.AssertEq proj.AuthorizeArithmeticCurrencyProof {stateέΘΡ"unresolved", domainέΘΡ"JPY", basisέΘΡ"legacy_compatibility", messageέΘΡ"x"}
0 lib.AssertEq proj.AuthorizeArithmeticCurrencyProof {stateέΘΡ"proven", domainέΘΡ"", basisέΘΡ"legacy_compatibility", messageέΘΡ"x"}
0 lib.AssertEq proj.AuthorizeArithmeticCurrencyProof {stateέΘΡ"proven", domainέΘΡ"USD", basisέΘΡ"legacy_compatibility", messageέΘΡ"x"}
0 lib.AssertEq proj.AuthorizeArithmeticCurrencyProof {stateέΘΡ"proven", domainέΘΡ"JPY", basisέΘΡ"forged_basis", messageέΘΡ"x"}
0 lib.AssertEq proj.AuthorizeArithmeticCurrencyProof {domainέΘΡ"JPY", basisέΘΡ"legacy_compatibility", messageέΘΡ"message mentions state"}
0 lib.AssertEq proj.AuthorizeArithmeticCurrencyProof {stateέΘΡ"proven", basisέΘΡ"legacy_compatibility", messageέΘΡ"message mentions domain"}
0 lib.AssertEq proj.AuthorizeArithmeticCurrencyProof {stateέΘΡ"proven", domainέΘΡ"JPY", messageέΘΡ"message mentions basis"}
0 lib.AssertEq proj.AuthorizeArithmeticCurrencyProof {stateέΘΡ"proven", basisέΘΡ"legacy_compatibility", messageέΘΡ"x"}
0 lib.AssertEq proj.AuthorizeArithmeticCurrencyProof {stateέΘΡ"proven", domainέΘΡ"JPY", messageέΘΡ"x"}
0 lib.AssertEq proj.AuthorizeArithmeticCurrencyProof "not-a-proof"

# Slice B1 Row Ingestion and Pre-Gate Row Evidence tests
CheckRowEvidence έΗΡ {ΏζΧΛ args:
  lineέΑ┐expectedCurrencyέΑ┐expectedProvenanceέΑ┐expectedStateέΑ┐expectedCoefέΑ┐expectedScale έΗΡ args
  snapshot έΗΡ ProofSnapshot έθρέθρlineέθσ, έθρέθσ, έθρέθσέθσ
  ev έΗΡ έΛΣ ctx.BuildRowEvidenceFromSnapshot snapshot
  expectedCurrency lib.AssertEq ev.currency
  expectedProvenance lib.AssertEq ev.provenance
  expectedState lib.AssertEq ev.state
  expectedCoef lib.AssertEq ev.parsed.coefficient
  expectedScale lib.AssertEq ev.parsed.scale
  1
}

CheckProofGateFail έΗΡ {ΏζΧΛ args:
  lineέΑ┐expectedMsgSubstring έΗΡ args
  snapshot έΗΡ ProofSnapshot έθρέθρlineέθσ, έθρέθσ, έθρέθσέθσ
  proof έΗΡ ResolveProof snapshot
  "unsupported" lib.AssertEq proof.state
  1 lib.AssertEq έΙρ┬┤ expectedMsgSubstring έΞ╖ proof.message
  1
}

CheckProofGateSuccess έΗΡ {ΏζΧΛ args:
  lineέΑ┐expectedDomainέΑ┐expectedBasisέΑ┐expectedScale έΗΡ args
  snapshot έΗΡ ProofSnapshot έθρέθρlineέθσ, έθρέθσ, έθρέθσέθσ
  proof έΗΡ ResolveProof snapshot
  "proven" lib.AssertEq proof.state
  expectedDomain lib.AssertEq proof.domain
  expectedBasis lib.AssertEq proof.basis
  expectedScale lib.AssertEq proof.amount_scale
  1
}

# 1. Legacy integer JPY success
CheckRowEvidence έθρLine έθρ"2026-06-15", "memo", "assets:bank", "expenses:food", "1200"έθσ, "JPY", "legacy_compatibility", "ok", 1200, 0έθσ

# 2. Explicit JPY decimal internal evidence (succeeds in proof gate)
CheckRowEvidence έθρLine έθρ"2026-06-15", "memo", "assets:bank", "expenses:food", "12.34", "currency=JPY"έθσ, "JPY", "explicit", "ok", 1234, 2έθσ
CheckProofGateSuccess έθρLine έθρ"2026-06-15", "memo", "assets:bank", "expenses:food", "12.34", "currency=JPY"έθσ, "JPY", "resolved_single_currency", 2έθσ

# 3. Explicit ILS decimal internal evidence (succeeds in proof gate)
CheckRowEvidence έθρLine έθρ"2026-06-15", "memo", "assets:bank", "expenses:food", "42.50", "currency=ILS"έθσ, "ILS", "explicit", "ok", 425, 1έθσ
CheckProofGateSuccess έθρLine έθρ"2026-06-15", "memo", "assets:bank", "expenses:food", "42.50", "currency=ILS"έθσ, "ILS", "resolved_single_currency", 1έθσ

# 4. Implicit JPY decimal (succeeds in proof gate)
CheckRowEvidence έθρLine έθρ"2026-06-15", "memo", "assets:bank", "expenses:food", "12.34"έθσ, "JPY", "legacy_compatibility", "ok", 1234, 2έθσ
CheckProofGateSuccess έθρLine έθρ"2026-06-15", "memo", "assets:bank", "expenses:food", "12.34"έθσ, "JPY", "legacy_compatibility", 2έθσ

# 5. Explicit JPY integer (succeeds in proof gate)
CheckRowEvidence έθρLine έθρ"2026-06-15", "memo", "assets:bank", "expenses:food", "1200", "currency=JPY"έθσ, "JPY", "explicit", "ok", 1200, 0έθσ
CheckProofGateSuccess έθρLine έθρ"2026-06-15", "memo", "assets:bank", "expenses:food", "1200", "currency=JPY"έθσ, "JPY", "resolved_single_currency", 0έθσ

# 6. Duplicate currency metadata (fails at row evidence stage)
CheckRowEvidence έθρLine έθρ"2026-06-15", "memo", "assets:bank", "expenses:food", "1200", "currency=JPY", "currency=JPY"έθσ, "JPY", "explicit", "error", 1200, 0έθσ
CheckProofGateFail έθρLine έθρ"2026-06-15", "memo", "assets:bank", "expenses:food", "1200", "currency=JPY", "currency=JPY"έθσ, "duplicate currency metadata"έθσ

# 7. Unsupported currency (fails at row evidence stage)
CheckRowEvidence έθρLine έθρ"2026-06-15", "memo", "assets:bank", "expenses:food", "1200", "currency=USD"έθσ, "JPY", "explicit", "error", 1200, 0έθσ
CheckProofGateFail έθρLine έθρ"2026-06-15", "memo", "assets:bank", "expenses:food", "1200", "currency=USD"έθσ, "unsupported currency: USD"έθσ

# 8. Invalid decimal syntax (propagates and fails gate on explicit currency)
CheckRowEvidence έθρLine έθρ"2026-06-15", "memo", "assets:bank", "expenses:food", "12x", "currency=JPY"έθσ, "JPY", "explicit", "error", έθρέθσ, έθρέθσέθσ
CheckProofGateFail έθρLine έθρ"2026-06-15", "memo", "assets:bank", "expenses:food", "12x", "currency=JPY"έθσ, "invalid_decimal_syntax"έθσ

# 9. Parsed coefficient range failure (propagates and fails gate on explicit currency)
CheckRowEvidence έθρLine έθρ"2026-06-15", "memo", "assets:bank", "expenses:food", "9007199254740993", "currency=JPY"έθσ, "JPY", "explicit", "error", έθρέθσ, έθρέθσέθσ
CheckProofGateFail έθρLine έθρ"2026-06-15", "memo", "assets:bank", "expenses:food", "9007199254740993", "currency=JPY"έθσ, "amount_out_of_exact_range"έθσ

# 10. Empty snapshot regression
emptyProof έΗΡ ResolveProof ProofSnapshot έθρέθρέθσ, έθρέθσ, έθρέθσέθσ
"proven" lib.AssertEq emptyProof.state
"empty_source_compatibility" lib.AssertEq emptyProof.basis

# Focused regression tests for untagged invalid rows (B1 fail-closed error state directly)
# 11. Untagged invalid decimal syntax (fails proof gate directly)
CheckRowEvidence έθρLine έθρ"2026-06-15", "memo", "assets:bank", "expenses:food", "12x"έθσ, "JPY", "legacy_compatibility", "error", έθρέθσ, έθρέθσέθσ
CheckProofGateFail έθρLine έθρ"2026-06-15", "memo", "assets:bank", "expenses:food", "12x"έθσ, "row error in Stage 2 minimal runtime slice"έθσ
CheckProofGateFail έθρLine έθρ"2026-06-15", "memo", "assets:bank", "expenses:food", "12x"έθσ, "invalid_decimal_syntax"έθσ
untaggedInvalidProof έΗΡ ResolveProof ProofSnapshot έθρέθρLine έθρ"2026-06-15", "memo", "assets:bank", "expenses:food", "12x"έθσέθσ, έθρέθσ, έθρέθσέθσ
"unsupported_row_evidence" lib.AssertEq untaggedInvalidProof.basis

# 12. Untagged parsed coefficient range failure (fails proof gate directly)
CheckRowEvidence έθρLine έθρ"2026-06-15", "memo", "assets:bank", "expenses:food", "9007199254740993"έθσ, "JPY", "legacy_compatibility", "error", έθρέθσ, έθρέθσέθσ
CheckProofGateFail έθρLine έθρ"2026-06-15", "memo", "assets:bank", "expenses:food", "9007199254740993"έθσ, "row error in Stage 2 minimal runtime slice"έθσ
CheckProofGateFail έθρLine έθρ"2026-06-15", "memo", "assets:bank", "expenses:food", "9007199254740993"έθσ, "amount_out_of_exact_range"έθσ
untaggedRangeProof έΗΡ ResolveProof ProofSnapshot έθρέθρLine έθρ"2026-06-15", "memo", "assets:bank", "expenses:food", "9007199254740993"έθσέθσ, έθρέθσ, έθρέθσέθσ
"unsupported_row_evidence" lib.AssertEq untaggedRangeProof.basis

έΑλOut "test_src_next_currency_domain_proof.bqn: OK"

