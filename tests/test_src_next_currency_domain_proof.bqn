# The canonical snapshot source representation is sources. Extra legacy-looking
# fields must not become a second projection input that can diverge from proof input.
inconsistent в†ђ {
  journal в‡ђ {source_fileв‡ђ"journal.tsv", requiredв‡ђ1, linesв‡ђвџЁLine вџЁ"2026-06-15", "dirty", "assets:bank", "expenses:food", "999", "currency=USD"вџ©вџ©},
  sources в‡ђ вџЁ
    {source_fileв‡ђ"journal.tsv", requiredв‡ђ1, linesв‡ђвџЁLine вџЁ"2026-06-15", "clean", "assets:bank", "expenses:food", "100"вџ©вџ©},
    {source_fileв‡ђ"plan.tsv", requiredв‡ђ0, linesв‡ђвџЁвџ©},
    {source_fileв‡ђ"budget_alloc.tsv", requiredв‡ђ0, linesв‡ђвџЁвџ©}
  вџ©
}
inconsistentBuilt в†ђ ctx.BuildAuthorizedRowsFromSnapshot вџЁinconsistent, legacy.resolved, legacy.cy.startвџ©
