#!/usr/bin/env bqn

lib вҶҗ вҖўImport "test_lib.bqn"
ctx_mod вҶҗ вҖўImport "../src_next/context.bqn"
actual_comparison вҶҗ вҖўImport "../src_next/actual_comparison.bqn"

# Clean target contract: explicit O, Posting IR/TBDS amounts, and per-key counts.
ctx вҶҗ ctx_mod.BuildContext вҹЁ"fixtures/actual-comparison-numeric-owner-target", "2026-03-05"вҹ©
vm вҶҗ actual_comparison.BuildAt вҹЁctx,"2026-03-05"вҹ©

"ok" lib.AssertEq vm.observation_status
"comparison_active" lib.AssertEq vm.reason
"2026-03-05" lib.AssertEq vm.as_of
"2026-03-01" lib.AssertEq vm.current_start
"2026-03-06" lib.AssertEq vm.current_end_exclusive
"2026-02-01" lib.AssertEq vm.baseline_start
"2026-02-06" lib.AssertEq vm.baseline_end_exclusive
5 lib.AssertEq vm.elapsed_days
0 lib.AssertEq вү vm.diagnostics
5 lib.AssertEq вү vm.table

RowFor вҶҗ {рқ•Ҡ unit:
  matches вҶҗ (unitвҠёвүЎВЁ {3вҠ‘рқ•©}ВЁvm.table) / vm.table
  1 lib.AssertEq вү matches
  вҠ‘matches
}
AssertRow вҶҗ {rowвҶҗRowFor рқ•© вӢ„ рқ•Ё lib.AssertEq 8вҶ“row}

# The dual income-from/expense-to source row contributes once to each distinct
# output key. Transfers and post-O rows do not contribute.
вҹЁ125,100,25,2,1,1,"125%","increased","ok"вҹ© AssertRow "salary"
вҹЁ120,100,20,1,1,0,"120%","increased","ok"вҹ© AssertRow "rent"
вҹЁ75,50,25,3,1,2,"150%","increased","ok"вҹ© AssertRow "food"
вҹЁ30,0,30,1,0,1,"n/a","new","ok"вҹ© AssertRow "new"
вҹЁ0,40,ВҜ40,0,1,ВҜ1,"0%","stopped","ok"вҹ© AssertRow "stopped"
0 lib.AssertEq +Вҙ"savings"вҠёвүЎВЁ{3вҠ‘рқ•©}ВЁvm.table
0 lib.AssertEq +Вҙ"loan"вҠёвүЎВЁ{3вҠ‘рқ•©}ВЁvm.table

text вҶҗ actual_comparison.Format vm
1 lib.AssertEq вҲЁВҙ"src_next_actual_comparison_status: ok"вҚ·text
1 lib.AssertEq вҲЁВҙ"src_next_actual_comparison_row: food lane=variable cur=75 base=50 diff=25 ratio=150% status=increased"вҚ·text

# No previous anchor is normal unavailability, not an error or old
# insufficient_history state.
history_ctx вҶҗ ctx_mod.BuildContext "fixtures/actual-comparison-history-boundary"
history_vm вҶҗ actual_comparison.BuildAt вҹЁhistory_ctx,"2026-03-05"вҹ©
"unavailable" lib.AssertEq history_vm.observation_status
"previous_comparable_anchor_unavailable" lib.AssertEq history_vm.reason
0 lib.AssertEq вү history_vm.table
0 lib.AssertEq вү history_vm.diagnostics
history_human вҶҗ actual_comparison.FormatHuman history_vm
1 lib.AssertEq вҲЁВҙ"status: unavailable"вҚ·history_human
1 lib.AssertEq вҲЁВҙ"ActualжҜ”ијғгҒҜиЎЁзӨәгҒ—гҒҫгҒӣгӮ“"вҚ·history_human

# Explicit observation boundaries never read the real clock.
before_vm вҶҗ actual_comparison.BuildAt вҹЁctx,"2026-02-28"вҹ©
"unavailable" lib.AssertEq before_vm.observation_status
"empty_current_window" lib.AssertEq before_vm.reason
0 lib.AssertEq before_vm.elapsed_days

start_vm вҶҗ actual_comparison.BuildAt вҹЁctx,"2026-03-01"вҹ©
"ok" lib.AssertEq start_vm.observation_status
"2026-03-02" lib.AssertEq start_vm.current_end_exclusive
1 lib.AssertEq start_vm.elapsed_days

after_vm вҶҗ actual_comparison.BuildAt вҹЁctx,"2026-04-10"вҹ©
"ok" lib.AssertEq after_vm.observation_status
"2026-04-01" lib.AssertEq after_vm.current_end_exclusive
31 lib.AssertEq after_vm.elapsed_days

bad_o_vm вҶҗ actual_comparison.BuildAt вҹЁctx,"2026-02-30"вҹ©
"error" lib.AssertEq bad_o_vm.observation_status
"invalid_observation" lib.AssertEq bad_o_vm.reason
0 lib.AssertEq вү bad_o_vm.table

bad_cycle вҶҗ {modeвҮҗ"fixed",startвҮҗ"bad",end_exclusiveвҮҗ"2026-04-01",day_countвҮҗ31}
bad_ctx вҶҗ {baseвҮҗctx.base,as_ofвҮҗctx.as_of,cyвҮҗbad_cycle,resolvedвҮҗctx.resolved,
  posting_rowsвҮҗctx.posting_rows,arithmetic_currency_proofвҮҗctx.arithmetic_currency_proof,
  cubeвҮҗctx.cube,tbdsвҮҗctx.tbds,issuesвҮҗctx.issues}
bad_cycle_vm вҶҗ actual_comparison.BuildAt вҹЁbad_ctx,"2026-03-05"вҹ©
"error" lib.AssertEq bad_cycle_vm.observation_status
"invalid_or_unresolvable_cycle" lib.AssertEq bad_cycle_vm.reason
0 lib.AssertEq вү bad_cycle_vm.table

вҖўOut "test_src_next_actual_comparison.bqn: OK"
