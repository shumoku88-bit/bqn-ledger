#!/usr/bin/env bqn

lib вҶҗ вҖўImport "test_lib.bqn"
ctx_mod вҶҗ вҖўImport "../src_next/context.bqn"
cube_mod вҶҗ вҖўImport "../src_next/cube.bqn"
trial_balance вҶҗ вҖўImport "../src_next/trial_balance.bqn"

# в”Җв”Җ opening-before-cycle fixture в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

ctx вҶҗ ctx_mod.BuildContext "fixtures/src-next-opening-before-cycle"
tb вҶҗ trial_balance.Build вҹЁctx, cube_mod.layer_actualвҹ©

"actual" lib.AssertEq tb.layer_name
"2026-06-15" lib.AssertEq tb.period_start
"2026-08-15" lib.AssertEq tb.period_end_exclusive
4 lib.AssertEq вү  tb.accounts

FindRow вҶҗ {рқ•Ҡ key:
  hits вҶҗ (keyвҠёвүЎВЁ tb.accounts) / вҶ• вү  tb.accounts
  вҠ‘ hits
}

bankIdx вҶҗ FindRow "assets:bank/JPY"
foodIdx вҶҗ FindRow "expenses:food/JPY"
equityIdx вҶҗ FindRow "equity:opening-balances/JPY"

100000 lib.AssertEq bankIdxвҠ‘tb.openings
0 lib.AssertEq bankIdxвҠ‘tb.debits
ВҜ1000 lib.AssertEq bankIdxвҠ‘tb.credits
99000 lib.AssertEq bankIdxвҠ‘tb.closings

0 lib.AssertEq foodIdxвҠ‘tb.openings
1000 lib.AssertEq foodIdxвҠ‘tb.debits
0 lib.AssertEq foodIdxвҠ‘tb.credits
1000 lib.AssertEq foodIdxвҠ‘tb.closings

ВҜ100000 lib.AssertEq equityIdxвҠ‘tb.openings
0 lib.AssertEq equityIdxвҠ‘tb.debits
0 lib.AssertEq equityIdxвҠ‘tb.credits
ВҜ100000 lib.AssertEq equityIdxвҠ‘tb.closings

# Zero-sum: total openings = 0, debits = -credits, total closings = 0
0 lib.AssertEq +Вҙ tb.openings
(+Вҙ tb.debits) lib.AssertEq ВҜ1 Г— (+Вҙ tb.credits)
0 lib.AssertEq +Вҙ tb.closings

# в”Җв”Җ FormatTSV в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

tsv вҶҗ trial_balance.FormatTSV tb
1 lib.AssertEq вҲЁВҙ "account_key\topening"вҚ·tsv
1 lib.AssertEq вҲЁВҙ "assets:bank/JPY\t100000"вҚ·tsv
1 lib.AssertEq вҲЁВҙ "expenses:food/JPY\t0\t1000"вҚ·tsv

# в”Җв”Җ FormatHuman в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

human вҶҗ trial_balance.FormatHuman tb
1 lib.AssertEq вҲЁВҙ "Trial Balance"вҚ·human
1 lib.AssertEq вҲЁВҙ "Zero-sum check"вҚ·human
1 lib.AssertEq вҲЁВҙ "OK"вҚ·human

# в”Җв”Җ Empty fixture в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

emptyCtx вҶҗ ctx_mod.BuildContext "fixtures/src-next-empty-projection"
emptyTb вҶҗ trial_balance.Build вҹЁemptyCtx, cube_mod.layer_actualвҹ©
0 lib.AssertEq +Вҙ emptyTb.closings
0 lib.AssertEq +Вҙ emptyTb.openings
(вү  emptyTb.accounts) lib.AssertEq 6

emptyTsv вҶҗ trial_balance.FormatTSV emptyTb
1 lib.AssertEq вҲЁВҙ "account_key"вҚ·emptyTsv

вҖўOut "test_src_next_trial_balance.bqn: OK"
