#!/usr/bin/env bqn

lib ÔćÉ ÔÇóImport "test_lib.bqn"
source ÔćÉ ÔÇóImport "../src_next/friend_travel_source_event.bqn"

tab ÔćÉ @+9
lf ÔćÉ @+10

Event ÔćÉ {­ŁĽŐ dateÔÇ┐partyÔÇ┐itemÔÇ┐amountÔÇ┐currencyÔÇ┐payerÔÇ┐tripÔÇ┐idÔÇ┐status:
  {dateÔçÉdate, partyÔçÉparty, item_or_categoryÔçÉitem, original_amountÔçÉamount,
   original_currencyÔçÉcurrency, payerÔçÉpayer, trip_idÔçÉtrip, source_event_idÔçÉid, statusÔçÉstatus}
}
Valid ÔćÉ {­ŁĽŐ: Event ÔčĘ"2026-07-20", "Synthetic Friend", "meal", "42.50", "ILS", "friend", "israel-2026", "israel-2026-friend-0001", "pending"Ôčę }
Request ÔćÉ {­ŁĽŐ eventÔÇ┐lines: {eventÔçÉevent, existing_linesÔçÉlines} }

accepted ÔćÉ source.ValidateAndPreview Request ÔčĘValid @, ÔčĘÔčęÔčę
"ok" lib.AssertEq accepted.state
0 lib.AssertEq Ôëáaccepted.diagnostics
1 lib.AssertEq Ôëáaccepted.preview_rows
("2026-07-20"ÔłżtabÔłż"Synthetic Friend"ÔłżtabÔłż"meal"ÔłżtabÔłż"42.50"ÔłżtabÔłż"ILS"ÔłżtabÔłż"friend"ÔłżtabÔłż"israel-2026"ÔłżtabÔłż"israel-2026-friend-0001"ÔłżtabÔłż"pending") lib.AssertEq ÔŐĹaccepted.preview_rows

CheckRejected ÔćÉ {­ŁĽŐ eventÔÇ┐lines:
  result ÔćÉ source.ValidateAndPreview Request ÔčĘevent, linesÔčę
  "error" lib.AssertEq result.state
  0 lib.AssertEq Ôëáresult.preview_rows
  lib.Assert 0 < Ôëáresult.diagnostics
  result
}

CheckRejected ÔčĘEvent ÔčĘ"2026-02-30", "Friend", "meal", "1", "ILS", "friend", "israel-2026", "id", "pending"Ôčę, ÔčĘÔčęÔčę
CheckRejected ÔčĘEvent ÔčĘ"2026-07-20", "Friend", "meal", "0", "ILS", "friend", "israel-2026", "id", "pending"Ôčę, ÔčĘÔčęÔčę
CheckRejected ÔčĘEvent ÔčĘ"2026-07-20", "Friend", "meal", "1.001", "ILS", "friend", "israel-2026", "id", "pending"Ôčę, ÔčĘÔčęÔčę
CheckRejected ÔčĘEvent ÔčĘ"2026-07-20", "Friend", "meal", "1", "JPY", "friend", "israel-2026", "id", "pending"Ôčę, ÔčĘÔčęÔčę
CheckRejected ÔčĘEvent ÔčĘ"2026-07-20", "Friend", "meal", "1", "ILS", "self", "israel-2026", "id", "pending"Ôčę, ÔčĘÔčęÔčę
CheckRejected ÔčĘEvent ÔčĘ"2026-07-20", "Friend", "meal", "1", "ILS", "friend", "other", "id", "pending"Ôčę, ÔčĘÔčęÔčę
CheckRejected ÔčĘEvent ÔčĘ"2026-07-20", "Friend"ÔłżtabÔłż"bad", "meal", "1", "ILS", "friend", "israel-2026", "id", "pending"Ôčę, ÔčĘÔčęÔčę
CheckRejected ÔčĘEvent ÔčĘ"2026-07-20", "Friend", "meal"ÔłżlfÔłż"bad", "1", "ILS", "friend", "israel-2026", "id", "pending"Ôčę, ÔčĘÔčęÔčę
CheckRejected ÔčĘEvent ÔčĘ"2026-07-20", "Friend", "meal", "1", "ILS", "friend", "israel-2026", "", "pending"Ôčę, ÔčĘÔčęÔčę
CheckRejected ÔčĘEvent ÔčĘ"2026-07-20", "Friend", "meal", "1", "ILS", "friend", "israel-2026", "id", "done"Ôčę, ÔčĘÔčęÔčę

line ÔćÉ ÔŐĹaccepted.preview_rows
duplicate ÔćÉ CheckRejected ÔčĘValid @, ÔčĘlineÔčęÔčę
"source_event_id_duplicate" lib.AssertEq (┬»1ÔŐĹduplicate.diagnostics).code
malformed ÔćÉ CheckRejected ÔčĘEvent ÔčĘ"2026-07-21", "Friend", "other", "2", "ILS", "friend", "israel-2026", "id-2", "pending"Ôčę, ÔčĘ"bad"ÔłżtabÔłż"row"ÔčęÔčę
"existing_row_shape_invalid" lib.AssertEq (ÔŐĹmalformed.diagnostics).code
existingDuplicate ÔćÉ source.ValidateExisting ÔčĘline, lineÔčę
"error" lib.AssertEq existingDuplicate.state

# Diagnostics expose fixed contracts, never source values.
privacy ÔćÉ CheckRejected ÔčĘEvent ÔčĘ"private-date", "Private Party"ÔłżtabÔłż"x", "Private Item"ÔłżlfÔłż"x", "987x", "JPY", "self", "private-trip", "private-id", "done"Ôčę, ÔčĘÔčęÔčę
messages ÔćÉ Ôłż({­ŁĽę.messageÔłż"\n"}┬Ęprivacy.diagnostics)
{­ŁĽę Ôőä 0 lib.AssertEq ÔłĘ┬┤­ŁĽęÔŹĚmessages}┬Ę ÔčĘ"private-date", "Private Party", "Private Item", "987x", "private-trip", "private-id"Ôčę

ÔÇóOut "test_src_next_friend_travel_source_event.bqn: OK"
