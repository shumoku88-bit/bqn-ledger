# test_find_section.bqn
lib ‚Üź {
  ToNum ‚áź {
    isneg ‚Üź '-' = ‚äĎ ūĚē©
    s ‚Üź isneg ‚Üď ūĚē©
    d ‚Üź s - ‚äĎ"0"
    val ‚Üź +¬ī d √ó 10 ‚čÜ ‚ĆĹ ‚Üē ‚Č† s
    (1 - 2 √ó isneg) √ó val
  }
}

sec_keys ‚Üź ‚ü®"snapshot","ytd","balances","cycle","envelopes","planned","recent","check","outlook","daily-trend","cycle-consult","cashflow","residual"‚ü©
sec_alias_keys ‚Üź ‚ü®"overview","summary","accounts","account","balance","budget","budgets","plan","plans","schedule","validation","trend","consult","advice","risk","forecast","drift","diff"‚ü©
sec_alias_idx ‚Üź ‚ü®0,0,2,2,2,4,4,5,5,5,7,9,10,10,11,11,12,12‚ü©

FindSectionIdx ‚Üź {
  tok ‚Üź ūĚē©
  Numeric ‚Üź { ūĚēä ‚čĄ
    n ‚Üź lib.ToNum tok
    ((0 < n) ‚ąß n ‚Č§ ‚Č† sec_keys) ? n - 1 ; ¬Į1
  }
  NonNumeric ‚Üź { ūĚēä ‚čĄ
    idxM ‚Üź ‚äĎ sec_keys ‚äź ‚ü® tok ‚ü©
    (idxM < ‚Č† sec_keys) ‚ó∂ ‚ü®
      { ūĚēä ‚čĄ
        idxA ‚Üź ‚äĎ sec_alias_keys ‚äź ‚ü® tok ‚ü©
        (idxA < ‚Č† sec_alias_keys) ‚ó∂ ‚ü® { ūĚēä ‚čĄ ¬Į1 }, { ūĚēä ‚čĄ idxA ‚äĎ sec_alias_idx } ‚ü© @
      },
      { ūĚēä ‚čĄ idxM }
    ‚ü© @
  }
  
  isNum ‚Üź (0 < ‚Č† tok) ‚ąß ‚ąß¬ī tok ‚ąä "0123456789"
  (isNum ‚ó∂ ‚ü® NonNumeric, Numeric ‚ü©) @
}

