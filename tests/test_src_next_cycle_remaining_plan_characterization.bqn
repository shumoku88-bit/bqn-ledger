#!/usr/bin/env bqn

lib ‚Üź ‚ÄĘImport "test_lib.bqn"
ctx_mod ‚Üź ‚ÄĘImport "../src_next/context.bqn"
cs ‚Üź ‚ÄĘImport "../src_next/cycle_summary.bqn"
tbds ‚Üź ‚ÄĘImport "../src_next/tbds.bqn"
proj ‚Üź ‚ÄĘImport "../src_next/projection.bqn"

# 1. Root Context & Normal Case
root_ctx ‚Üź ctx_mod.BuildContext "fixtures/cycle-remaining-plan-characterization"
summary ‚Üź cs.Build root_ctx

# Assert O derivation: C.end_exclusive is 2026-03-01. O is 2026-02-15.
# end_dn (2026-03-01) - as_dn (2026-02-15) = 14 days
14 lib.AssertEq summary.days_remaining

# plan_expense_remaining should be 500 (today-expense 200 + future-expense 300)
# (past-expense 100, future-income 1000, outside-expense 400 are excluded)
500 lib.AssertEq summary.plan_expense_remaining


# Helper to build custom context pointing to subfixture base
MakeCustomCtx ‚Üź {ūĚēä sub_dir:
  {
    base ‚áź sub_dir,
    cy ‚áź root_ctx.cy,
    resolved ‚áź root_ctx.resolved,
    posting_rows ‚áź root_ctx.posting_rows,
    arithmetic_currency_proof ‚áź root_ctx.arithmetic_currency_proof,
    cube ‚áź root_ctx.cube,
    tbds ‚áź root_ctx.tbds,
    issues ‚áź root_ctx.issues
  }
}

MakeCustomCtxWithRows ‚Üź {ūĚēä sub_dir‚ÄŅrows:
  {
    base ‚áź sub_dir,
    cy ‚áź root_ctx.cy,
    resolved ‚áź root_ctx.resolved,
    posting_rows ‚áź rows,
    arithmetic_currency_proof ‚áź root_ctx.arithmetic_currency_proof,
    cube ‚áź root_ctx.cube,
    tbds ‚áź root_ctx.tbds,
    issues ‚áź root_ctx.issues
  }
}

# 2. Subfixture: sub_reverse_journal
# Tests that O derivation is independent of journal source order.
rev_ctx ‚Üź MakeCustomCtx "fixtures/cycle-remaining-plan-characterization/sub_reverse_journal"
rev_sum ‚Üź cs.Build rev_ctx
14 lib.AssertEq rev_sum.days_remaining
500 lib.AssertEq rev_sum.plan_expense_remaining

# 3. Subfixture: sub_completion
# Tests that completed plans (plan_id with actual completion in journal)
# are STILL included in plan_expense_remaining by the current local parser.
comp_ctx ‚Üź MakeCustomCtx "fixtures/cycle-remaining-plan-characterization/sub_completion"
comp_sum ‚Üź cs.Build comp_ctx
300 lib.AssertEq comp_sum.plan_expense_remaining

# 4. Subfixture: sub_invalid_amount
# Tests zero-substitution for non-integer amounts.
# abc -> 0, 100.5 -> 0, 200 -> 200. Total = 200.
inv_amt_ctx ‚Üź MakeCustomCtx "fixtures/cycle-remaining-plan-characterization/sub_invalid_amount"
inv_amt_sum ‚Üź cs.Build inv_amt_ctx
200 lib.AssertEq inv_amt_sum.plan_expense_remaining

# 5. Subfixture: sub_unknown_account
# Tests unknown account exclusion (IsExpenseTo role fallback to empty).
# unknown-acc (300) is excluded, valid-acc (200) is included. Total = 200.
unk_acc_ctx ‚Üź MakeCustomCtx "fixtures/cycle-remaining-plan-characterization/sub_unknown_account"
unk_acc_sum ‚Üź cs.Build unk_acc_ctx
200 lib.AssertEq unk_acc_sum.plan_expense_remaining

# Checked Posting IR side validation for unknown-account
# Read files for sub_unknown_account
loader ‚Üź ‚ÄĘImport "../src_next/loader.bqn"
unk_plan_lines ‚Üź loader.ReadLinesOptional "fixtures/cycle-remaining-plan-characterization/sub_unknown_account/plan.tsv"
shared_journal_lines ‚Üź loader.ReadLinesOptional "fixtures/cycle-remaining-plan-characterization/journal.tsv"
unk_snap ‚Üź {
  sources ‚áź ‚ü®
    {source_file‚áź"journal.tsv", required‚áź1, lines‚áźshared_journal_lines},
    {source_file‚áź"plan.tsv", required‚áź0, lines‚áźunk_plan_lines},
    {source_file‚áź"budget_alloc.tsv", required‚áź0, lines‚áź‚ü®‚ü©}
  ‚ü©
}
unk_proj ‚Üź ctx_mod.BuildCheckedPostingProjectionFromSnapshot ‚ü®unk_snap, root_ctx.resolved, root_ctx.cy.start‚ü©
target_rows ‚Üź (("plan.tsv"‚äł‚Č°¬® {ūĚē©.source_file}¬® unk_proj.posting_rows) ‚ąß (0 = {ūĚē©.source_row}¬® unk_proj.posting_rows)) / unk_proj.posting_rows
2 lib.AssertEq ‚Č† target_rows # Should return debit/credit pair
debit_row ‚Üź ‚äĎ ("debit"‚äł‚Č°¬® {ūĚē©.side}¬® target_rows) / target_rows
"unknown_account" lib.AssertEq debit_row.status
"plan.tsv" lib.AssertEq debit_row.source_file
0 lib.AssertEq debit_row.source_row

# 5b. Structurally unjoinable checked Posting IR evidence
# We create unjoinable rows by dropping the credit row of the future-expense pair (source_row 2).
future_rows ‚Üź (("plan.tsv"‚äł‚Č°¬® {ūĚē©.source_file}¬® root_ctx.posting_rows) ‚ąß (2 = {ūĚē©.source_row}¬® root_ctx.posting_rows)) / root_ctx.posting_rows
2 lib.AssertEq ‚Č† future_rows # Normal checks yield 1 debit and 1 credit row
IsTargetCredit ‚Üź { ("plan.tsv" ‚Č° ūĚē©.source_file) ‚ąß (2 = ūĚē©.source_row) ‚ąß ("credit" ‚Č° ūĚē©.side) }
unjoinable_rows ‚Üź (¬¨ IsTargetCredit¬® root_ctx.posting_rows) / root_ctx.posting_rows

# Current cycle_summary local parser ignores join boundaries and sums all direct source amount texts
unjoinable_ctx ‚Üź MakeCustomCtxWithRows ‚ü®"fixtures/cycle-remaining-plan-characterization", unjoinable_rows‚ü©
unjoinable_sum ‚Üź cs.Build unjoinable_ctx
500 lib.AssertEq unjoinable_sum.plan_expense_remaining

# But the checked rows for source_row 2 do not form exactly one pair (missing credit row)
unjoined_pair ‚Üź (("plan.tsv"‚äł‚Č°¬® {ūĚē©.source_file}¬® unjoinable_rows) ‚ąß (2 = {ūĚē©.source_row}¬® unjoinable_rows)) / unjoinable_rows
1 lib.AssertEq ‚Č† unjoined_pair # Only 1 row (debit) exists, showing structural unjoinability

# 6. Subfixture: sub_invalid_date
# Tests that invalid date format (like "abc") crashes the BQN execution.
# We catch the error and assert it fails.
inv_date_ctx ‚Üź MakeCustomCtx "fixtures/cycle-remaining-plan-characterization/sub_invalid_date"
HasError ‚Üź {ūĚēä:
  # Try to build, if it throws an error return 1, else 0
  ({ūĚēä ‚čĄ cs.Build inv_date_ctx ‚čĄ 0}‚éä{ūĚēä ‚čĄ 1}) @
}
1 lib.AssertEq HasError @

# 7. Subfixture: sub_empty_plan
# Empty plan.tsv returns 0.
empty_plan_ctx ‚Üź MakeCustomCtx "fixtures/cycle-remaining-plan-characterization/sub_empty_plan"
empty_plan_sum ‚Üź cs.Build empty_plan_ctx
0 lib.AssertEq empty_plan_sum.plan_expense_remaining

# 8. Subfixture: sub_no_actual
# No actual journal rows inside cycle: O falls back to cy.start (2026-02-01).
# days_remaining = 2026-03-01 - 2026-02-01 = 28 days.
# future-expense (300) on 2026-02-10 is included. Total = 300.
no_act_ctx ‚Üź MakeCustomCtx "fixtures/cycle-remaining-plan-characterization/sub_no_actual"
no_act_sum ‚Üź cs.Build no_act_ctx
28 lib.AssertEq no_act_sum.days_remaining
300 lib.AssertEq no_act_sum.plan_expense_remaining

# 9. Subfixture: sub_outside_actual
# Actual rows only outside cycle: O remains cy.start (2026-02-01).
# Total = 300.
out_act_ctx ‚Üź MakeCustomCtx "fixtures/cycle-remaining-plan-characterization/sub_outside_actual"
out_act_sum ‚Üź cs.Build out_act_ctx
28 lib.AssertEq out_act_sum.days_remaining
300 lib.AssertEq out_act_sum.plan_expense_remaining

# 10. Fallback: context without base
# Uses fallback_total which is tbds.PlanExpenseAmount (from root_ctx.tbds).
no_base_ctx ‚Üź {
  cy ‚áź root_ctx.cy,
  resolved ‚áź root_ctx.resolved,
  posting_rows ‚áź root_ctx.posting_rows,
  arithmetic_currency_proof ‚áź root_ctx.arithmetic_currency_proof,
  cube ‚áź root_ctx.cube,
  tbds ‚áź root_ctx.tbds,
  issues ‚áź root_ctx.issues
}
no_base_sum ‚Üź cs.Build no_base_ctx
no_base_sum.plan_expense lib.AssertEq no_base_sum.plan_expense_remaining

# 11. Exact-decimal plan input vs local parser
# Reuse "fixtures/currency-usd-single" context.
usd_ctx ‚Üź ctx_mod.BuildContext "fixtures/currency-usd-single"
usd_sum ‚Üź cs.Build usd_ctx
# USD scale is 2, so 49.99 becomes 4999 in TBDS.
# Local parser in PlanExpenseRemaining fails IsIntegerText("49.99"), returning 0.
4999 lib.AssertEq usd_sum.plan_expense
0 lib.AssertEq usd_sum.plan_expense_remaining

# 12. Subfixture: sub_duplicate_plan_id & sub_duplicate_plan_id_rev
# Tests that duplicate plan_id is not treated as an error by current local parser.
# It simply sums up both rows (300 + 200 = 500) and is order-independent.
dup_ctx ‚Üź MakeCustomCtx "fixtures/cycle-remaining-plan-characterization/sub_duplicate_plan_id"
dup_sum ‚Üź cs.Build dup_ctx
500 lib.AssertEq dup_sum.plan_expense_remaining

dup_rev_ctx ‚Üź MakeCustomCtx "fixtures/cycle-remaining-plan-characterization/sub_duplicate_plan_id_rev"
dup_rev_sum ‚Üź cs.Build dup_rev_ctx
500 lib.AssertEq dup_rev_sum.plan_expense_remaining

‚ÄĘOut "test_src_next_cycle_remaining_plan_characterization.bqn: OK"
