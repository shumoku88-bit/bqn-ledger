#!/usr/bin/env bqn

lib έΗΡ έΑλImport "test_lib.bqn"
carrier_module έΗΡ έΑλImport "../src_next/journal_read_only_source_carrier.bqn"
context έΗΡ έΑλImport "../src_next/context.bqn"
trial_balance έΗΡ έΑλImport "../src_next/trial_balance.bqn"
balances έΗΡ έΑλImport "../src_next/balances.bqn"
cube έΗΡ έΑλImport "../src_next/cube.bqn"
ak έΗΡ έΑλImport "../src_next/account_key.bqn"
loader έΗΡ έΑλImport "../src_next/loader.bqn"

base έΗΡ "fixtures/journal-native-three-posting-parity"
cycleStart έΗΡ "2026-08-01"
cy έΗΡ {
  start έΘΡ cycleStart,
  end_exclusive έΘΡ "2026-09-01",
  day_count έΘΡ 31,
  mode έΘΡ "explicit"
}

accountLines έΗΡ loader.ReadLines (base έΙ╛ "/accounts.tsv")
resolved έΗΡ ak.Resolve accountLines
έθρ"assets:anonymous/JPY", "expenses:anonymous-first/JPY", "expenses:anonymous-second/JPY"έθσ lib.AssertEq resolved.account_keys

# Journal text -> admitted Transaction IR via carrier.
raw έΗΡ loader.ReadRaw (base έΙ╛ "/profile.journal")
journalLines έΗΡ (@+10) loader.SplitKeepEmpty raw
carrier έΗΡ {
  source_file έΘΡ "profile.journal",
  lines έΘΡ journalLines
}
carrierResult έΗΡ carrier_module.Build έθρcarrier, resolved, cycleStartέθσ
"ok" lib.AssertEq carrierResult.state
0 lib.AssertEq έΚι carrierResult.diagnostics
1 lib.AssertEq έΚι carrierResult.transactions
transaction έΗΡ έΛΣ carrierResult.transactions
3 lib.AssertEq έΚι transaction.postings

# Successful current Posting IR rows.
journalRows έΗΡ carrierResult.posting_rows
3 lib.AssertEq έΚι journalRows
lib.Assert έΙπ┬┤ {ΏζΧσ.status έΚκ "ok"}┬ρ journalRows
lib.Assert έΙπ┬┤ {ΏζΧσ.source_file έΚκ "profile.journal"}┬ρ journalRows
έθρ800, 300, -1100έθσ lib.AssertEq {ΏζΧσ.delta}┬ρ journalRows
0 lib.AssertEq +┬┤ {ΏζΧσ.delta}┬ρ journalRows

# Existing period-view boundary: Posting IR -> Cube + TBDS.
view έΗΡ context.BuildPeriodView έθρjournalRows, resolved, cyέθσ
3 lib.AssertEq view.cube.valid_count
0 lib.AssertEq view.cube.skipped_count
0 lib.AssertEq έΚι view.cube.skipped_rows
έθρ-1100, 800, 300έθσ lib.AssertEq view.cube.actual_account_totals
12 lib.AssertEq έΚι view.tbds
actualRows έΗΡ (cube.layer_actual = {ΏζΧσ.layer_index}┬ρ view.tbds) / view.tbds
3 lib.AssertEq έΚι actualRows
έθρ"assets:anonymous/JPY", "expenses:anonymous-first/JPY", "expenses:anonymous-second/JPY"έθσ lib.AssertEq {ΏζΧσ.account_key}┬ρ actualRows
έθρ0, 0, 0έθσ lib.AssertEq {ΏζΧσ.opening}┬ρ actualRows
έθρ0, 800, 300έθσ lib.AssertEq {ΏζΧσ.debit_movement}┬ρ actualRows
έθρ-1100, 0, 0έθσ lib.AssertEq {ΏζΧσ.credit_movement}┬ρ actualRows
έθρ-1100, 800, 300έθσ lib.AssertEq {ΏζΧσ.closing}┬ρ actualRows

# Existing Trial Balance builder over the Journal-derived period view.
ctx έΗΡ {cy έΘΡ cy, tbds έΘΡ view.tbds}
tb έΗΡ trial_balance.Build έθρctx, cube.layer_actualέθσ
"2026-08-01" lib.AssertEq tb.period_start
"2026-09-01" lib.AssertEq tb.period_end_exclusive
"actual" lib.AssertEq tb.layer_name
έθρ"assets:anonymous/JPY", "expenses:anonymous-first/JPY", "expenses:anonymous-second/JPY"έθσ lib.AssertEq tb.accounts
έθρ0, 0, 0έθσ lib.AssertEq tb.openings
έθρ0, 800, 300έθσ lib.AssertEq tb.debits
έθρ-1100, 0, 0έθσ lib.AssertEq tb.credits
έθρ-1100, 800, 300έθσ lib.AssertEq tb.closings
1100 lib.AssertEq +┬┤ tb.debits
(-1100) lib.AssertEq +┬┤ tb.credits
0 lib.AssertEq +┬┤ tb.closings

# Existing Balances builder over the Journal-derived period view.
balancesCtx έΗΡ { resolved έΘΡ resolved, tbds έΘΡ view.tbds }
balanceEntriesActual έΗΡ balances.Build balancesCtx

# Setup legacy TSV projection for verification
legacyLines έΗΡ loader.ReadLines (base έΙ╛ "/journal.tsv")
legacySnapshot έΗΡ {
  sources έΘΡ έθρ
    {source_fileέΘΡ"journal.tsv", requiredέΘΡ1, linesέΘΡlegacyLines},
    {source_fileέΘΡ"plan.tsv", requiredέΘΡ0, linesέΘΡέθρέθσ},
    {source_fileέΘΡ"budget_alloc.tsv", requiredέΘΡ0, linesέΘΡέθρέθσ}
  έθσ
}
legacyProjection έΗΡ context.BuildCheckedPostingProjectionFromSnapshot έθρlegacySnapshot, resolved, cycleStartέθσ
"ok" lib.AssertEq legacyProjection.state
legacyRows έΗΡ legacyProjection.posting_rows

legacyView έΗΡ context.BuildPeriodView έθρlegacyRows, resolved, cyέθσ
legacyBalancesCtx έΗΡ { resolved έΘΡ resolved, tbds έΘΡ legacyView.tbds }
balanceEntriesLegacy έΗΡ balances.Build legacyBalancesCtx

# Verify they match
balanceEntriesActual lib.AssertEq balanceEntriesLegacy

# Verify format human and compact methods do not crash and emit nonempty output
humanOutput έΗΡ balances.FormatHuman balanceEntriesActual
compactOutput έΗΡ balances.Format balanceEntriesActual
lib.Assert 0 < έΚι humanOutput
lib.Assert 0 < έΚι compactOutput

έΑλOut "test_journal_read_path_trial_balance_rehearsal.bqn: OK"
