#!/usr/bin/env bqn

lib ‚Üź ‚ÄĘImport "test_lib.bqn"
parser ‚Üź ‚ÄĘImport "../src_next/journal_profile_stage1.bqn"
adapter ‚Üź ‚ÄĘImport "../src_next/journal_posting_ir_stage2a.bqn"
context ‚Üź ‚ÄĘImport "../src_next/context.bqn"
trial_balance ‚Üź ‚ÄĘImport "../src_next/trial_balance.bqn"
balances ‚Üź ‚ÄĘImport "../src_next/balances.bqn"
cube ‚Üź ‚ÄĘImport "../src_next/cube.bqn"
ak ‚Üź ‚ÄĘImport "../src_next/account_key.bqn"
loader ‚Üź ‚ÄĘImport "../src_next/loader.bqn"

base ‚Üź "fixtures/journal-native-three-posting-parity"
cycleStart ‚Üź "2026-08-01"
cy ‚Üź {
  start ‚áź cycleStart,
  end_exclusive ‚áź "2026-09-01",
  day_count ‚áź 31,
  mode ‚áź "explicit"
}

accountLines ‚Üź loader.ReadLines (base ‚ąĺ "/accounts.tsv")
resolved ‚Üź ak.Resolve accountLines
‚ü®"assets:anonymous/JPY", "expenses:anonymous-first/JPY", "expenses:anonymous-second/JPY"‚ü© lib.AssertEq resolved.account_keys

# Journal text -> admitted Transaction IR.
raw ‚Üź ‚ÄĘFChars ("../" ‚ąĺ base ‚ąĺ "/profile.journal")
parsed ‚Üź parser.Parse raw
"ok" lib.AssertEq parsed.state
0 lib.AssertEq ‚Č† parsed.diagnostics
1 lib.AssertEq ‚Č† parsed.transactions
transaction ‚Üź ‚äĎ parsed.transactions
3 lib.AssertEq ‚Č† transaction.postings

# Transaction IR -> successful current Posting IR rows.
journalResult ‚Üź adapter.Build ‚ü®parsed.transactions, resolved, cycleStart‚ü©
"ok" lib.AssertEq journalResult.state
0 lib.AssertEq ‚Č† journalResult.diagnostics
journalRows ‚Üź journalResult.posting_rows
3 lib.AssertEq ‚Č† journalRows
lib.Assert ‚ąß¬ī {ūĚē©.status ‚Č° "ok"}¬® journalRows
lib.Assert ‚ąß¬ī {ūĚē©.source_file ‚Č° "profile.journal"}¬® journalRows
‚ü®800, 300, -1100‚ü© lib.AssertEq {ūĚē©.delta}¬® journalRows
0 lib.AssertEq +¬ī {ūĚē©.delta}¬® journalRows

# Existing period-view boundary: Posting IR -> Cube + TBDS.
view ‚Üź context.BuildPeriodView ‚ü®journalRows, resolved, cy‚ü©
3 lib.AssertEq view.cube.valid_count
0 lib.AssertEq view.cube.skipped_count
0 lib.AssertEq ‚Č† view.cube.skipped_rows
‚ü®-1100, 800, 300‚ü© lib.AssertEq view.cube.actual_account_totals
12 lib.AssertEq ‚Č† view.tbds
actualRows ‚Üź (cube.layer_actual = {ūĚē©.layer_index}¬® view.tbds) / view.tbds
3 lib.AssertEq ‚Č† actualRows
‚ü®"assets:anonymous/JPY", "expenses:anonymous-first/JPY", "expenses:anonymous-second/JPY"‚ü© lib.AssertEq {ūĚē©.account_key}¬® actualRows
‚ü®0, 0, 0‚ü© lib.AssertEq {ūĚē©.opening}¬® actualRows
‚ü®0, 800, 300‚ü© lib.AssertEq {ūĚē©.debit_movement}¬® actualRows
‚ü®-1100, 0, 0‚ü© lib.AssertEq {ūĚē©.credit_movement}¬® actualRows
‚ü®-1100, 800, 300‚ü© lib.AssertEq {ūĚē©.closing}¬® actualRows

# Existing Trial Balance builder over the Journal-derived period view.
ctx ‚Üź {cy ‚áź cy, tbds ‚áź view.tbds}
tb ‚Üź trial_balance.Build ‚ü®ctx, cube.layer_actual‚ü©
"2026-08-01" lib.AssertEq tb.period_start
"2026-09-01" lib.AssertEq tb.period_end_exclusive
"actual" lib.AssertEq tb.layer_name
‚ü®"assets:anonymous/JPY", "expenses:anonymous-first/JPY", "expenses:anonymous-second/JPY"‚ü© lib.AssertEq tb.accounts
‚ü®0, 0, 0‚ü© lib.AssertEq tb.openings
‚ü®0, 800, 300‚ü© lib.AssertEq tb.debits
‚ü®-1100, 0, 0‚ü© lib.AssertEq tb.credits
‚ü®-1100, 800, 300‚ü© lib.AssertEq tb.closings
1100 lib.AssertEq +¬ī tb.debits
(-1100) lib.AssertEq +¬ī tb.credits
0 lib.AssertEq +¬ī tb.closings

# Existing Balances builder over the Journal-derived period view.
balancesCtx ‚Üź { resolved ‚áź resolved, tbds ‚áź view.tbds }
balanceEntriesActual ‚Üź balances.Build balancesCtx

# Setup legacy TSV projection for verification
legacyLines ‚Üź loader.ReadLines (base ‚ąĺ "/journal.tsv")
legacySnapshot ‚Üź {
  sources ‚áź ‚ü®
    {source_file‚áź"journal.tsv", required‚áź1, lines‚áźlegacyLines},
    {source_file‚áź"plan.tsv", required‚áź0, lines‚áź‚ü®‚ü©},
    {source_file‚áź"budget_alloc.tsv", required‚áź0, lines‚áź‚ü®‚ü©}
  ‚ü©
}
legacyProjection ‚Üź context.BuildCheckedPostingProjectionFromSnapshot ‚ü®legacySnapshot, resolved, cycleStart‚ü©
"ok" lib.AssertEq legacyProjection.state
legacyRows ‚Üź legacyProjection.posting_rows

legacyView ‚Üź context.BuildPeriodView ‚ü®legacyRows, resolved, cy‚ü©
legacyBalancesCtx ‚Üź { resolved ‚áź resolved, tbds ‚áź legacyView.tbds }
balanceEntriesLegacy ‚Üź balances.Build legacyBalancesCtx

# Verify they match
balanceEntriesActual lib.AssertEq balanceEntriesLegacy

# Verify format human and compact methods do not crash
humanOutput ‚Üź balances.FormatHuman balanceEntriesActual
compactOutput ‚Üź balances.Format balanceEntriesActual

‚ÄĘOut "test_journal_read_path_trial_balance_rehearsal.bqn: OK"
