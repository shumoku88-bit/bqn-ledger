# journal_native_source_check.bqn
# Mandatory post-write validator for an explicit native Journal candidate.

parser ‚Üź ‚ÄĘImport "../src_next/journal_profile_stage1.bqn"
adapter ‚Üź ‚ÄĘImport "../src_next/journal_posting_ir_stage2a.bqn"
ak ‚Üź ‚ÄĘImport "../src_next/account_key.bqn"
loader ‚Üź ‚ÄĘImport "../src_next/loader.bqn"
decimal ‚Üź ‚ÄĘImport "../src_next/exact_decimal.bqn"

args ‚Üź ‚ÄĘargs
tab ‚Üź @+9
empty ‚Üź ‚ü®‚ü©
Fail ‚Üź {ūĚēä code‚ÄŅmessage: ‚ÄĘOut "ERROR"‚ąĺtab‚ąĺcode‚ąĺtab‚ąĺmessage ‚čĄ ‚ÄĘExit 1}
{ūĚēä‚čĄFail ‚ü®"usage", "expected BASE TARGET DATE DESCRIPTION EVENT_ID and at least two postings"‚ü©}‚ćü(7 > ‚Č† args) @
base ‚Üź 0‚äĎargs
target ‚Üź 1‚äĎargs
dateText ‚Üź 2‚äĎargs
description ‚Üź 3‚äĎargs
eventId ‚Üź 4‚äĎargs
postingArgs ‚Üź 5‚Üďargs

expected ‚Üź empty
{ūĚēä text:
  equalMask ‚Üź '=' = text
  {ūĚēä‚čĄFail ‚ü®"expected_posting_invalid", "expected posting protocol is malformed"‚ü©}‚ćü(1 ‚Č† +¬ī equalMask) @
  i ‚Üź ‚äĎ equalMask / ‚Üē‚Č†text
  account ‚Üź i‚ÜĎtext
  amountText ‚Üź (i+1)‚Üďtext
  negative ‚Üź '-' = ‚äĎ (amountText‚ąĺ"0")
  unsigned ‚Üź negative‚ÜďamountText
  parsedAmount ‚Üź decimal.Parse unsigned
  valid ‚Üź (parsedAmount.state‚Č°"ok") ‚ąß (0=parsedAmount.scale) ‚ąß unsigned‚Č°‚ÄĘFmt parsedAmount.coefficient
  {ūĚēä‚čĄFail ‚ü®"expected_posting_invalid", "expected posting amount is invalid"‚ü©}‚ćü(¬¨valid) @
  delta ‚Üź (1-2√ónegative) √ó parsedAmount.coefficient
  {ūĚēä‚čĄFail ‚ü®"expected_posting_invalid", "expected posting amount is zero"‚ü©}‚ćü(0=delta) @
  expected ‚ąĺ‚Ü© ‚ü®{account_key‚áźaccount, delta‚áźdelta, commodity‚áź"JPY"}‚ü©
}¬®postingArgs
{ūĚēä‚čĄFail ‚ü®"expected_posting_invalid", "expected candidate requires at least two balanced postings"‚ü©}‚ćü((2>‚Č†expected) ‚ą® 0‚Č†+¬ī{ūĚē©.delta}¬®expected) @

raw ‚Üź loader.ReadRaw target
parsed ‚Üź parser.ParseWithProfile ‚ü®raw,"historical_external_plan"‚ü©
{ūĚēä‚čĄFail ‚ü®"native_journal_invalid", "full written native Journal failed parsing or global invariants"‚ü©}‚ćü(parsed.state‚ČĘ"ok") @

resolved ‚Üź ak.Resolve loader.ReadLines (base‚ąĺ"/accounts.tsv")
allPostings ‚Üź ‚ąĺ {ūĚē©.postings}¬® parsed.transactions
{ūĚēä posting:
  mask ‚Üź posting.account_key‚äł‚Č°¬® resolved.accounts
  {ūĚēä‚čĄFail ‚ü®"native_account_unresolved", "every native posting account must resolve exactly once"‚ü©}‚ćü(1‚Č†+¬īmask) @
  idx ‚Üź ‚äĎ mask/‚Üē‚Č†mask
  {ūĚēä‚čĄFail ‚ü®"native_account_currency_invalid", "every native posting account must resolve to JPY"‚ü©}‚ćü("JPY"‚ČĘidx‚äĎresolved.currencies) @
  {ūĚēä‚čĄFail ‚ü®"native_posting_invalid", "every native posting must be explicit nonzero JPY exact integer evidence"‚ü©}‚ćü((0=posting.delta) ‚ą® posting.commodity‚ČĘ"JPY") @
}¬®allPostings

checked ‚Üź adapter.Build ‚ü®parsed.transactions, resolved, dateText‚ü©
{ūĚēä‚čĄFail ‚ü®"native_posting_ir_invalid", "checked Stage 2A rejected the full written Journal"‚ü©}‚ćü(checked.state‚ČĘ"ok") @

matching ‚Üź ({(ūĚē©.identity_kind‚Č°"durable") ‚ąß ūĚē©.source_event_id‚Č°eventId}¬®parsed.transactions)/parsed.transactions
{ūĚēä‚čĄFail ‚ü®"native_candidate_identity_invalid", "new durable event must exist exactly once"‚ü©}‚ćü(1‚Č†‚Č†matching) @
candidate ‚Üź ‚äĎmatching
expectedAccounts ‚Üź {ūĚē©.account_key}¬®expected
expectedAmounts ‚Üź {ūĚē©.delta}¬®expected
actualAccounts ‚Üź {ūĚē©.account_key}¬®candidate.postings
actualAmounts ‚Üź {ūĚē©.delta}¬®candidate.postings
commoditiesOk ‚Üź ‚ąß¬ī {ūĚē©.commodity‚Č°"JPY"}¬®candidate.postings
postingIndexesOk ‚Üź (‚Üē‚Č†candidate.postings) ‚Č° {ūĚē©.posting_index}¬®candidate.postings
candidateOk ‚Üź (candidate.date‚Č°dateText) ‚ąß (candidate.description‚Č°description) ‚ąß (candidate.source_event_id‚Č°eventId) ‚ąß (candidate.identity_kind‚Č°"durable") ‚ąß (candidate.status_marker='*') ‚ąß (candidate.layer_name‚Č°"actual") ‚ąß ((‚Č†candidate.postings)=‚Č†expected) ‚ąß postingIndexesOk ‚ąß (actualAccounts‚Č°expectedAccounts) ‚ąß (actualAmounts‚Č°expectedAmounts) ‚ąß commoditiesOk
{ūĚēä‚čĄFail ‚ü®"native_candidate_mismatch", "written candidate does not exactly equal previewed candidate"‚ü©}‚ćü(¬¨candidateOk) @

‚ÄĘOut "OK"‚ąĺtab‚ąĺ"NATIVE_JOURNAL_CANDIDATE"‚ąĺtab‚ąĺeventId‚ąĺtab‚ąĺ(‚ÄĘFmt ‚Č†candidate.postings)
