  isMeta ‚Üź (indentCount > 0) ‚ąß (0 < ‚Č†trimmed) ‚ąß (';' = ‚äĎ (trimmed ‚ąĺ " "))
  isLayerActual ‚Üź isMeta ‚ąß (trimmed ‚Č° "; layer: actual")
  isCurrencyJpy ‚Üź isMeta ‚ąß (trimmed ‚Č° "; currency: JPY")
  {
